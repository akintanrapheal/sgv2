@model SterlingLams.Web.Models.Domain.Register
@{
    ViewData["Title"] = "POS";
    var session = ViewData["Session"] as SterlingLams.Web.Models.Domain.TillSession;
    var cashierName = ViewData["CashierName"]?.ToString() ?? User.Identity?.Name ?? "";
}

@Html.AntiForgeryToken()

<div class="h-screen flex flex-col bg-neutral-100 overflow-hidden select-none">

    <!-- ── Top bar ───────────────────────────────────────────────────────── -->
    <header class="flex items-center gap-3 px-4 py-2 bg-neutral-900 text-white flex-shrink-0">
        <!-- Menu -->
        <button type="button" id="hamburger-btn"
                class="relative flex-shrink-0 w-8 h-8 flex items-center justify-center rounded hover:bg-neutral-800 transition-colors" title="Menu">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <span id="hamburger-dot" class="hidden absolute top-1 right-1 w-2 h-2 rounded-full bg-brand-500"></span>
        </button>
        <!-- Logo -->
        <img src="~/images/sg-logo.png" alt="Sterlin Glams" class="h-7 object-contain flex-shrink-0 bg-white rounded-md px-1.5 py-0.5" />
        <div class="flex-1 min-w-0">
            <p class="text-xs font-medium text-white leading-none">@Model.Store?.Name</p>
            <p class="text-[10px] text-neutral-400 leading-none mt-0.5">@Model.Name</p>
        </div>
        <div class="flex items-center gap-4">
            <div class="text-right">
                <p class="text-xs text-neutral-300 tabular-nums" id="till-clock"></p>
                <p class="text-[10px] text-neutral-500" id="till-date-top"></p>
            </div>
            <div class="h-5 w-px bg-neutral-700"></div>
            <div class="flex items-center gap-1.5">
                <div class="w-6 h-6 rounded-full bg-brand-500 flex items-center justify-center text-[10px] font-medium">
                    @(cashierName.Length > 0 ? cashierName.Substring(0, 1).ToUpper() : "?")
                </div>
                <span class="text-xs text-neutral-300">@cashierName</span>
            </div>
        </div>
    </header>

    <!-- ── Side menu ─────────────────────────────────────────────────────── -->
    <div id="menu-overlay" class="hidden fixed inset-0 bg-black/40 z-40"></div>
    <div id="till-menu" class="fixed inset-y-0 left-0 w-72 max-w-[85vw] bg-white z-50 shadow-2xl -translate-x-full transition-transform duration-200 flex flex-col">
        <div class="flex items-center justify-between px-4 py-3 bg-neutral-900 text-white flex-shrink-0">
            <div class="flex items-center gap-2 min-w-0">
                <img src="~/images/sg-logo.png" alt="Sterlin Glams" class="h-6 object-contain flex-shrink-0 bg-white rounded-md px-1 py-0.5" />
                <span class="text-sm font-medium truncate">@Model.Store?.Name</span>
            </div>
            <button type="button" id="menu-close-btn" class="text-neutral-400 hover:text-white transition-colors flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <nav class="flex-1 overflow-y-auto py-2">
            <p class="px-4 pt-3 pb-1 text-[10px] font-semibold uppercase tracking-wide text-neutral-400">Admin</p>
            <button type="button" id="till-cashup-btn" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 transition-colors text-left">
                <svg class="w-5 h-5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 10-8 0v2h8z"/></svg>
                Close session
            </button>
            <button type="button" id="menu-cashinout-btn" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 transition-colors text-left">
                <svg class="w-5 h-5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Cash in / out
            </button>
            <button type="button" onclick="window.open(window.__posBase + '/Xreport','_blank')" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 transition-colors text-left">
                <svg class="w-5 h-5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                X-report (read)
            </button>
            <button type="button" id="menu-changeregister-btn" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 transition-colors text-left">
                <svg class="w-5 h-5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                Change register
            </button>
            <button type="button" id="menu-sync-btn" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 transition-colors text-left">
                <svg class="w-5 h-5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999A5.5 5.5 0 105.5 15"/></svg>
                Sync with cloud
                <span id="sync-pending-count" class="hidden ml-auto inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full bg-amber-500 text-white text-[10px] font-semibold">0</span>
            </button>
            <p id="sync-status" class="px-4 pb-1 text-[10px] text-neutral-400"></p>

            <p class="px-4 pt-4 pb-1 text-[10px] font-semibold uppercase tracking-wide text-neutral-400">Sales</p>
            <button type="button" id="till-held-btn" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 transition-colors text-left">
                <svg class="w-5 h-5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Held sales
                <span id="till-held-count" class="hidden ml-auto inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full bg-brand-500 text-white text-[10px] font-semibold">0</span>
            </button>
            <button type="button" id="till-refund-btn" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 transition-colors text-left">
                <svg class="w-5 h-5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h10a4 4 0 014 4v1m-4-9l-4 4 4 4"/></svg>
                Refund
            </button>
            <button type="button" id="menu-receipts-btn" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 transition-colors text-left">
                <svg class="w-5 h-5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
                Recent receipts
            </button>
            <button type="button" id="menu-pickup-btn" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 transition-colors text-left">
                <svg class="w-5 h-5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/></svg>
                Verify pickup
            </button>

            <p class="px-4 pt-4 pb-1 text-[10px] font-semibold uppercase tracking-wide text-neutral-400">Stock</p>
            <button type="button" id="menu-stocklookup-btn" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 transition-colors text-left">
                <svg class="w-5 h-5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                Stock Lookup
            </button>
            <button type="button" id="menu-sendstock-btn" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 transition-colors text-left">
                <svg class="w-5 h-5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 100-4h14a2 2 0 100 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
                Send Stock
            </button>
            <button type="button" id="menu-receivestock-btn" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 transition-colors text-left">
                <svg class="w-5 h-5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
                Receive Stock
                <span id="receivestock-badge" class="hidden ml-auto min-w-[18px] h-[18px] px-1 rounded-full bg-brand-500 text-white text-[10px] leading-[18px] text-center font-semibold"></span>
            </button>
            <button type="button" id="menu-transferhistory-btn" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 transition-colors text-left">
                <svg class="w-5 h-5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Transfer History
            </button>
        </nav>
        <div class="border-t border-neutral-100 p-2 flex-shrink-0">
            <form asp-controller="Pos" asp-action="Logout" method="post">
                <button type="submit" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 transition-colors text-left">
                    <svg class="w-5 h-5 flex-shrink-0 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    Sign out
                </button>
            </form>
        </div>
    </div>

    <!-- ── Body ──────────────────────────────────────────────────────────── -->
    <div class="flex-1 flex overflow-hidden">

        <!-- ── Left panel: categories / products ─────────────────────────── -->
        <div class="flex-1 flex flex-col overflow-hidden">

            <!-- Search bar + breadcrumb -->
            <div class="flex items-center gap-2 px-3 py-2 bg-white border-b border-neutral-200 flex-shrink-0">
                <button type="button" id="home-btn"
                        class="hidden flex-shrink-0 items-center gap-1 text-xs text-brand-500 hover:text-brand-700 transition-colors font-medium">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                    </svg>
                    Categories
                </button>
                <div id="breadcrumb-divider" class="hidden text-neutral-300 text-sm">›</div>
                <span id="breadcrumb-cat" class="hidden text-xs font-medium text-neutral-700 truncate"></span>
                <div class="flex-1 relative">
                    <svg class="w-4 h-4 text-neutral-400 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                    <input id="till-search" type="text" autocomplete="off" placeholder="Search or scan barcode…"
                           class="w-full pl-9 pr-4 py-2 text-sm bg-neutral-50 border border-neutral-200 rounded-lg focus:outline-none focus:border-brand-500 focus:bg-white transition-colors" />
                </div>
                <button type="button" id="quick-item-btn" title="Add a one-off / un-barcoded item"
                        class="flex-shrink-0 flex items-center gap-1 px-3 py-2 text-xs font-medium text-brand-600 border border-brand-200 rounded-lg hover:bg-brand-50 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
                    Quick item
                </button>
            </div>

            <!-- Category grid / product grid -->
            <div class="flex-1 overflow-y-auto p-3">

                <!-- Category tiles -->
                <div id="cat-grid" class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-5 gap-2.5"></div>

                <!-- Product grid (hidden initially) -->
                <div id="till-results" class="hidden grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2.5"></div>

            </div>
        </div>

        <!-- ── Right panel: tabs + cart ──────────────────────────────────── -->
        <div class="w-72 xl:w-80 bg-white border-l border-neutral-200 flex flex-col flex-shrink-0">

            <!-- Tab bar -->
            <div class="flex border-b border-neutral-200 flex-shrink-0">
                <button type="button" data-tab="products" class="till-tab flex-1 flex flex-col items-center py-2.5 gap-0.5 border-b-2 border-brand-500 text-brand-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                    </svg>
                    <span class="text-[10px] font-medium uppercase tracking-wide">Products</span>
                </button>
                <button type="button" data-tab="customers" class="till-tab flex-1 flex flex-col items-center py-2.5 gap-0.5 border-b-2 border-transparent text-neutral-400 hover:text-neutral-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <span class="text-[10px] font-medium uppercase tracking-wide">Customers</span>
                </button>
                <button type="button" data-tab="orders" class="till-tab flex-1 flex flex-col items-center py-2.5 gap-0.5 border-b-2 border-transparent text-neutral-400 hover:text-neutral-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                    <span class="text-[10px] font-medium uppercase tracking-wide">Orders</span>
                </button>
            </div>

            <!-- PRODUCTS tab (cart) -->
            <div id="tab-products" class="flex-1 flex flex-col overflow-hidden">
                <!-- Attached customer banner -->
                <div id="customer-banner" class="hidden flex items-center gap-2 px-3 py-2 bg-brand-50 border-b border-brand-100 flex-shrink-0">
                    <svg class="w-4 h-4 text-brand-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    <div class="flex-1 min-w-0">
                        <p id="customer-banner-name" class="text-xs font-medium text-brand-700 truncate"></p>
                        <p id="customer-banner-phone" class="text-[10px] text-brand-400 truncate"></p>
                    </div>
                    <button type="button" id="customer-remove" class="text-brand-300 hover:text-red-400 transition-colors flex-shrink-0" title="Remove customer">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                    </button>
                </div>
                <!-- Cart line items -->
                <div id="till-cart" class="flex-1 overflow-y-auto">
                    <div id="cart-empty" class="flex flex-col items-center justify-center h-full text-center px-6 py-8">
                        <svg class="w-12 h-12 text-neutral-200 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.5 6h13M9 21a1 1 0 100-2 1 1 0 000 2zm10 0a1 1 0 100-2 1 1 0 000 2z"/>
                        </svg>
                        <p class="text-sm font-medium text-neutral-400">Add an item</p>
                        <p class="text-xs text-neutral-300 mt-1">Tap a product to add to the transaction</p>
                    </div>
                    <div id="cart-items" class="hidden divide-y divide-neutral-100 px-3 py-1"></div>
                </div>

                <!-- Cart summary -->
                <div class="border-t border-neutral-200 flex-shrink-0">
                    <div class="px-4 py-2 space-y-1 text-xs text-neutral-500 bg-neutral-50">
                        <div class="flex justify-between">
                            <span>ITEMS</span>
                            <span id="cart-count" class="font-medium text-neutral-700">0</span>
                        </div>
                        <div class="flex justify-between">
                            <span>TOTAL DISCOUNT</span>
                            <span id="cart-total-discount" class="font-medium text-emerald-600">₦0</span>
                        </div>
                        <div id="till-loyalty-row" class="hidden flex justify-between items-center">
                            <span>LOYALTY <span id="till-loyalty-bal" class="text-neutral-400"></span></span>
                            <span class="flex items-center gap-2">
                                <span id="till-loyalty-disc" class="font-medium text-emerald-600"></span>
                                <button type="button" id="till-loyalty-btn" class="text-[11px] px-2 py-0.5 rounded border transition-colors"></button>
                            </span>
                        </div>
                        <div class="flex justify-between text-sm font-semibold text-neutral-900 border-t border-neutral-200 pt-1.5 mt-1.5">
                            <span>TOTAL</span>
                            <span id="till-total">₦0</span>
                        </div>
                        <div class="flex justify-between font-medium text-neutral-700">
                            <span>DUE</span>
                            <span id="till-due">₦0</span>
                        </div>
                    </div>

                    <!-- Cash tendered row (cash method only) -->
                    <div id="till-cash-row" class="px-3 pb-2 bg-neutral-50">
                        <div class="flex gap-2 items-center">
                            <input id="till-tendered" type="number" min="0" step="any" placeholder="Cash received (₦)"
                                   class="flex-1 border border-neutral-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-500 bg-white" />
                            <span class="text-xs text-neutral-400">Change: <span id="till-change" class="font-medium text-neutral-700">₦0</span></span>
                        </div>
                    </div>

                    <!-- Payment method -->
                    <div class="px-3 pb-2 bg-neutral-50">
                        <div class="flex gap-1.5" id="till-methods">
                            <button type="button" data-method="Cash" class="till-method flex-1 border-2 border-brand-500 bg-brand-50 text-brand-700 rounded-lg py-1.5 text-xs font-medium">Cash</button>
                            <button type="button" data-method="Card" class="till-method flex-1 border border-neutral-200 text-neutral-600 rounded-lg py-1.5 text-xs font-medium hover:border-neutral-300">Card</button>
                            <button type="button" data-method="Transfer" class="till-method flex-1 border border-neutral-200 text-neutral-600 rounded-lg py-1.5 text-xs font-medium hover:border-neutral-300">Transfer</button>
                            <button type="button" data-method="Split" class="till-method flex-1 border border-neutral-200 text-neutral-600 rounded-lg py-1.5 text-xs font-medium hover:border-neutral-300">Split</button>
                        </div>
                        <p id="till-split-summary" class="hidden mt-1.5 text-[11px] text-neutral-500"></p>
                    </div>

                    <!-- Customer-required hint (shown when cart has items but no customer attached) -->
                    <div id="till-customer-hint" class="hidden px-3 pb-2 bg-neutral-50 text-[11px] text-amber-600 flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Attach a customer to take payment.
                    </div>

                    <!-- Action buttons: DELETE | HOLD | PAY -->
                    <div class="flex gap-0 border-t border-neutral-200">
                        <button type="button" id="till-void-btn"
                                class="flex-1 flex flex-col items-center justify-center gap-1 py-3 text-red-400 hover:bg-red-50 transition-colors border-r border-neutral-200">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                            <span class="text-[10px] font-medium uppercase tracking-wide">Delete</span>
                        </button>
                        <button type="button" id="till-hold-btn"
                                class="flex-1 flex flex-col items-center justify-center gap-1 py-3 text-neutral-400 hover:bg-neutral-50 transition-colors border-r border-neutral-200">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <span class="text-[10px] font-medium uppercase tracking-wide">Hold</span>
                        </button>
                        <button id="till-pay" type="button" disabled
                                class="flex-2 w-28 flex flex-col items-center justify-center gap-1 py-3 bg-brand-500 text-white hover:bg-brand-600 transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                            </svg>
                            <span class="text-[10px] font-semibold uppercase tracking-wide">Pay</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- CUSTOMERS tab -->
            <div id="tab-customers" class="hidden flex-1 flex flex-col overflow-hidden">
                <div class="p-3 border-b border-neutral-100 flex-shrink-0">
                    <input id="cust-search" type="text" autocomplete="off" placeholder="Search name or phone…"
                           class="w-full border border-neutral-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-500" />
                </div>
                <div id="cust-results" class="flex-1 overflow-y-auto divide-y divide-neutral-100 text-sm">
                    <p class="text-center text-neutral-400 py-6 text-xs">Search for a customer, or add a new one below.</p>
                </div>
                <!-- Add new customer -->
                <div class="border-t border-neutral-200 flex-shrink-0 bg-neutral-50">
                    <button type="button" id="cust-add-toggle"
                            class="w-full flex items-center justify-center gap-1.5 py-2.5 text-xs font-medium text-brand-600 hover:bg-brand-50 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
                        Add new customer
                    </button>
                    <div id="cust-add-form" class="hidden px-3 pb-3 space-y-2">
                        <div class="flex gap-2">
                            <input id="cust-first" type="text" placeholder="First name" class="flex-1 min-w-0 border border-neutral-200 rounded-lg px-2.5 py-2 text-sm focus:outline-none focus:border-brand-500" />
                            <input id="cust-last" type="text" placeholder="Last name" class="flex-1 min-w-0 border border-neutral-200 rounded-lg px-2.5 py-2 text-sm focus:outline-none focus:border-brand-500" />
                        </div>
                        <input id="cust-phone" type="tel" placeholder="Phone" class="w-full border border-neutral-200 rounded-lg px-2.5 py-2 text-sm focus:outline-none focus:border-brand-500" />
                        <input id="cust-email" type="email" placeholder="Email (optional)" class="w-full border border-neutral-200 rounded-lg px-2.5 py-2 text-sm focus:outline-none focus:border-brand-500" />
                        <button type="button" id="cust-save"
                                class="w-full bg-brand-500 text-white rounded-lg py-2.5 text-sm font-semibold hover:bg-brand-600 transition-colors">Save &amp; attach</button>
                    </div>
                </div>
            </div>

            <!-- ORDERS tab -->
            <div id="tab-orders" class="hidden flex-1 flex flex-col overflow-hidden">
                <div class="px-3 py-2 border-b border-neutral-100">
                    <p class="text-xs font-medium uppercase tracking-wide text-neutral-400">Recent orders</p>
                </div>
                <div id="orders-list" class="flex-1 overflow-y-auto divide-y divide-neutral-100 text-xs">
                    <p class="text-center text-neutral-400 py-6">Loading…</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Item Note / Discount modal ────────────────────────────────────────── -->
<div id="item-modal" class="hidden fixed inset-0 z-50 bg-black/50 flex items-end sm:items-center justify-center p-4">
    <div class="bg-white rounded-xl w-full max-w-sm overflow-hidden">
        <!-- Header -->
        <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-100">
            <p id="modal-item-name" class="text-sm font-semibold text-neutral-800 truncate flex-1 mr-3"></p>
            <button type="button" id="item-modal-close" class="text-neutral-400 hover:text-neutral-700 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <!-- Tabs -->
        <div class="flex border-b border-neutral-100">
            <button type="button" id="modal-tab-notes" class="flex-1 py-3 text-sm font-semibold tracking-wide text-brand-600 border-b-2 border-brand-500 transition-colors">NOTES</button>
            <button type="button" id="modal-tab-discount" class="flex-1 py-3 text-sm font-semibold tracking-wide text-neutral-400 transition-colors">DISCOUNT</button>
        </div>

        <!-- Notes panel -->
        <div id="modal-notes-panel" class="p-5">
            <p class="text-xs font-medium text-neutral-500 mb-2">Note</p>
            <div class="relative">
                <textarea id="item-note-input" rows="3" placeholder="Add a note…"
                    class="w-full border border-neutral-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-500 resize-none pr-8"></textarea>
                <button type="button" id="item-note-clear" class="absolute right-2 top-2 text-neutral-300 hover:text-neutral-500 transition-colors">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                </button>
            </div>
            <button type="button" id="item-note-done" class="mt-3 w-full bg-brand-500 text-white rounded-lg py-3 text-sm font-semibold hover:bg-brand-600 transition-colors">DONE</button>
        </div>

        <!-- Discount panel -->
        <div id="modal-discount-panel" class="hidden">
            <!-- Step 1: Select reason -->
            <div id="discount-step1">
                <p class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wide border-b border-neutral-100">Select Discount Reason</p>
                <div id="discount-reasons-list" class="max-h-64 overflow-y-auto"></div>
            </div>
            <!-- Step 2: Select type -->
            <div id="discount-step2" class="hidden">
                <div class="flex items-center gap-2 px-4 py-3 border-b border-neutral-100">
                    <button type="button" id="discount-step2-back" class="text-neutral-400 hover:text-neutral-700">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </button>
                    <p id="discount-step2-title" class="text-sm font-semibold text-neutral-800"></p>
                </div>
                <div id="discount-types-list" class="max-h-64 overflow-y-auto"></div>
            </div>
            <!-- Step 3: Numpad -->
            <div id="discount-step3" class="hidden">
                <div class="flex items-center gap-2 px-4 py-3 border-b border-neutral-100">
                    <button type="button" id="discount-step3-back" class="text-neutral-400 hover:text-neutral-700">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </button>
                    <p id="discount-step3-title" class="text-sm font-semibold text-neutral-800 flex-1"></p>
                    <span id="discount-type-label" class="text-sm font-bold text-blue-700">%</span>
                </div>
                <div class="px-4 py-2 border-b border-neutral-100">
                    <p id="numpad-display" class="text-2xl font-semibold text-neutral-800 text-right min-h-[2rem]"></p>
                </div>
                <div class="grid grid-cols-3 divide-x divide-y divide-neutral-100 border-b border-neutral-100">
                    @foreach (var n in new[]{"1","2","3","4","5","6","7","8","9",".","0"})
                    {
                        <button type="button" data-num="@n" class="py-4 text-base font-medium text-neutral-700 hover:bg-neutral-50 transition-colors">@n</button>
                    }
                    <button type="button" id="numpad-backspace" class="py-4 flex items-center justify-center text-neutral-400 hover:bg-neutral-50 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2M3 12l6.414 6.414a2 2 0 001.414.586H19a2 2 0 002-2V7a2 2 0 00-2-2h-8.172a2 2 0 00-1.414.586L3 12z"/></svg>
                    </button>
                </div>
                <div class="p-4">
                    <button type="button" id="discount-update" class="w-full border-2 border-brand-500 text-brand-600 rounded-lg py-3 text-sm font-semibold hover:bg-brand-50 transition-colors">UPDATE</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Variant picker modal ──────────────────────────────────────────────── -->
<div id="variant-modal" class="hidden fixed inset-0 z-50 bg-black/50 flex items-end sm:items-center justify-center p-4">
    <div class="bg-white rounded-xl p-6 w-full max-w-sm">
        <h3 id="variant-title" class="text-base font-medium text-neutral-900 mb-1"></h3>
        <p class="text-xs text-neutral-400 mb-4">Choose an option to add to the cart.</p>
        <div id="variant-list" class="space-y-2 max-h-60 overflow-y-auto mb-4"></div>
        <button type="button" id="variant-cancel"
                class="w-full border border-neutral-200 rounded-lg py-2.5 text-sm text-neutral-600 hover:border-neutral-400 transition-colors">
            Cancel
        </button>
    </div>
</div>

<!-- ── Refund modal ──────────────────────────────────────────────────────── -->
<div id="till-refund" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl p-6 max-w-md w-full max-h-[90vh] overflow-y-auto">
        <div id="refund-search-state">
            <h3 class="text-lg font-medium text-neutral-900 mb-1">Refund a sale</h3>
            <p class="text-sm text-neutral-500 mb-4">Enter the receipt number, pick what's coming back.</p>
            <div class="flex gap-2 mb-4">
                <input id="refund-order" type="text" placeholder="POS-…"
                       class="flex-1 border border-neutral-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-brand-500" />
                <button type="button" id="refund-find"
                        class="px-4 bg-neutral-900 text-white rounded-lg text-sm hover:bg-neutral-700 transition-colors">Find</button>
            </div>
            <div id="refund-body" class="hidden">
                <div id="refund-items" class="divide-y divide-neutral-100 mb-4"></div>
                <label class="block text-xs text-neutral-500 mb-1">Refund method</label>
                <div class="flex gap-2 mb-3" id="refund-methods">
                    <button type="button" data-method="Cash" class="refund-method flex-1 border-2 border-brand-500 bg-brand-50 rounded-lg py-2 text-sm">Cash</button>
                    <button type="button" data-method="Card" class="refund-method flex-1 border border-neutral-200 text-neutral-600 rounded-lg py-2 text-sm">Card</button>
                    <button type="button" data-method="Transfer" class="refund-method flex-1 border border-neutral-200 text-neutral-600 rounded-lg py-2 text-sm">Transfer</button>
                </div>
                <input id="refund-reason" type="text" placeholder="Reason (optional)"
                       class="w-full border border-neutral-300 rounded-lg px-3 py-2 text-sm mb-4 focus:outline-none focus:border-brand-500" />
                <div class="flex justify-between text-base font-medium text-neutral-900 mb-3">
                    <span>Refund total</span><span id="refund-total">₦0</span>
                </div>
            </div>
            <p id="refund-msg" class="text-xs text-red-500 mb-3"></p>
            <div class="flex gap-2">
                <button type="button" id="refund-cancel"
                        class="flex-1 border border-neutral-200 rounded-lg py-2.5 text-sm text-neutral-600 hover:border-neutral-400 transition-colors">Close</button>
                <button type="button" id="refund-confirm"
                        class="flex-1 bg-red-600 text-white rounded-lg py-2.5 text-sm hover:bg-red-700 transition-colors disabled:opacity-40" disabled>Process refund</button>
            </div>
        </div>
        <div id="refund-success-state" class="hidden text-center py-4">
            <div class="w-14 h-14 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center mx-auto mb-4">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/>
                </svg>
            </div>
            <p class="text-base font-medium text-neutral-900 mb-1">Refund processed</p>
            <p id="refund-success-detail" class="text-sm text-neutral-500 mb-6"></p>
            <button type="button" id="refund-done"
                    class="w-full bg-neutral-900 text-white rounded-lg py-3 text-sm hover:bg-neutral-700 transition-colors">Done</button>
        </div>
    </div>
</div>

<!-- ── Cash-up modal ─────────────────────────────────────────────────────── -->
<div id="till-cashup" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl p-6 max-w-sm w-full">
        <h3 class="text-lg font-medium text-neutral-900 mb-1">Cash up &amp; close session</h3>
        <p class="text-sm text-neutral-500 mb-5">Count the cash in the drawer and enter the total.</p>
        <label class="block text-xs text-neutral-500 mb-1">Counted cash (₦)</label>
        <input id="cashup-counted" type="number" min="0" step="any"
               class="w-full border border-neutral-300 rounded-lg px-3 py-2.5 text-base mb-3 focus:outline-none focus:border-brand-500" />
        <label class="block text-xs text-neutral-500 mb-1">Note (optional)</label>
        <input id="cashup-note" type="text"
               class="w-full border border-neutral-300 rounded-lg px-3 py-2.5 text-sm mb-5 focus:outline-none focus:border-brand-500" />
        <div class="flex gap-2">
            <button type="button" id="cashup-cancel"
                    class="flex-1 border border-neutral-200 rounded-lg py-2.5 text-sm text-neutral-600 hover:border-neutral-400 transition-colors">Cancel</button>
            <button type="button" id="cashup-confirm"
                    class="flex-1 bg-neutral-900 text-white rounded-lg py-2.5 text-sm hover:bg-neutral-700 transition-colors">Close session</button>
        </div>
    </div>
</div>

<!-- ── Quick item modal ──────────────────────────────────────────────────── -->
<div id="till-quickitem" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl p-6 max-w-sm w-full">
        <h3 class="text-lg font-medium text-neutral-900 mb-1">Quick item</h3>
        <p class="text-sm text-neutral-500 mb-4">Sell a one-off or un-barcoded item. Stock isn't tracked.</p>
        <label class="block text-xs text-neutral-500 mb-1">Description</label>
        <input id="qi-name" type="text" placeholder="e.g. Gift wrap, repair"
               class="w-full border border-neutral-300 rounded-lg px-3 py-2.5 text-sm mb-3 focus:outline-none focus:border-brand-500" />
        <label class="block text-xs text-neutral-500 mb-1">Price (₦)</label>
        <input id="qi-price" type="number" min="0" step="any"
               class="w-full border border-neutral-300 rounded-lg px-3 py-2.5 text-base mb-5 focus:outline-none focus:border-brand-500" />
        <div class="flex gap-2">
            <button type="button" id="qi-cancel" class="flex-1 border border-neutral-200 rounded-lg py-2.5 text-sm text-neutral-600 hover:border-neutral-400 transition-colors">Cancel</button>
            <button type="button" id="qi-add" class="flex-1 bg-neutral-900 text-white rounded-lg py-2.5 text-sm hover:bg-neutral-700 transition-colors">Add to cart</button>
        </div>
    </div>
</div>

<!-- ── Split payment modal ───────────────────────────────────────────────── -->
<div id="till-split" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl p-6 max-w-sm w-full">
        <h3 class="text-lg font-medium text-neutral-900 mb-1">Split payment</h3>
        <div class="flex justify-between text-sm text-neutral-500 mb-4">
            <span>Total <span id="split-total" class="font-medium text-neutral-800">₦0</span></span>
            <span>Remaining <span id="split-remaining" class="font-medium text-amber-600">₦0</span></span>
        </div>
        <div class="space-y-2 mb-3">
            <div class="flex items-center gap-2"><label class="w-20 text-sm text-neutral-600">Cash</label>
                <input data-pm="Cash" type="number" min="0" step="any" class="split-amt flex-1 border border-neutral-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-500" /></div>
            <div class="flex items-center gap-2"><label class="w-20 text-sm text-neutral-600">Card</label>
                <input data-pm="Card" type="number" min="0" step="any" class="split-amt flex-1 border border-neutral-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-500" /></div>
            <div class="flex items-center gap-2"><label class="w-20 text-sm text-neutral-600">Transfer</label>
                <input data-pm="Transfer" type="number" min="0" step="any" class="split-amt flex-1 border border-neutral-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-500" /></div>
        </div>
        <p class="text-xs text-neutral-400 mb-4">Change (from cash): <span id="split-change" class="font-medium text-neutral-700">₦0</span></p>
        <div class="flex gap-2">
            <button type="button" id="split-cancel" class="flex-1 border border-neutral-200 rounded-lg py-2.5 text-sm text-neutral-600 hover:border-neutral-400 transition-colors">Cancel</button>
            <button type="button" id="split-confirm" class="flex-1 bg-neutral-900 text-white rounded-lg py-2.5 text-sm hover:bg-neutral-700 transition-colors disabled:opacity-40" disabled>Confirm</button>
        </div>
    </div>
</div>

<!-- ── Cash in / out modal ───────────────────────────────────────────────── -->
<div id="till-cashinout" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl p-6 max-w-sm w-full">
        <h3 class="text-lg font-medium text-neutral-900 mb-1">Cash in / out</h3>
        <p class="text-sm text-neutral-500 mb-4">Record a drop or top-up so cash-up still balances.</p>
        <div class="grid grid-cols-2 gap-2 mb-4">
            <button type="button" data-dir="in" class="cashio-dir border rounded-lg py-2.5 text-sm font-medium border-brand-500 bg-brand-50 text-brand-600">Cash in</button>
            <button type="button" data-dir="out" class="cashio-dir border rounded-lg py-2.5 text-sm font-medium border-neutral-200 text-neutral-500">Cash out</button>
        </div>
        <label class="block text-xs text-neutral-500 mb-1">Amount (₦)</label>
        <input id="cashio-amount" type="number" min="0" step="any"
               class="w-full border border-neutral-300 rounded-lg px-3 py-2.5 text-base mb-3 focus:outline-none focus:border-brand-500" />
        <label class="block text-xs text-neutral-500 mb-1">Reason (optional)</label>
        <input id="cashio-reason" type="text" placeholder="e.g. paid supplier, float top-up"
               class="w-full border border-neutral-300 rounded-lg px-3 py-2.5 text-sm mb-5 focus:outline-none focus:border-brand-500" />
        <div class="flex gap-2">
            <button type="button" id="cashio-cancel"
                    class="flex-1 border border-neutral-200 rounded-lg py-2.5 text-sm text-neutral-600 hover:border-neutral-400 transition-colors">Cancel</button>
            <button type="button" id="cashio-confirm"
                    class="flex-1 bg-neutral-900 text-white rounded-lg py-2.5 text-sm hover:bg-neutral-700 transition-colors">Record</button>
        </div>
    </div>
</div>

<!-- ── Held sales modal ──────────────────────────────────────────────────── -->
<div id="till-held" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl w-full max-w-md max-h-[80vh] flex flex-col overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-100 flex-shrink-0">
            <h3 class="text-base font-medium text-neutral-900">Held sales</h3>
            <button type="button" id="held-close" class="text-neutral-400 hover:text-neutral-700 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </button>
        </div>
        <div id="held-list" class="flex-1 overflow-y-auto divide-y divide-neutral-100 text-sm">
            <p class="text-center text-neutral-400 py-8 text-xs">Loading…</p>
        </div>
    </div>
