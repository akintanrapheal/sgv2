// ── Stock lookup (EPOS-style grid) ───────────────────────────────────────────
(function () {
    const fmt = n => '₦' + Number(n || 0).toLocaleString('en-NG', { maximumFractionDigits: 0 });
    const modal = document.getElementById('till-stocklookup');
    const input = document.getElementById('stocklookup-search');
    const locationSelect = document.getElementById('stocklookup-location');
    const periodSelect = document.getElementById('stocklookup-period');
    const results = document.getElementById('stocklookup-results');
    const backBtn = document.getElementById('stocklookup-back');
    const DASH = '—';
    const esc = s => (s == null ? '' : String(s)).replace(/[&<>"]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    let debounce, lastItems = [], locationsLoaded = false;

    function openModal(prefill) {
        modal.classList.remove('hidden');
        if (backBtn) backBtn.classList.add('hidden');
        loadLocations();
        if (prefill != null) input.value = prefill;
        setTimeout(() => input.focus(), 50);
        if (input.value.trim()) search(); else emptyState();
    }
    document.getElementById('menu-stocklookup-btn').addEventListener('click', () => openModal(null));
    document.getElementById('stocklookup-close').addEventListener('click', () => modal.classList.add('hidden'));
    // Exposed so the product popup's "Stock info" can open the lookup pre-filtered to a product.
    window.SGStockLookup = { open: openModal };

    input.addEventListener('input', () => { clearTimeout(debounce); debounce = setTimeout(search, 250); });
    input.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); clearTimeout(debounce); search(); } });
    locationSelect.addEventListener('change', renderGrid);     // location filter is client-side
    periodSelect.addEventListener('change', search);           // qty-sold depends on period -> refetch

    async function loadLocations() {
        if (locationsLoaded) return;
        locationsLoaded = true;
        try {
            const res = await fetch('/Pos/StockLookupStores');
            const stores = await res.json();
            locationSelect.insertAdjacentHTML('beforeend', stores.map(s => `<option value="${esc(s.name)}">${esc(s.name)}</option>`).join(''));
        } catch { locationsLoaded = false; }
    }

    function emptyState(msg) {
        results.innerHTML = `<p class="text-center text-neutral-400 py-10 text-xs">${msg || 'Search for a product to see stock levels.'}</p>`;
    }

    async function search() {
        const q = input.value.trim();
        if (!q) { lastItems = []; emptyState(); return; }
        results.innerHTML = '<p class="text-center text-neutral-400 py-10 text-xs">Searching…</p>';
        try {
            const res = await fetch('/Pos/StockLookup?q=' + encodeURIComponent(q) + '&period=' + encodeURIComponent(periodSelect.value));
            lastItems = await res.json();
            renderGrid();
        } catch { emptyState('Could not search.'); }
    }

    function renderGrid() {
        if (!lastItems.length) { emptyState('No products found.'); return; }
        const loc = locationSelect.value;
        const headers = ['Name', 'Description', 'Colour', 'Size', 'Location', 'In stock', 'On hold', 'On order', 'Sale price', 'Brand', 'Category', 'Barcode', 'Order code', 'Qty sold'];
        const rightAlign = new Set(['In stock', 'On hold', 'On order', 'Sale price', 'Qty sold']);

        // Flatten products into one row per (product, branch[, variant]) — already deduped server-side.
        const flat = [];
        lastItems.forEach(p => {
            let rows = p.rows || [];
            if (loc) rows = rows.filter(r => r.location === loc);
            rows.forEach(r => flat.push({ p, r }));
        });
        if (!flat.length) { emptyState(loc ? 'No stock at this location.' : 'No stock records.'); return; }

        const body = flat.map(({ p, r }, ri) => {
            const cells = {
                'Name': esc(p.name),
                'Description': esc(p.description) || DASH,
                'Colour': esc(r.variant) || DASH,
                'Size': DASH,
                'Location': esc(r.location),
                'In stock': r.inStock,
                'On hold': r.onHold,
                'On order': DASH,
                'Sale price': fmt(p.price),
                'Brand': DASH,
                'Category': esc(p.category) || DASH,
                'Barcode': esc(p.barcode) || DASH,
                'Order code': esc(p.sku) || DASH,
                'Qty sold': r.qtySold
            };
            const zebra = ri % 2 ? 'bg-neutral-50' : 'bg-white';
            return `<tr class="${zebra} hover:bg-sky-50 transition-colors">${headers.map(h => {
                let cls = 'px-3 py-2 text-neutral-700 align-top border border-neutral-100';
                if (rightAlign.has(h)) cls += ' text-right tabular-nums';
                if (h === 'In stock') cls += (cells[h] > 0 ? ' font-semibold text-emerald-600' : ' font-semibold text-red-500');
                if (h === 'Name') cls += ' font-medium text-neutral-900 whitespace-normal min-w-[180px]';
                if (h === 'Description') cls += ' whitespace-normal text-neutral-400 min-w-[160px]';
                if (h === 'Barcode' || h === 'Order code') cls += ' font-mono text-[11px]';
                return `<td class="${cls}">${cells[h]}</td>`;
            }).join('')}</tr>`;
        }).join('');

        results.innerHTML = `
            <div class="overflow-x-auto p-4">
                <table class="w-full text-xs whitespace-nowrap border-collapse">
                    <thead class="sticky top-0">
                        <tr class="text-left bg-neutral-100 text-sky-700 uppercase tracking-wide text-[10px]">
                            ${headers.map(h => `<th class="px-3 py-2.5 font-semibold border border-neutral-200${rightAlign.has(h) ? ' text-right' : ''}">${h}</th>`).join('')}
                        </tr>
                    </thead>
                    <tbody>${body}</tbody>
                </table>
            </div>`;
    }

    document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) modal.classList.add('hidden');
    });
}());

// ── Verify pickup (scan the customer's QR pass) ───────────────────────────────
(function () {
    const fmt = n => '₦' + Number(n || 0).toLocaleString('en-NG', { maximumFractionDigits: 0 });
    const modal = document.getElementById('till-pickup');
    const input = document.getElementById('pickup-code');
    const result = document.getElementById('pickup-result');
    const esc = s => (s == null ? '' : String(s)).replace(/[&<>"]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    let debounce;

    function open(prefill) {
        modal.classList.remove('hidden');
        result.innerHTML = '';
        input.value = prefill || '';
        setTimeout(() => input.focus(), 50);
        if (input.value.trim()) verify(input.value.trim());
    }
    window.openPickupVerify = open;
    document.getElementById('menu-pickup-btn').addEventListener('click', () => open(''));
    document.getElementById('pickup-close').addEventListener('click', () => modal.classList.add('hidden'));
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && !modal.classList.contains('hidden')) modal.classList.add('hidden'); });
    input.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); clearTimeout(debounce); verify(input.value.trim()); } });

    async function verify(code) {
        if (!code) return;
        result.innerHTML = '<p class="text-center text-neutral-400 py-6 text-xs">Looking up…</p>';
        try {
            const res = await fetch('/Pos/PickupVerify?code=' + encodeURIComponent(code));
            const d = await res.json();
            if (!d.success) { result.innerHTML = `<p class="text-center text-red-500 py-6 text-sm">${esc(d.message)}</p>`; return; }
            render(d);
        } catch { result.innerHTML = '<p class="text-center text-red-500 py-6 text-sm">Could not verify — check the connection.</p>'; }
    }

    function render(d) {
        const items = (d.items || []).map(i => `<div class="flex justify-between text-sm py-1"><span class="text-neutral-700">${i.qty}× ${esc(i.name)}${i.variant ? ' (' + esc(i.variant) + ')' : ''}</span><span class="text-neutral-800">${fmt(i.lineTotal)}</span></div>`).join('');
        let banner = '', action = '';
        if (d.collected) banner = '<div class="text-center text-xs font-semibold uppercase tracking-wide text-amber-700 bg-amber-50 border border-amber-200 rounded-lg py-2 mb-3">Already collected</div>';
        else if (!d.ready) banner = `<div class="text-center text-xs font-semibold text-amber-700 bg-amber-50 border border-amber-200 rounded-lg py-2 mb-3">Order is ${esc(d.status)} — not ready for pickup</div>`;
        if (d.ready) action = `<button type="button" id="pickup-confirm" data-token="${esc(d.token)}" class="w-full mt-4 bg-emerald-600 text-white text-sm font-semibold uppercase tracking-wide py-3 rounded-xl hover:bg-emerald-700 transition-colors">Confirm collected</button>`;
        const storeWarn = d.sameStore ? '' : `<p class="text-[11px] text-amber-600 mt-1">⚠ Pickup branch is <strong>${esc(d.pickupStore)}</strong>, not this till.</p>`;
        result.innerHTML = `
            ${banner}
            <div class="flex justify-between items-start gap-2">
                <div><p class="text-base font-semibold text-neutral-900">${esc(d.orderNumber)}</p>
                ${d.customer ? `<p class="text-xs text-neutral-500">${esc(d.customer)}</p>` : ''}
                <p class="text-xs text-neutral-400">Pickup at ${esc(d.pickupStore) || '—'}</p>${storeWarn}</div>
                <span class="text-sm font-semibold">${fmt(d.total)}</span>
            </div>
            <div class="mt-3 border-t border-neutral-100 pt-2">${items}</div>
            ${action}`;
        const btn = document.getElementById('pickup-confirm');
        if (btn) btn.addEventListener('click', () => complete(btn.dataset.token, btn));
    }

    async function complete(token, btn) {
        btn.disabled = true; btn.textContent = 'Confirming…';
        const tok = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        try {
            const res = await fetch('/Pos/PickupComplete', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': tok }, body: JSON.stringify({ token }) });
            const d = await res.json();
            if (d.success) result.innerHTML = `<div class="text-center py-8"><div class="text-4xl text-emerald-600 mb-2">✓</div><p class="text-base font-semibold text-emerald-700">Collected</p><p class="text-xs text-neutral-500 mt-1">${esc(d.orderNumber)} handed over.</p></div>`;
            else { btn.disabled = false; btn.textContent = 'Confirm collected'; result.insertAdjacentHTML('afterbegin', `<p class="text-center text-red-500 text-sm mb-2">${esc(d.message)}</p>`); }
        } catch { btn.disabled = false; btn.textContent = 'Confirm collected'; }
    }
}());

// ── Stock transfers: Send (request + mark-sent + print), Receive (scan/edit/reason), History ──
(function () {
    var sendPanel = document.getElementById('till-sendstock');
    var recvPanel = document.getElementById('till-receivestock');
    if (!sendPanel || !recvPanel) return;
    var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    var esc = function (s) { return String(s == null ? '' : s).replace(/[&<>"]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]; }); };
    var post = function (url, body) { return fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token }, body: JSON.stringify(body) }).then(function (r) { return r.json().catch(function () { return {}; }); }); };
    var get = function (url) { return fetch(url, { headers: { 'X-Requested-With': 'fetch' } }).then(function (r) { return r.ok ? r.json() : null; }).catch(function () { return null; }); };
    // Small square product thumbnail (or a placeholder box) so the cashier eyeballs the item, not just its name.
    var thumb = function (url) { return url
        ? '<img src="' + esc(url) + '" class="w-10 h-10 rounded object-cover bg-neutral-100 flex-shrink-0" alt="">'
        : '<div class="w-10 h-10 rounded bg-neutral-100 flex-shrink-0 flex items-center justify-center text-neutral-300"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14M4 6h16M4 6v12a2 2 0 002 2h12a2 2 0 002-2V6"/></svg></div>'; };
    var openManifest = function (url) { if (url) window.open(url, '_blank'); };

    var destSel = document.getElementById('sendstock-dest');
    var reasonSel = document.getElementById('sendstock-reason');
    var searchIn = document.getElementById('sendstock-search');
    var resultsBox = document.getElementById('sendstock-results');
    var basketBox = document.getElementById('sendstock-basket');
    var submitBtn = document.getElementById('sendstock-submit');
    var sendMsg = document.getElementById('sendstock-msg');
    var outgoingBox = document.getElementById('sendstock-outgoing');
    var recvList = document.getElementById('receivestock-list');
    var basket = [], lastResults = [], branchesLoaded = false;

    function badge(n) { var b = document.getElementById('receivestock-badge'); if (!b) return; if (n > 0) { b.textContent = n; b.classList.remove('hidden'); } else b.classList.add('hidden'); }
    function loadBranches() {
        if (branchesLoaded) return Promise.resolve();
        return get('/Pos/TransferMeta').then(function (d) {
            branchesLoaded = true;
            destSel.innerHTML = '<option value="">— Select branch —</option>' + ((d && d.branches) || []).map(function (b) { return '<option value="' + b.id + '">' + esc(b.name) + '</option>'; }).join('');
            reasonSel.innerHTML = '<option value="">— Select reason —</option>' + ((d && d.reasons) || []).map(function (r) { return '<option value="' + esc(r) + '">' + esc(r) + '</option>'; }).join('');
        });
    }
    function renderBasket() {
        basketBox.innerHTML = basket.length ? basket.map(function (it, i) {
            return '<div class="flex items-center gap-2 border border-neutral-200 rounded-lg px-3 py-2">' + thumb(it.image) + '<div class="flex-1 min-w-0"><p class="text-sm text-neutral-800 truncate">' + esc(it.name) + '</p><p class="text-[11px] text-neutral-400">' + it.available + ' available</p></div>'
                + '<button type="button" data-dec="' + i + '" class="w-7 h-7 rounded border border-neutral-200 text-neutral-600">−</button><span class="w-8 text-center text-sm">' + it.qty + '</span>'
                + '<button type="button" data-inc="' + i + '" class="w-7 h-7 rounded border border-neutral-200 text-neutral-600">+</button>'
                + '<button type="button" data-rm="' + i + '" class="ml-1 text-neutral-300 hover:text-red-500">✕</button></div>';
        }).join('') : '<p class="text-xs text-neutral-400 py-3 text-center">No items yet — search or scan above.</p>';
        submitBtn.disabled = !(basket.length && destSel.value && reasonSel.value);
    }
    function addToBasket(r) {
        var ex = basket.find(function (x) { return x.productId === r.id; });
        if (ex) { if (ex.qty < ex.available) ex.qty++; } else basket.push({ productId: r.id, name: r.name, image: r.image, available: r.available, qty: 1 });
        renderBasket();
    }
    basketBox.addEventListener('click', function (e) {
        var inc = e.target.closest('[data-inc]'), dec = e.target.closest('[data-dec]'), rm = e.target.closest('[data-rm]');
        if (inc) { var i = +inc.dataset.inc; if (basket[i].qty < basket[i].available) basket[i].qty++; }
        else if (dec) { var j = +dec.dataset.dec; if (basket[j].qty > 1) basket[j].qty--; }
        else if (rm) { basket.splice(+rm.dataset.rm, 1); } else return;
        renderBasket();
    });
    destSel.addEventListener('change', renderBasket);
    reasonSel.addEventListener('change', renderBasket);
    var sdeb; searchIn.addEventListener('input', function () { clearTimeout(sdeb); sdeb = setTimeout(searchProducts, 250); });
    // Enter = scanner submit: exact barcode/SKU match (or a lone result) is added straight to the basket.
    searchIn.addEventListener('keydown', function (e) {
        if (e.key !== 'Enter') return;
        e.preventDefault();
        var q = searchIn.value.trim().toLowerCase(); if (!q) return;
        var exact = lastResults.find(function (r) { return (r.barcode && r.barcode.toLowerCase() === q) || (r.sku && r.sku.toLowerCase() === q); });
        var pick = exact || (lastResults.length === 1 ? lastResults[0] : null);
        if (pick) { addToBasket(pick); searchIn.value = ''; resultsBox.classList.add('hidden'); }
    });
    function searchProducts() {
        var q = searchIn.value.trim(); if (!q) { resultsBox.classList.add('hidden'); return; }
        get('/Pos/TransferSearch?q=' + encodeURIComponent(q)).then(function (rows) {
            lastResults = rows || [];
            resultsBox.innerHTML = lastResults.length ? lastResults.map(function (r, i) {
                return '<button type="button" data-add="' + i + '" class="w-full flex items-center gap-2 text-left px-3 py-2 hover:bg-neutral-50 border-b border-neutral-50">' + thumb(r.image) + '<span class="flex-1 min-w-0"><span class="block text-sm text-neutral-800 truncate">' + esc(r.name) + '</span><span class="block text-[11px] text-neutral-400">' + r.available + ' available' + (r.sku ? ' · ' + esc(r.sku) : '') + '</span></span></button>';
            }).join('') : '<p class="px-3 py-2 text-xs text-neutral-400">No products with stock here.</p>';
            resultsBox.classList.remove('hidden');
        });
    }
    resultsBox.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-add]'); if (!btn) return;
        var r = lastResults[+btn.dataset.add]; if (!r) return;
        addToBasket(r);
        searchIn.value = ''; resultsBox.classList.add('hidden'); searchIn.focus();
    });
    submitBtn.addEventListener('click', function () {
        if (!basket.length || !destSel.value || !reasonSel.value) return;
        submitBtn.disabled = true; sendMsg.className = 'text-xs text-center h-4 text-neutral-500'; sendMsg.textContent = 'Sending…';
        post('/Pos/TransferRequest', { toStoreId: +destSel.value, reason: reasonSel.value, items: basket.map(function (b) { return { productId: b.productId, qty: b.qty }; }) }).then(function (d) {
            if (d.success) { sendMsg.className = 'text-xs text-center h-4 text-emerald-600'; sendMsg.textContent = '✓ Request ' + (d.number || '') + ' sent for approval.'; basket = []; reasonSel.value = ''; renderBasket(); loadLists(); }
            else { sendMsg.className = 'text-xs text-center h-4 text-red-600'; sendMsg.textContent = d.message || 'Failed.'; submitBtn.disabled = false; }
        });
    });
    outgoingBox.addEventListener('click', function (e) {
        var mf = e.target.closest('[data-manifest]');
        if (mf) { openManifest(mf.dataset.manifest); return; }
        var btn = e.target.closest('[data-dispatch]'); if (!btn) return;
        if (!confirm('Mark this transfer as sent? Stock leaves this branch.')) return;
        btn.disabled = true; btn.textContent = 'Sending…';
        post('/Pos/TransferDispatch', { id: +btn.dataset.dispatch }).then(function (d) { if (!d.success) alert(d.message || 'Could not send.'); loadLists(); });
    });
    function loadLists() {
        return get('/Pos/TransfersList').then(function (d) {
            var out = (d && d.outgoing) || [], inc = (d && d.incoming) || [];
            badge(inc.length);
            outgoingBox.innerHTML = out.length ? out.map(function (t) {
                var items = t.items.map(function (i) { return esc(i.name) + ' ×' + i.qty; }).join(', ');
                var b = t.status === 'PendingApproval' ? '<span class="text-[10px] px-2 py-0.5 rounded-full bg-amber-50 text-amber-700">Pending approval</span>' : t.status === 'Approved' ? '<span class="text-[10px] px-2 py-0.5 rounded-full bg-blue-50 text-blue-700">Approved</span>' : '<span class="text-[10px] px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-700">In transit</span>';
                var actions = '<div class="flex gap-2 mt-2">'
                    + '<button type="button" data-manifest="' + esc(t.manifestUrl) + '" class="flex-1 border border-neutral-200 text-neutral-700 text-xs py-2 rounded-lg hover:bg-neutral-50">Print manifest</button>'
                    + (t.canDispatch ? '<button type="button" data-dispatch="' + t.id + '" class="flex-1 bg-neutral-900 text-white text-xs py-2 rounded-lg hover:bg-black">Mark as sent</button>' : '')
                    + '</div>';
                return '<div class="border border-neutral-200 rounded-lg px-3 py-2"><div class="flex items-center justify-between gap-2 mb-1"><span class="text-xs font-medium text-neutral-700">' + esc(t.number) + ' → ' + esc(t.toStore) + '</span>' + b + '</div><p class="text-[11px] text-neutral-500">' + items + '</p>' + actions + '</div>';
            }).join('') : '<p class="text-xs text-neutral-400 py-2 text-center">None.</p>';
            recvList.innerHTML = inc.length ? inc.map(function (t) {
                var items = t.items.map(function (i) { return esc(i.name) + ' ×' + i.qty; }).join(', ');
                return '<div class="border border-neutral-200 rounded-lg px-4 py-3"><div class="flex items-center justify-between gap-2 mb-1"><span class="text-sm font-medium text-neutral-800">' + esc(t.number) + '</span><span class="text-[11px] text-neutral-400">from ' + esc(t.fromStore) + '</span></div><p class="text-xs text-neutral-500 mb-2">' + items + '</p><div class="flex gap-2"><button type="button" data-manifest="' + esc(t.manifestUrl) + '" class="border border-neutral-200 text-neutral-700 text-xs px-3 py-2 rounded-lg hover:bg-neutral-50">Manifest</button><button type="button" data-open="' + t.id + '" class="flex-1 bg-emerald-600 text-white text-sm py-2 rounded-lg hover:bg-emerald-700">Check in items</button></div></div>';
            }).join('') : '<p class="text-sm text-neutral-400 py-8 text-center">No incoming transfers.</p>';
        });
    }

    // ── Receive detail: scan items in, edit counts, add a reason when short ──
    var recvDetailPanel = document.getElementById('till-receive-detail');
    var recvLinesBox = document.getElementById('recvdetail-lines');
    var recvScan = document.getElementById('recvdetail-scan');
    var recvScanMsg = document.getElementById('recvdetail-scanmsg');
    var recvNotes = document.getElementById('recvdetail-notes');
    var recvSubmit = document.getElementById('recvdetail-submit');
    var recvMsg = document.getElementById('recvdetail-msg');
    var recvState = { id: 0, lines: [] };

    function renderRecvLines() {
        var short = false;
        recvLinesBox.innerHTML = recvState.lines.map(function (l, i) {
            if (l.received < l.expected) short = true;
            var full = l.received >= l.expected;
            return '<div class="flex items-center gap-2 border rounded-lg px-3 py-2 ' + (full ? 'border-emerald-200 bg-emerald-50/40' : 'border-neutral-200') + '">' + thumb(l.image)
                + '<div class="flex-1 min-w-0"><p class="text-sm text-neutral-800 truncate">' + esc(l.name) + '</p><p class="text-[11px] text-neutral-400">expected ' + l.expected + '</p></div>'
                + '<button type="button" data-rdec="' + i + '" class="w-7 h-7 rounded border border-neutral-200 text-neutral-600">−</button>'
                + '<input type="number" data-rqty="' + i + '" value="' + l.received + '" min="0" max="' + l.expected + '" class="w-12 text-center text-sm border border-neutral-200 rounded py-1" />'
                + '<span class="text-[11px] text-neutral-400 w-8">/ ' + l.expected + '</span>'
                + '<button type="button" data-rinc="' + i + '" class="w-7 h-7 rounded border border-neutral-200 text-neutral-600">+</button></div>';
        }).join('');
        recvNotes.parentElement.style.display = short ? '' : 'none';
    }
    function openReceiveDetail(id) {
        recvScanMsg.textContent = ''; recvMsg.textContent = ''; recvNotes.value = '';
        recvLinesBox.innerHTML = '<p class="text-sm text-neutral-400 py-4 text-center">Loading…</p>';
        recvPanel.classList.add('hidden'); recvDetailPanel.classList.remove('hidden');
        get('/Pos/TransferReceiveDetail?id=' + id).then(function (d) {
            if (!d || !d.ok) { recvLinesBox.innerHTML = '<p class="text-sm text-red-500 py-4 text-center">Could not load this transfer.</p>'; return; }
            document.getElementById('recvdetail-num').textContent = d.number;
            document.getElementById('recvdetail-from').textContent = 'from ' + d.fromStore;
            recvState = { id: d.id, lines: d.lines.map(function (l) { return { itemId: l.itemId, name: l.name, image: l.image, expected: l.expected, codes: l.codes || [], received: l.expected }; }) };
            renderRecvLines(); recvScan.focus();
        });
    }
    recvLinesBox.addEventListener('click', function (e) {
        var inc = e.target.closest('[data-rinc]'), dec = e.target.closest('[data-rdec]');
        if (inc) { var i = +inc.dataset.rinc; if (recvState.lines[i].received < recvState.lines[i].expected) recvState.lines[i].received++; }
        else if (dec) { var j = +dec.dataset.rdec; if (recvState.lines[j].received > 0) recvState.lines[j].received--; } else return;
        renderRecvLines();
    });
    recvLinesBox.addEventListener('input', function (e) {
        var el = e.target.closest('[data-rqty]'); if (!el) return;
        var i = +el.dataset.rqty, v = Math.max(0, Math.min(recvState.lines[i].expected, parseInt(el.value, 10) || 0));
        recvState.lines[i].received = v; renderRecvLines();
    });
    recvScan.addEventListener('keydown', function (e) {
        if (e.key !== 'Enter') return;
        e.preventDefault();
        var code = recvScan.value.trim().toLowerCase(); recvScan.value = ''; if (!code) return;
        var idx = recvState.lines.findIndex(function (l) { return l.codes.indexOf(code) !== -1; });
        if (idx === -1) { recvScanMsg.className = 'text-xs text-center h-4 mt-1 text-red-500'; recvScanMsg.textContent = 'No item on this transfer matches that barcode.'; return; }
        var line = recvState.lines[idx];
        // Start counting from 0 the first time a line is scanned, so scans tally the physical count.
        if (!line._scanned) { line._scanned = true; line.received = 0; }
        if (line.received < line.expected) { line.received++; recvScanMsg.className = 'text-xs text-center h-4 mt-1 text-emerald-600'; recvScanMsg.textContent = '✓ ' + line.name + ' (' + line.received + '/' + line.expected + ')'; }
        else { recvScanMsg.className = 'text-xs text-center h-4 mt-1 text-amber-600'; recvScanMsg.textContent = line.name + ' already at ' + line.expected + '.'; }
        renderRecvLines();
    });
    recvSubmit.addEventListener('click', function () {
        var short = recvState.lines.some(function (l) { return l.received < l.expected; });
        if (short && !recvNotes.value.trim()) { recvMsg.className = 'text-xs text-center h-4 text-red-600'; recvMsg.textContent = 'Add a reason — some counts are short.'; recvNotes.focus(); return; }
        if (!confirm('Confirm receipt? Received units are added to this branch.')) return;
        recvSubmit.disabled = true; recvMsg.className = 'text-xs text-center h-4 text-neutral-500'; recvMsg.textContent = 'Receiving…';
        post('/Pos/TransferReceive', { id: recvState.id, notes: recvNotes.value.trim(), items: recvState.lines.map(function (l) { return { itemId: l.itemId, received: l.received }; }) }).then(function (d) {
            recvSubmit.disabled = false;
            if (d.success) { recvDetailPanel.classList.add('hidden'); recvPanel.classList.remove('hidden'); loadLists(); }
            else { recvMsg.className = 'text-xs text-center h-4 text-red-600'; recvMsg.textContent = d.message || 'Could not receive.'; }
        });
    });
    recvList.addEventListener('click', function (e) {
        var mf = e.target.closest('[data-manifest]'); if (mf) { openManifest(mf.dataset.manifest); return; }
        var btn = e.target.closest('[data-open]'); if (btn) openReceiveDetail(+btn.dataset.open);
    });
    document.getElementById('recvdetail-back').addEventListener('click', function () { recvDetailPanel.classList.add('hidden'); recvPanel.classList.remove('hidden'); });

    // ── Transfer history ──
    var histPanel = document.getElementById('till-transferhistory');
    var histList = document.getElementById('transferhistory-list');
    function loadHistory() {
        histList.innerHTML = '<p class="text-sm text-neutral-400 py-8 text-center">Loading…</p>';
        get('/Pos/TransferHistory').then(function (rows) {
            rows = rows || [];
            histList.innerHTML = rows.length ? rows.map(function (t) {
                var badgeCls = t.status === 'Completed' ? 'bg-emerald-50 text-emerald-700' : t.status === 'PartiallyReceived' ? 'bg-amber-50 text-amber-700' : t.status === 'Rejected' ? 'bg-red-50 text-red-600' : 'bg-neutral-100 text-neutral-500';
                var dir = t.outgoing ? '<span class="text-neutral-400">→</span> ' + esc(t.otherStore) : '<span class="text-neutral-400">←</span> ' + esc(t.otherStore);
                var mf = t.manifestUrl ? '<button type="button" data-manifest="' + esc(t.manifestUrl) + '" class="text-[11px] text-brand-600 hover:underline">Manifest</button>' : '';
                var reason = t.reason ? '<span class="text-[10px] text-neutral-400"> · ' + esc(t.reason) + '</span>' : '';
                return '<div class="border border-neutral-200 rounded-lg px-3 py-2"><div class="flex items-center justify-between gap-2"><span class="text-xs font-medium text-neutral-700">' + esc(t.number) + ' ' + dir + '</span><span class="text-[10px] px-2 py-0.5 rounded-full ' + badgeCls + '">' + esc(t.status) + '</span></div><div class="flex items-center justify-between gap-2 mt-1"><span class="text-[11px] text-neutral-400">' + esc(t.when) + ' · ' + t.lines + ' pcs' + '</span>' + mf + '</div>' + (reason ? '<div class="text-[11px] text-neutral-400 mt-0.5">Reason:' + reason + '</div>' : '') + '</div>';
            }).join('') : '<p class="text-sm text-neutral-400 py-8 text-center">No past transfers yet.</p>';
        });
    }
    histList.addEventListener('click', function (e) { var mf = e.target.closest('[data-manifest]'); if (mf) openManifest(mf.dataset.manifest); });

    document.getElementById('menu-sendstock-btn').addEventListener('click', function () { sendPanel.classList.remove('hidden'); loadBranches(); renderBasket(); loadLists(); });
    document.getElementById('sendstock-close').addEventListener('click', function () { sendPanel.classList.add('hidden'); });
    document.getElementById('menu-receivestock-btn').addEventListener('click', function () { recvPanel.classList.remove('hidden'); loadLists(); });
    document.getElementById('receivestock-close').addEventListener('click', function () { recvPanel.classList.add('hidden'); });
    document.getElementById('menu-transferhistory-btn').addEventListener('click', function () { histPanel.classList.remove('hidden'); loadHistory(); });
    document.getElementById('transferhistory-close').addEventListener('click', function () { histPanel.classList.add('hidden'); });
    loadLists(); setInterval(loadLists, 60000);   // keep the "receive" badge fresh
}());
</script>
}
