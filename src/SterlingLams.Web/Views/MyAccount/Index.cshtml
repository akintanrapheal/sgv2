@model SterlingLams.Web.Controllers.MyAccountViewModel
@{
    Layout = "_BackofficeLayout";
    ViewData["Title"] = "My Account";
    var accent = string.IsNullOrEmpty(Model.Accent) ? "#ed028b" : Model.Accent;
    string Inp = "w-full border border-neutral-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-500";
    string Btn = "bg-neutral-900 text-white text-sm px-5 py-2 rounded-lg hover:bg-neutral-700 transition-colors";
    var initials = ($"{(Model.FirstName.Length > 0 ? Model.FirstName[0].ToString() : "")}{(Model.LastName.Length > 0 ? Model.LastName[0].ToString() : "")}").ToUpper();
    if (string.IsNullOrEmpty(initials)) { initials = Model.Email.Length > 0 ? Model.Email[0].ToString().ToUpper() : "?"; }
}

<h1 class="font-cormorant text-3xl font-light mb-1">My Account</h1>
<p class="text-sm text-neutral-500 mb-8">Manage your profile, password, backend colour and security.</p>

<div class="space-y-6">

    <!-- Profile picture -->
    <section class="bg-white border border-neutral-200 rounded-xl p-6">
        <h2 class="text-sm font-semibold text-neutral-800 mb-4">Profile picture</h2>
        <div class="flex items-center gap-5">
            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
            {
                <img src="@SterlingLams.Web.Infrastructure.Img.Cld(Model.AvatarUrl, 160, 160)" alt="Avatar"
                     class="w-20 h-20 rounded-full object-cover border border-neutral-200" />
            }
            else
            {
                <span class="w-20 h-20 rounded-full bg-brand-500 text-white text-xl font-semibold flex items-center justify-center">@initials</span>
            }
            <div class="flex-1">
                <form asp-controller="MyAccount" asp-action="Avatar" method="post" enctype="multipart/form-data" class="flex flex-wrap items-center gap-2">
                    <input type="file" name="file" accept="image/png,image/jpeg,image/webp,image/gif"
                           class="text-xs text-neutral-600 file:mr-3 file:px-3 file:py-1.5 file:rounded-lg file:border-0 file:bg-neutral-900 file:text-white file:text-xs file:cursor-pointer" />
                    <button type="submit" class="text-xs bg-brand-500 text-white px-4 py-1.5 rounded-lg hover:bg-brand-600 transition-colors">Upload</button>
                </form>
                @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                {
                    <form asp-controller="MyAccount" asp-action="RemoveAvatar" method="post" class="mt-2">
                        <button type="submit" class="text-xs text-red-500 hover:text-red-700">Remove picture</button>
                    </form>
                }
                <p class="text-[11px] text-neutral-400 mt-2">JPG, PNG, WEBP or GIF · up to 5&nbsp;MB. Shown white on the pink chip when it's a plain icon.</p>
            </div>
        </div>
    </section>

    <!-- Name & email -->
    <section class="bg-white border border-neutral-200 rounded-xl p-6">
        <h2 class="text-sm font-semibold text-neutral-800 mb-4">Profile</h2>
        <form asp-controller="MyAccount" asp-action="Profile" method="post" class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div><label class="block text-xs font-medium text-neutral-600 mb-1">First name</label><input name="firstName" value="@Model.FirstName" class="@Inp" /></div>
                <div><label class="block text-xs font-medium text-neutral-600 mb-1">Last name</label><input name="lastName" value="@Model.LastName" class="@Inp" /></div>
            </div>
            <div><label class="block text-xs font-medium text-neutral-600 mb-1">Email</label><input name="email" type="email" value="@Model.Email" class="@Inp" /><p class="text-[11px] text-neutral-400 mt-1">You sign in with this email.</p></div>
            <button type="submit" class="@Btn">Save profile</button>
        </form>
    </section>

    <!-- Password -->
    <section class="bg-white border border-neutral-200 rounded-xl p-6">
        <h2 class="text-sm font-semibold text-neutral-800 mb-4">Password</h2>
        <form asp-controller="MyAccount" asp-action="Password" method="post" class="space-y-4">
            <div><label class="block text-xs font-medium text-neutral-600 mb-1">Current password</label><input name="currentPassword" type="password" autocomplete="current-password" class="@Inp" /></div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div><label class="block text-xs font-medium text-neutral-600 mb-1">New password</label><input name="newPassword" type="password" autocomplete="new-password" class="@Inp" /></div>
                <div><label class="block text-xs font-medium text-neutral-600 mb-1">Confirm new password</label><input name="confirmPassword" type="password" autocomplete="new-password" class="@Inp" /></div>
            </div>
            <button type="submit" class="@Btn">Change password</button>
        </form>
    </section>

    <!-- Theme colour -->
    <section class="bg-white border border-neutral-200 rounded-xl p-6">
        <h2 class="text-sm font-semibold text-neutral-800 mb-1">Backend colour</h2>
        <p class="text-[11px] text-neutral-400 mb-4">Your own accent colour for the back office — buttons, links and highlights. Only you see it.</p>
        <form asp-controller="MyAccount" asp-action="Theme" method="post" class="flex flex-wrap items-center gap-3">
            <input type="color" id="accent-input" name="accent" value="@accent" class="w-12 h-10 rounded-lg border border-neutral-200 cursor-pointer bg-white p-1" />
            <div class="flex gap-1.5">
                @foreach (var c in new[] { "#ed028b", "#2563eb", "#059669", "#7c3aed", "#e11d48", "#0891b2", "#475569", "#d97706" })
                {
                    <button type="button" class="preset w-7 h-7 rounded-full border border-neutral-200 hover:scale-110 transition-transform" style="background:@c" data-color="@c" aria-label="@c"></button>
                }
            </div>
            <button type="submit" class="@Btn">Save colour</button>
        </form>
        @if (!string.IsNullOrEmpty(Model.Accent))
        {
            <form asp-controller="MyAccount" asp-action="Theme" method="post" class="mt-2">
                <input type="hidden" name="reset" value="true" />
                <button type="submit" class="text-xs text-neutral-500 hover:text-neutral-800">Reset to default (pink)</button>
            </form>
        }
    </section>

    <!-- Two-factor -->
    <section class="bg-white border border-neutral-200 rounded-xl p-6">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h2 class="text-sm font-semibold text-neutral-800 mb-1">Two-factor authentication</h2>
                <p class="text-[11px] text-neutral-400 max-w-md">An authenticator app gives a one-time code at sign-in — a second layer beyond your password.</p>
            </div>
            <span class="text-[10px] px-2 py-1 rounded-full @(Model.Is2faEnabled ? "bg-emerald-50 text-emerald-700" : "bg-neutral-100 text-neutral-500")">@(Model.Is2faEnabled ? "On" : "Off")</span>
        </div>

        @if (Model.RecoveryCodes != null)
        {
            <div class="mt-4 bg-amber-50 border border-amber-200 rounded-lg p-4">
                <p class="text-xs font-medium text-amber-800 mb-2">Save these recovery codes somewhere safe — each works once if you lose your device.</p>
                <div class="grid grid-cols-2 sm:grid-cols-5 gap-1.5 font-mono text-xs text-neutral-700">
                    @foreach (var code in Model.RecoveryCodes.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                    {
                        <span class="bg-white border border-amber-100 rounded px-2 py-1 text-center">@code</span>
                    }
                </div>
            </div>
        }

        <div class="mt-4 flex flex-wrap items-center gap-3">
            @if (!Model.Is2faEnabled)
            {
                <a asp-controller="MyAccount" asp-action="SetupTwoFactor" class="bg-brand-500 text-white text-sm px-5 py-2 rounded-lg hover:bg-brand-600 transition-colors">Set up two-factor</a>
            }
            else
            {
                <form asp-controller="MyAccount" asp-action="RegenerateRecoveryCodes" method="post">
                    <button type="submit" class="text-sm border border-neutral-200 text-neutral-700 px-4 py-2 rounded-lg hover:bg-neutral-50 transition-colors">Regenerate recovery codes</button>
                </form>
                <form asp-controller="MyAccount" asp-action="DisableTwoFactor" method="post" onsubmit="return confirm('Turn off two-factor authentication?');">
                    <button type="submit" class="text-sm text-red-500 hover:text-red-700 px-2 py-2">Turn off</button>
                </form>
                <span class="text-[11px] text-neutral-400">@Model.RecoveryCodesLeft recovery codes left</span>
            }
        </div>
    </section>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.preset').forEach(function (b) {
        b.addEventListener('click', function () { document.getElementById('accent-input').value = b.dataset.color; });
    });
</script>
}
