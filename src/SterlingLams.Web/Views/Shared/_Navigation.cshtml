@using SterlingLams.Web.Services
@using SterlingLams.Web.Models.ViewModels
@inject ISettingsService SettingsService
@{
    // Read the live cart count from session so the nav badge is correct on every page
    // load (not just after an AJAX add). Mirrors CartController's "cart" session key.
    int cartCount = ViewBag.CartCount ?? 0;
    if (cartCount == 0)
    {
        var cartJson = Context.Session.GetString("cart");
        if (!string.IsNullOrEmpty(cartJson))
        {
            try { cartCount = System.Text.Json.JsonSerializer.Deserialize<CartViewModel>(cartJson)?.TotalItems ?? 0; }
            catch { /* malformed cart cookie — leave at 0 */ }
        }
    }
    var wishlistCount = ViewBag.WishlistCount ?? 0;
    var announcementEnabled = await SettingsService.GetBoolAsync("announcement.enabled", true);
    var announcementText    = await SettingsService.GetAsync("announcement.text", "COMPLIMENTARY SHIPPING ON ORDERS OVER N150,000  |  IN-STORE PICKUP AVAILABLE");
    var announcementBg      = await SettingsService.GetAsync("announcement.bg_color", "bg-brand-500");
    if (string.IsNullOrWhiteSpace(announcementBg)) { announcementBg = "bg-brand-500"; }

    // Top-bar mega-menu: heading → category sub-items (slug). Empty Items = a direct link.
    var megaMenu = new (string Label, string? Href, (string Label, string Slug)[] Items)[]
    {
        ("New In", "/Products?sortBy=newest", System.Array.Empty<(string, string)>()),
        ("Jewelry", null, new (string, string)[]
        {
            ("Sets", "sets"), ("Earrings", "earrings"), ("Rings", "rings"),
            ("Bracelets & Bangles", "bracelets-bangles"), ("Necklaces & Pendants", "necklaces-pendants"),
        }),
        ("Accessories", null, new (string, string)[]
        {
            ("Anklets", "anklets"), ("Waist Chains", "waist-chains"), ("Key Rings", "key-rings"),
            ("Hair Accessories", "hair-accessories"), ("Scarfs & Caps", "scarfs-caps"), ("Belts", "belts"),
            ("Sunglasses", "sunglasses"), ("Brooches", "brooches"), ("Extenders", "extenders"),
        }),
        ("Watches", null, new (string, string)[]
        {
            ("Bracelet Watches", "bracelet-watches"), ("Strap Watches", "strap-watches"),
        }),
        ("Gifts", null, new (string, string)[]
        {
            ("Gift Boxes", "gift-boxes"), ("Gifts Combo Packages", "gifts-combo-packages"),
        }),
        ("Mens", null, new (string, string)[]
        {
            ("Bracelets", "bracelets"), ("Cufflinks", "cufflinks"), ("Unisex Brooches", "unisex-brooches"),
            ("Trouser Chains", "trouser-chains"), ("MenKind", "menkind"),
        }),
        ("Clutches", null, new (string, string)[]
        {
            ("Stoned Clutches", "stoned-clutches"), ("None Stone Clutches", "none-stone-clutches"),
        }),
    };
}

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-b border-neutral-100">
    <!-- Top bar -->
    @if (announcementEnabled)
    {
        <div class="@announcementBg text-white text-xs text-center py-2 tracking-widest font-light">
            @announcementText
        </div>
    }

    <!-- Row 1: Brand name + icons -->
    <div class="relative flex items-center justify-center px-6 py-4">

        <!-- Brand name — centred absolutely so icons never push it -->
        <a asp-controller="Home" asp-action="Index"
           class="absolute left-1/2 -translate-x-1/2">
            <span class="font-cormorant font-semibold uppercase text-neutral-900 tracking-widest whitespace-nowrap"
                  style="font-size: clamp(1.8rem, 3.5vw, 3rem); letter-spacing: 0.28em;">
                Sterlin Glams
            </span>
        </a>

        <!-- Icons — right side -->
        <div class="ml-auto flex items-center gap-5">
            <!-- Search -->
            <button id="search-toggle" aria-label="Search"
                    class="text-neutral-600 hover:text-brand-500 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
                </svg>
            </button>

            <!-- Wishlist -->
            <a asp-controller="Wishlist" asp-action="Index" aria-label="Wishlist"
               class="relative text-neutral-600 hover:text-brand-500 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                </svg>
                @if (wishlistCount > 0)
                {
                    <span class="absolute -top-1.5 -right-1.5 bg-brand-500 text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center">
                        @wishlistCount
                    </span>
                }
            </a>

            <!-- Account -->
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Account" asp-action="Profile" aria-label="Account"
                   class="text-neutral-600 hover:text-brand-500 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                </a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" aria-label="Sign in"
                   class="text-xs tracking-widest uppercase text-neutral-600 hover:text-brand-500 transition-colors">
                    Sign in
                </a>
            }

            <!-- Cart -->
            <a id="cart-link" asp-controller="Cart" asp-action="Index" aria-label="Shopping bag"
               class="relative text-neutral-600 hover:text-brand-500 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                </svg>
                @if (cartCount > 0)
                {
                    <span id="cart-badge"
                          class="absolute -top-1.5 -right-1.5 bg-brand-500 text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center">
                        @cartCount
                    </span>
                }
            </a>

            <!-- Mobile hamburger -->
            <button id="mobile-menu-toggle" class="md:hidden text-neutral-600" aria-label="Menu">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- Row 2: Mega-menu category nav (desktop only) -->
    <nav class="hidden md:flex items-center justify-center gap-7 lg:gap-9 border-t border-neutral-100 py-3">
        @foreach (var m in megaMenu)
        {
            if (m.Items.Length == 0)
            {
                <a href="@m.Href" class="relative text-xs tracking-widest uppercase text-neutral-600 hover:text-brand-500 transition-colors">
                    @if (m.Label == "New In")
                    {
                        <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-green-500 text-white text-[8px] leading-none px-1.5 py-0.5 rounded tracking-wider">LATEST</span>
                    }
                    @m.Label
                </a>
            }
            else
            {
                <div class="relative group">
                    <button type="button" class="flex items-center gap-1 text-xs tracking-widest uppercase text-neutral-600 group-hover:text-brand-500 transition-colors">
                        @m.Label
                        <svg class="w-3 h-3 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <!-- pt-3 forms a hover bridge so the panel stays open between button and list -->
                    <div class="absolute left-1/2 -translate-x-1/2 top-full pt-3 hidden group-hover:block z-50">
                        <div class="bg-neutral-900 min-w-[230px] py-2 shadow-xl">
                            @foreach (var (label, slug) in m.Items)
                            {
                                <a asp-controller="Products" asp-action="Index" asp-route-category="@slug"
                                   class="block px-5 py-2.5 text-sm text-neutral-200 hover:bg-neutral-800 hover:text-white transition-colors whitespace-nowrap">@label</a>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </nav>

    <!-- Mobile menu (accordion) -->
    <div id="mobile-menu" class="md:hidden hidden border-t border-neutral-100 bg-white px-6 py-2 flex flex-col max-h-[70vh] overflow-y-auto">
        @foreach (var m in megaMenu)
        {
            if (m.Items.Length == 0)
            {
                <a href="@m.Href" class="py-3.5 text-sm tracking-[0.15em] uppercase text-neutral-700 border-b border-neutral-100">@m.Label</a>
            }
            else
            {
                <details class="border-b border-neutral-100 group">
                    <summary class="cursor-pointer list-none py-3.5 flex items-center justify-between text-sm tracking-[0.15em] uppercase text-neutral-700">
                        @m.Label
                        <svg class="w-4 h-4 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg>
                    </summary>
                    <div class="pb-3 pl-3 flex flex-col">
                        @foreach (var (label, slug) in m.Items)
                        {
                            <a asp-controller="Products" asp-action="Index" asp-route-category="@slug" class="py-2 text-sm text-neutral-500">@label</a>
                        }
                    </div>
                </details>
            }
        }
        <a asp-controller="Stores" asp-action="Index" class="py-3.5 text-sm tracking-[0.15em] uppercase text-neutral-700">Our Stores</a>
    </div>
</header>

<!-- Search Overlay -->
<div id="search-overlay" class="hidden fixed inset-0 z-[200]" role="dialog" aria-modal="true" aria-label="Search">
    <!-- Backdrop -->
    <div id="search-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
    <!-- Panel -->
    <div class="relative bg-white w-full shadow-xl px-6 py-8">
        <form id="search-form" action="/Products" method="get" class="max-w-2xl mx-auto">
            <div class="flex items-center border-b-2 border-brand-500 gap-4">
                <svg class="w-5 h-5 text-neutral-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
                </svg>
                <input id="search-input" name="search" type="search" autocomplete="off"
                       placeholder="Search rings, necklaces, diamonds…"
                       class="flex-1 py-3 text-lg text-neutral-900 placeholder-neutral-400 bg-transparent outline-none font-light tracking-wide"/>
                <button type="button" id="search-close"
                        class="text-neutral-400 hover:text-neutral-900 transition-colors p-1" aria-label="Close search">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <div id="search-suggestions" class="mt-4 text-sm text-neutral-500 font-light tracking-wide"></div>
        </form>
        <!-- Quick links -->
        <div class="max-w-2xl mx-auto mt-6">
            <p class="text-xs tracking-[0.25em] uppercase text-neutral-400 mb-3">Popular</p>
            <div class="flex flex-wrap gap-2">
                <a href="/Products?category=rings"    onclick="document.getElementById('search-overlay').classList.add('hidden');document.body.style.overflow=''" class="text-xs tracking-widest uppercase border border-neutral-200 px-4 py-2 hover:border-neutral-900 hover:text-neutral-900 transition-colors">Rings</a>
                <a href="/Products?category=necklaces" onclick="document.getElementById('search-overlay').classList.add('hidden');document.body.style.overflow=''" class="text-xs tracking-widest uppercase border border-neutral-200 px-4 py-2 hover:border-neutral-900 hover:text-neutral-900 transition-colors">Necklaces</a>
                <a href="/Products?category=earrings"  onclick="document.getElementById('search-overlay').classList.add('hidden');document.body.style.overflow=''" class="text-xs tracking-widest uppercase border border-neutral-200 px-4 py-2 hover:border-neutral-900 hover:text-neutral-900 transition-colors">Earrings</a>
                <a href="/Products?category=bracelets" onclick="document.getElementById('search-overlay').classList.add('hidden');document.body.style.overflow=''" class="text-xs tracking-widest uppercase border border-neutral-200 px-4 py-2 hover:border-neutral-900 hover:text-neutral-900 transition-colors">Bracelets</a>
                <a href="/Products?isNewArrival=true"  onclick="document.getElementById('search-overlay').classList.add('hidden');document.body.style.overflow=''" class="text-xs tracking-widest uppercase border border-neutral-200 px-4 py-2 hover:border-neutral-900 hover:text-neutral-900 transition-colors">New Arrivals</a>
                <a href="/Products"                    onclick="document.getElementById('search-overlay').classList.add('hidden');document.body.style.overflow=''" class="text-xs tracking-widest uppercase border border-neutral-200 px-4 py-2 hover:border-neutral-900 hover:text-neutral-900 transition-colors">All Jewellery</a>
            </div>
        </div>
    </div>
</div>

<!-- Spacer for fixed nav (shrinks when announcement bar is hidden) -->
<div style="height: @(announcementEnabled ? "90px" : "62px");" class="md:hidden" aria-hidden="true"></div>
<div style="height: @(announcementEnabled ? "126px" : "98px");" class="hidden md:block" aria-hidden="true"></div>
