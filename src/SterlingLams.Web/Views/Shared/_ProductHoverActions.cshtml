@model SterlingLams.Web.Models.ViewModels.ProductCardViewModel
@* Hover action stack shown on a product image: Compare / Quick View / Add to Wishlist.
   Relies on an ancestor having the `group` class (the product card). *@
<div class="absolute top-3 right-3 flex flex-col gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10">

    <div class="group/act relative">
        <span class="pointer-events-none absolute right-full mr-2 top-1/2 -translate-y-1/2 whitespace-nowrap bg-neutral-900 text-white text-[11px] px-2 py-1 rounded opacity-0 group-hover/act:opacity-100 transition-opacity">Compare</span>
        <button type="button" class="compare-toggle bg-white shadow p-2 rounded-md text-neutral-700 hover:bg-brand-500 hover:text-white transition-colors"
                data-product-slug="@Model.Slug" data-product-id="@Model.Id" aria-label="Add to compare">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-9L21 7.5m0 0L16.5 3m4.5 4.5H7.5"/>
            </svg>
        </button>
    </div>

    <div class="group/act relative">
        <span class="pointer-events-none absolute right-full mr-2 top-1/2 -translate-y-1/2 whitespace-nowrap bg-neutral-900 text-white text-[11px] px-2 py-1 rounded opacity-0 group-hover/act:opacity-100 transition-opacity">Quick view</span>
        <button type="button" class="quick-view-btn bg-white shadow p-2 rounded-md text-neutral-700 hover:bg-brand-500 hover:text-white transition-colors"
                data-product-slug="@Model.Slug" aria-label="Quick view">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
        </button>
    </div>

    <div class="group/act relative">
        <span class="pointer-events-none absolute right-full mr-2 top-1/2 -translate-y-1/2 whitespace-nowrap bg-neutral-900 text-white text-[11px] px-2 py-1 rounded opacity-0 group-hover/act:opacity-100 transition-opacity">Add to wishlist</span>
        <button type="button" class="wishlist-toggle bg-white shadow p-2 rounded-md text-neutral-700 hover:bg-brand-500 hover:text-white transition-colors"
                data-product-id="@Model.Id" aria-label="Add to wishlist">
            <svg class="w-4 h-4 @(Model.IsInWishlist ? "fill-brand-500 text-brand-500" : "")" fill="@(Model.IsInWishlist ? "currentColor" : "none")" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
        </button>
    </div>
</div>
