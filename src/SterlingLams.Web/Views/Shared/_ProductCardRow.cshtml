@model List<SterlingLams.Web.Models.ViewModels.ProductCardViewModel>
@{
    var title = ViewData["RowTitle"] as string ?? "";
    var eyebrow = ViewData["RowEyebrow"] as string ?? "";
    var bg = ViewData["RowBg"] as string ?? "bg-white";
}
@* Reusable merchandising row (best sellers / trending / recently viewed / new arrivals).
   Renders nothing when there are no products, so empty rows never show. *@
@if (Model != null && Model.Any())
{
    <section class="py-20 @bg">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-14">
                @if (!string.IsNullOrEmpty(eyebrow))
                {
                    <p class="text-xs tracking-[0.3em] uppercase text-brand-500 mb-3">@eyebrow</p>
                }
                <h2 class="font-cormorant text-4xl font-light text-neutral-900">@title</h2>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                @foreach (var p in Model)
                {
                    <div class="group">
                        <a asp-controller="Products" asp-action="Detail" asp-route-slug="@p.Slug" class="block">
                            <div class="aspect-square bg-neutral-100 mb-4 overflow-hidden relative">
                                <img src="@p.PrimaryImageUrl" alt="@p.Name" loading="lazy"
                                     class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105 @(p.SecondaryImageUrl != null ? "group-hover:opacity-0" : "")" />
                                @if (p.SecondaryImageUrl != null)
                                {
                                    <img src="@p.SecondaryImageUrl" alt="@p.Name" loading="lazy"
                                         class="absolute inset-0 w-full h-full object-cover opacity-0 transition-all duration-700 group-hover:opacity-100 group-hover:scale-105" />
                                }
                                <partial name="_DiscountBadge" model="p.DiscountPercent" />
                                @if (!p.IsAvailable)
                                {
                                    <div class="absolute inset-0 bg-white/50 flex items-center justify-center">
                                        <span class="text-xs tracking-widest uppercase text-neutral-500">Sold Out</span>
                                    </div>
                                }
                                else if (p.IsNewArrival)
                                {
                                    <span class="absolute top-3 left-3 bg-brand-500 text-white text-[9px] tracking-widest uppercase px-2 py-1">New</span>
                                }
                                <partial name="_ProductHoverActions" model="p" />
                            </div>
                            <h3 class="font-light text-sm text-neutral-700 group-hover:text-neutral-900 transition-colors leading-snug">@p.Name</h3>
                            @if (p.IsOnSale)
                            {
                                <p class="text-xs mt-1"><span class="text-neutral-400 line-through">@p.FormattedRegularPrice</span> <span class="text-brand-600 ml-1">@p.FormattedPrice</span></p>
                            }
                            else
                            {
                                <p class="text-xs text-neutral-400 mt-1">@p.FormattedPrice</p>
                            }
                        </a>
                        <partial name="_ProductCardCta" model="p" />
                    </div>
                }
            </div>
        </div>
    </section>
}
