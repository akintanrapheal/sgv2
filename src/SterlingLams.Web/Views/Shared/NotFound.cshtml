@{
    ViewData["Title"] = "Page Not Found";
    Response.StatusCode = 404;
}

<div class="max-w-xl mx-auto px-6 py-32 text-center">
    <p class="font-cormorant text-9xl font-light text-neutral-100 leading-none select-none">404</p>
    <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-4 -mt-4">Page not found</p>
    <h1 class="font-cormorant text-4xl font-light text-neutral-900 mb-6">We couldn't find that page</h1>
    <p class="text-sm text-neutral-400 font-light mb-10">
        The page you're looking for may have been moved or no longer exists.
    </p>
    <div class="flex gap-4 justify-center">
        <a asp-controller="Home" asp-action="Index" class="btn-primary">Go Home</a>
        <a asp-controller="Products" asp-action="Index" class="btn-outline">Browse Collections</a>
    </div>
</div>
