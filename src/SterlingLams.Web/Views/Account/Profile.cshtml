@model SterlingLams.Web.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Account";
}

<div class="max-w-4xl mx-auto px-6 py-16">
    <div class="mb-10">
        <p class="section-label">Your account</p>
        <h1 class="font-cormorant text-4xl font-light">Hello, @Model.FirstName</h1>
    </div>

    <div class="grid md:grid-cols-3 gap-10">

        <!-- ─── Sidebar nav ──────────────────────────────────────────────── -->
        <aside class="md:col-span-1">
            <nav class="flex flex-col gap-1">
                @foreach (var (label, action) in new[] {
                    ("My Profile", "Profile"),
                    ("My Orders", "Orders"),
                    ("Change Password", "ChangePassword"),
                })
                {
                    <a asp-action="@action"
                       class="text-sm py-3 border-b border-neutral-100 text-neutral-600 hover:text-neutral-900 transition-colors @(ViewContext.RouteData.Values["action"]?.ToString() == action ? "text-neutral-900 font-medium" : "")">
                        @label
                    </a>
                }
                <form asp-action="Logout" method="post" class="mt-2">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="text-sm text-neutral-400 hover:text-neutral-700 transition-colors py-2">
                        Sign out
                    </button>
                </form>
            </nav>
        </aside>

        <!-- ─── Main content ────────────────────────────────────────────── -->
        <div class="md:col-span-2 space-y-10">

            <!-- Account Info -->
            <section>
                <h2 class="font-cormorant text-2xl font-light mb-6">Account Details</h2>
                <dl class="space-y-4">
                    <div class="flex flex-col sm:flex-row sm:gap-6">
                        <dt class="text-xs tracking-[0.15em] uppercase text-neutral-400 w-32 flex-shrink-0 pt-0.5">Name</dt>
                        <dd class="text-sm text-neutral-700">@Model.FirstName @Model.LastName</dd>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:gap-6">
                        <dt class="text-xs tracking-[0.15em] uppercase text-neutral-400 w-32 flex-shrink-0 pt-0.5">Email</dt>
                        <dd class="text-sm text-neutral-700">@Model.Email</dd>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <div class="flex flex-col sm:flex-row sm:gap-6">
                            <dt class="text-xs tracking-[0.15em] uppercase text-neutral-400 w-32 flex-shrink-0 pt-0.5">Phone</dt>
                            <dd class="text-sm text-neutral-700">@Model.Phone</dd>
                        </div>
                    }
                    <div class="flex flex-col sm:flex-row sm:gap-6">
                        <dt class="text-xs tracking-[0.15em] uppercase text-neutral-400 w-32 flex-shrink-0 pt-0.5">Member since</dt>
                        <dd class="text-sm text-neutral-700">@Model.CreatedAt.ToString("MMMM yyyy")</dd>
                    </div>
                </dl>
            </section>

            <!-- Recent Orders -->
            @if (Model.RecentOrders.Any())
            {
                <section>
                    <div class="flex justify-between items-baseline mb-6">
                        <h2 class="font-cormorant text-2xl font-light">Recent Orders</h2>
                        <a asp-action="Orders" class="text-xs tracking-widest uppercase text-neutral-400 hover:text-neutral-900 transition-colors">
                            View all
                        </a>
                    </div>
                    <div class="space-y-3">
                        @foreach (var order in Model.RecentOrders)
                        {
                            <a asp-action="OrderDetail" asp-route-id="@order.Id"
                               class="flex items-center justify-between py-4 border-b border-neutral-100 hover:bg-neutral-50 -mx-4 px-4 transition-colors group">
                                <div>
                                    <p class="text-sm text-neutral-800 font-light">@order.OrderNumber</p>
                                    <p class="text-xs text-neutral-400 mt-0.5">@order.CreatedAt.ToString("d MMM yyyy") · @order.ItemCount piece@(order.ItemCount == 1 ? "" : "s")</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-sm text-neutral-700">@order.FormattedTotal</p>
                                    <span class="text-[10px] tracking-widest uppercase @(order.Status == "Delivered" ? "text-emerald-600" : "text-neutral-400")">
                                        @order.Status
                                    </span>
                                </div>
                            </a>
                        }
                    </div>
                </section>
            }
            else
            {
                <section>
                    <h2 class="font-cormorant text-2xl font-light mb-4">Recent Orders</h2>
                    <p class="text-sm text-neutral-400 font-light">You haven't placed any orders yet.</p>
                    <a asp-controller="Products" asp-action="Index" class="btn-outline mt-6 inline-block">
                        Start Shopping
                    </a>
                </section>
            }
        </div>
    </div>
</div>
