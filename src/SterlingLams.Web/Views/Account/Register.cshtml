@model SterlingLams.Web.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="min-h-[80vh] flex items-center justify-center py-16 px-4">
    <div class="w-full max-w-md">
        <div class="text-center mb-10">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-2">Join us</p>
            <h1 class="font-cormorant text-4xl font-light">Create an Account</h1>
        </div>

        <form asp-action="Register" method="post" class="space-y-5">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="text-sm text-red-600 bg-red-50 px-4 py-3 border border-red-100"></div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="FirstName" class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">First Name</label>
                    <input asp-for="FirstName" class="form-input" placeholder="Jane" autocomplete="given-name" />
                    <span asp-validation-for="FirstName" class="text-xs text-red-500 mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="LastName" class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Last Name</label>
                    <input asp-for="LastName" class="form-input" placeholder="Smith" autocomplete="family-name" />
                    <span asp-validation-for="LastName" class="text-xs text-red-500 mt-1 block"></span>
                </div>
            </div>

            <div>
                <label asp-for="Email" class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Email</label>
                <input asp-for="Email" type="email" class="form-input" placeholder="your@email.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Phone" class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Phone <span class="text-neutral-300">(optional)</span></label>
                <input asp-for="Phone" type="tel" class="form-input" placeholder="+234 800 000 0000" autocomplete="tel" />
                <span asp-validation-for="Phone" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Password</label>
                <input asp-for="Password" type="password" class="form-input" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-xs text-red-500 mt-1 block"></span>
                <p class="text-[11px] text-neutral-400 mt-1">Minimum 8 characters</p>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-input" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <button type="submit"
                    class="w-full bg-neutral-900 text-white text-xs tracking-[0.2em] uppercase py-4 hover:bg-neutral-700 transition-colors duration-300 mt-2">
                Create Account
            </button>

            <p class="text-[11px] text-neutral-400 text-center leading-relaxed">
                By creating an account you agree to our
                <a href="#" class="underline underline-offset-2">Terms of Service</a> and
                <a href="#" class="underline underline-offset-2">Privacy Policy</a>.
            </p>
        </form>

        <p class="text-center text-sm text-neutral-400 mt-8 font-light">
            Already have an account?
            <a asp-action="Login" class="text-neutral-700 hover:text-neutral-900 underline underline-offset-2 transition-colors">
                Sign in
            </a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
