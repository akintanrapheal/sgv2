@{
    ViewData["Title"] = "Forgot Password";
}

<div class="min-h-[80vh] flex items-center justify-center py-16 px-4">
    <div class="w-full max-w-md">
        <div class="text-center mb-10">
            <p class="text-xs tracking-[0.3em] uppercase text-brand-500 mb-2">Account Recovery</p>
            <h1 class="font-cormorant text-4xl font-light">Forgot Password</h1>
            <p class="text-sm text-neutral-400 font-light mt-4 leading-relaxed">
                Enter your email address and we'll send you a link to reset your password.
            </p>
        </div>

        <form asp-action="ForgotPassword" method="post" class="space-y-5">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-sm text-red-600 bg-red-50 px-4 py-3 border border-red-100 hidden"></div>

            <div>
                <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Email</label>
                <input type="email" name="email" autocomplete="email" required
                       class="form-input" placeholder="your@email.com" />
            </div>

            <button type="submit"
                    class="w-full bg-brand-500 text-white text-xs tracking-[0.2em] uppercase py-4 hover:bg-brand-600 transition-colors duration-300">
                Send Reset Link
            </button>
        </form>

        <p class="text-center text-sm text-neutral-400 mt-8 font-light">
            Remembered your password?
            <a asp-action="Login" class="text-neutral-700 hover:text-brand-500 underline underline-offset-2 transition-colors">
                Sign in
            </a>
        </p>
    </div>
</div>
