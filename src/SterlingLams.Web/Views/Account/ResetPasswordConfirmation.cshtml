@{
    ViewData["Title"] = "Password Reset Successful";
}

<div class="min-h-[80vh] flex items-center justify-center py-16 px-4">
    <div class="w-full max-w-md text-center">
        <div class="w-16 h-16 rounded-full bg-emerald-50 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/>
            </svg>
        </div>
        <p class="text-xs tracking-[0.3em] uppercase text-brand-500 mb-2">Done</p>
        <h1 class="font-cormorant text-4xl font-light mb-6">Password Updated</h1>
        <p class="text-sm text-neutral-500 font-light leading-relaxed mb-8">
            Your password has been reset successfully. You can now sign in with your new password.
        </p>
        <a asp-action="Login"
           class="inline-block bg-brand-500 text-white text-xs tracking-[0.2em] uppercase px-10 py-4 hover:bg-brand-600 transition-colors duration-300">
            Sign In
        </a>
    </div>
</div>
