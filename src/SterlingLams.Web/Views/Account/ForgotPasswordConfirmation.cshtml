@{
    ViewData["Title"] = "Check Your Email";
}

<div class="min-h-[80vh] flex items-center justify-center py-16 px-4">
    <div class="w-full max-w-md text-center">
        <div class="w-16 h-16 rounded-full bg-brand-50 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
        </div>
        <p class="text-xs tracking-[0.3em] uppercase text-brand-500 mb-2">Check Your Inbox</p>
        <h1 class="font-cormorant text-4xl font-light mb-6">Email Sent</h1>
        <p class="text-sm text-neutral-500 font-light leading-relaxed mb-8">
            If an account exists for that email, you will receive a password reset link shortly.
            Please check your spam folder if you don't see it within a few minutes.
        </p>
        <a asp-action="Login"
           class="inline-block border border-brand-500 text-brand-500 text-xs tracking-[0.2em] uppercase px-10 py-4 hover:bg-brand-500 hover:text-white transition-colors duration-300">
            Return to Sign In
        </a>
    </div>
</div>
