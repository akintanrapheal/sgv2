@model SterlingLams.Web.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="max-w-4xl mx-auto px-6 py-16">
    <div class="mb-10">
        <p class="section-label">Security</p>
        <h1 class="font-cormorant text-4xl font-light">Change Password</h1>
    </div>

    <div class="max-w-md">
        <form asp-action="ChangePassword" method="post" class="space-y-5">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="text-sm text-red-600 bg-red-50 px-4 py-3 border border-red-100"></div>

            <div>
                <label asp-for="CurrentPassword" class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Current Password</label>
                <input asp-for="CurrentPassword" type="password" class="form-input" />
                <span asp-validation-for="CurrentPassword" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label asp-for="NewPassword" class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">New Password</label>
                <input asp-for="NewPassword" type="password" class="form-input" />
                <span asp-validation-for="NewPassword" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label asp-for="ConfirmNewPassword" class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Confirm New Password</label>
                <input asp-for="ConfirmNewPassword" type="password" class="form-input" />
                <span asp-validation-for="ConfirmNewPassword" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <button type="submit" class="btn-primary">Update Password</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
