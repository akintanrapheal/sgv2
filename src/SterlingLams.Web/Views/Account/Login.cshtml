@model SterlingLams.Web.Models.ViewModels.LoginViewModel
@{
    // Staff heading into /Admin or /Inventory get a back-office sign-in (own minimal layout,
    // no storefront chrome). Same form + POST handler — only the presentation differs.
    var ru = Model.ReturnUrl ?? "";
    var staff = ru.StartsWith("/Admin", StringComparison.OrdinalIgnoreCase)
             || ru.StartsWith("/Inventory", StringComparison.OrdinalIgnoreCase)
             || ru.StartsWith("/Marketing", StringComparison.OrdinalIgnoreCase)
             || ru.StartsWith("/Till", StringComparison.OrdinalIgnoreCase)
             || ru.StartsWith("/Pos", StringComparison.OrdinalIgnoreCase);
    if (staff) { Layout = "_StaffAuthLayout"; }
    // Workspace label shown on the staff sign-in chrome.
    ViewData["Workspace"] = ru.StartsWith("/Marketing", StringComparison.OrdinalIgnoreCase) ? "Marketing Hub"
        : ru.StartsWith("/Inventory", StringComparison.OrdinalIgnoreCase) ? "Inventory System"
        : "Staff Workspace";
    ViewData["Title"] = staff ? "Staff Sign In" : "Sign In";
}

@if (staff)
{
    <div class="text-center mb-6">
        <h1 class="font-cormorant text-2xl font-light text-neutral-900">Staff sign in</h1>
        <p class="text-xs text-neutral-400 mt-1">Sign in to continue to the back office</p>
    </div>
    <partial name="_LoginForm" model="Model" />
}
else
{
    <div class="min-h-[80vh] flex items-center justify-center py-16 px-4">
        <div class="w-full max-w-md">
            <div class="text-center mb-10">
                <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-2">Welcome back</p>
                <h1 class="font-cormorant text-4xl font-light">Sign In</h1>
            </div>

            <partial name="_LoginForm" model="Model" />

            <p class="text-center text-sm text-neutral-400 mt-8 font-light">
                New to Sterlin Glams?
                <a asp-action="Register" class="text-neutral-700 hover:text-brand-500 underline underline-offset-2 transition-colors">
                    Create an account
                </a>
            </p>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
