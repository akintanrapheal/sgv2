@model SterlingLams.Web.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="min-h-[80vh] flex items-center justify-center py-16 px-4">
    <div class="w-full max-w-md">
        <div class="text-center mb-10">
            <p class="text-xs tracking-[0.3em] uppercase text-brand-500 mb-2">Account Recovery</p>
            <h1 class="font-cormorant text-4xl font-light">Set New Password</h1>
        </div>

        <form asp-action="ResetPassword" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />

            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 px-4 py-3 border border-red-100"></div>

            <div>
                <label asp-for="NewPassword" class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">New Password</label>
                <input asp-for="NewPassword" type="password" autocomplete="new-password"
                       class="form-input" placeholder="Minimum 8 characters" />
                <span asp-validation-for="NewPassword" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" autocomplete="new-password"
                       class="form-input" placeholder="Re-enter new password" />
                <span asp-validation-for="ConfirmPassword" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <button type="submit"
                    class="w-full bg-brand-500 text-white text-xs tracking-[0.2em] uppercase py-4 hover:bg-brand-600 transition-colors duration-300">
                Reset Password
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
