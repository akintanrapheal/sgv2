@model SterlingLams.Web.Areas.Admin.ViewModels.AdminCategoryEditViewModel
@{
    var isNew = Model.Id == 0;
}

<div class="mb-6">
    <a asp-area="Admin" asp-controller="Categories" asp-action="Index"
       class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">← Back to Categories</a>
</div>

<div class="max-w-lg">
    <form asp-area="Admin" asp-controller="Categories" asp-action="Save" method="post" enctype="multipart/form-data" class="space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div>
            <label class="block text-xs text-neutral-500 mb-1">Name *</label>
            <input asp-for="Name" required
                   class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
        </div>

        <div>
            <label class="block text-xs text-neutral-500 mb-1">Category Image</label>
            <p class="text-[11px] text-neutral-400 mb-1.5">Shown in the homepage “Shop by Category” section. Recommended: square image, at least 600×600px.</p>
            <div class="space-y-3">
                <div id="cat-img-preview" class="@(string.IsNullOrEmpty(Model.ImageUrl) ? "hidden " : "")inline-block">
                    <img src="@Model.ImageUrl" alt="Preview"
                         class="h-32 w-32 object-cover rounded border border-neutral-200" />
                </div>
                <div class="flex gap-2 items-center">
                    <label class="cursor-pointer inline-flex items-center gap-2 px-3 py-2 border border-neutral-200 rounded-sm text-xs text-neutral-600 hover:border-neutral-400 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        <span>Upload from computer</span>
                        <input type="file" name="imageFile" accept="image/*" class="hidden"
                               onchange="(function(i){var f=i.files[0];if(!f)return;var r=new FileReader();r.onload=function(e){var w=document.getElementById('cat-img-preview');w.classList.remove('hidden');w.querySelector('img').src=e.target.result;};r.readAsDataURL(f);i.closest('label').querySelector('span').textContent=f.name;})(this)" />
                    </label>
                    <span class="text-neutral-400 text-xs">or</span>
                    <input asp-for="ImageUrl" type="url" placeholder="https://…"
                           class="flex-1 border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
            </div>
        </div>

        <div>
            <label class="block text-xs text-neutral-500 mb-1">Slug (leave blank to auto-generate)</label>
            <input asp-for="Slug"
                   class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400 font-mono" />
        </div>

        <div>
            <label class="block text-xs text-neutral-500 mb-1">Description</label>
            <textarea asp-for="Description" rows="3"
                      class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400 resize-none"></textarea>
        </div>

        <div>
            <label class="block text-xs text-neutral-500 mb-1">Parent Category</label>
            <select asp-for="ParentId"
                    class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400">
                <option value="">— None (top-level) —</option>
                @foreach (var cat in Model.AllCategories)
                {
                    <option value="@cat.Id" selected="@(Model.ParentId == cat.Id)">@cat.Name</option>
                }
            </select>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-xs text-neutral-500 mb-1">Sort Order</label>
                <input asp-for="SortOrder" type="number" min="0"
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>
            <div class="flex items-end pb-2">
                <label class="flex items-center gap-2 text-sm cursor-pointer">
                    <input asp-for="IsActive" type="checkbox" class="accent-neutral-900" />
                    <span class="text-xs text-neutral-600">Active</span>
                </label>
            </div>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit"
                    class="px-6 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
                @(isNew ? "Create Category" : "Save Changes")
            </button>
            <a asp-area="Admin" asp-controller="Categories" asp-action="Index"
               class="px-6 py-2 border border-neutral-200 text-neutral-600 text-xs rounded-sm hover:border-neutral-400 transition-colors">
                Cancel
            </a>
        </div>
    </form>
</div>
