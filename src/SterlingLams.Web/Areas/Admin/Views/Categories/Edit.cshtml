@model SterlingLams.Web.Areas.Admin.ViewModels.AdminCategoryEditViewModel
@{
    var isNew = Model.Id == 0;
}

<div class="mb-6">
    <a asp-area="Admin" asp-controller="Categories" asp-action="Index"
       class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">← Back to Categories</a>
</div>

<div class="max-w-lg">
    <form asp-area="Admin" asp-controller="Categories" asp-action="Save" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div>
            <label class="block text-xs text-neutral-500 mb-1">Name *</label>
            <input asp-for="Name" required
                   class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
        </div>

        <div>
            <label class="block text-xs text-neutral-500 mb-1">Slug (leave blank to auto-generate)</label>
            <input asp-for="Slug"
                   class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400 font-mono" />
        </div>

        <div>
            <label class="block text-xs text-neutral-500 mb-1">Description</label>
            <textarea asp-for="Description" rows="3"
                      class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400 resize-none"></textarea>
        </div>

        <div>
            <label class="block text-xs text-neutral-500 mb-1">Parent Category</label>
            <select asp-for="ParentId"
                    class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400">
                <option value="">— None (top-level) —</option>
                @foreach (var cat in Model.AllCategories)
                {
                    <option value="@cat.Id" selected="@(Model.ParentId == cat.Id)">@cat.Name</option>
                }
            </select>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-xs text-neutral-500 mb-1">Sort Order</label>
                <input asp-for="SortOrder" type="number" min="0"
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>
            <div class="flex items-end pb-2">
                <label class="flex items-center gap-2 text-sm cursor-pointer">
                    <input asp-for="IsActive" type="checkbox" class="accent-neutral-900" />
                    <span class="text-xs text-neutral-600">Active</span>
                </label>
            </div>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit"
                    class="px-6 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
                @(isNew ? "Create Category" : "Save Changes")
            </button>
            <a asp-area="Admin" asp-controller="Categories" asp-action="Index"
               class="px-6 py-2 border border-neutral-200 text-neutral-600 text-xs rounded-sm hover:border-neutral-400 transition-colors">
                Cancel
            </a>
        </div>
    </form>
</div>
