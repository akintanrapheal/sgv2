@model System.Collections.Generic.List<SterlingLams.Web.Models.Domain.Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="flex items-center justify-between mb-6">
    <h2 class="text-sm font-medium">All Categories</h2>
    <a asp-area="Admin" asp-controller="Categories" asp-action="Create"
       class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
        + New Category
    </a>
</div>

<div class="bg-white rounded-sm border border-neutral-100 overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-neutral-100 bg-neutral-50">
                <th class="text-left px-6 py-3 text-xs text-neutral-400 font-medium">Name</th>
                <th class="text-left px-6 py-3 text-xs text-neutral-400 font-medium">Slug</th>
                <th class="text-left px-6 py-3 text-xs text-neutral-400 font-medium">Parent</th>
                <th class="text-right px-6 py-3 text-xs text-neutral-400 font-medium">Sort</th>
                <th class="text-left px-6 py-3 text-xs text-neutral-400 font-medium">Status</th>
                <th class="px-6 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-50">
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="px-6 py-10 text-center text-xs text-neutral-400">No categories found.</td></tr>
            }
            @foreach (var c in Model)
            {
                <tr class="hover:bg-neutral-50 transition-colors">
                    <td class="px-6 py-3 text-xs font-medium text-neutral-800">@c.Name</td>
                    <td class="px-6 py-3 text-xs text-neutral-400 font-mono">@c.Slug</td>
                    <td class="px-6 py-3 text-xs text-neutral-500">@(c.Parent?.Name ?? "—")</td>
                    <td class="px-6 py-3 text-xs text-right text-neutral-500">@c.SortOrder</td>
                    <td class="px-6 py-3">
                        @if (c.IsActive)
                        {
                            <span class="text-[10px] bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Active</span>
                        }
                        else
                        {
                            <span class="text-[10px] bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full">Inactive</span>
                        }
                    </td>
                    <td class="px-6 py-3 text-right flex items-center justify-end gap-3">
                        <a asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@c.Id"
                           class="text-xs text-neutral-500 hover:text-neutral-900 transition-colors">Edit</a>
                        <form asp-area="Admin" asp-controller="Categories" asp-action="Delete" asp-route-id="@c.Id"
                              method="post" onsubmit="return confirm('Delete this category?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="text-xs text-red-400 hover:text-red-700 transition-colors">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
