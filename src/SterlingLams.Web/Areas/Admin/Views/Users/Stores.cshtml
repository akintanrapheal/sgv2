@{
    var user = ViewBag.User as SterlingLams.Web.Models.Domain.ApplicationUser;
    var stores = ViewBag.AllStores as List<SterlingLams.Web.Models.Domain.Store> ?? new();
    var assigned = ViewBag.Assigned as HashSet<int> ?? new();
    ViewData["Title"] = "Branch Access";
}

<div class="max-w-xl mx-auto">
    <a asp-action="Index" class="text-xs tracking-widest uppercase text-neutral-400 hover:text-neutral-700 transition-colors">← Users</a>
    <h1 class="text-xl font-medium mt-3 mb-1">Branch access</h1>
    <p class="text-sm text-neutral-500 mb-6">@user?.FullName <span class="text-neutral-400">(@user?.Email)</span></p>

    <div class="bg-white rounded-sm border border-neutral-100 p-6">
        <p class="text-sm text-neutral-600 mb-1">Tick the branches this user may <strong>make changes to</strong> — stock edits, stock-take, transfers, and POS sales.</p>
        <p class="text-xs text-neutral-400 mb-5">Leave every box unticked to keep them <strong>unrestricted</strong> (all branches). Administrators always have every branch. Viewing stock/reports is never restricted.</p>

        <form asp-action="SetStores" asp-route-id="@user?.Id" method="post" class="space-y-3">
            @Html.AntiForgeryToken()
            @if (stores.Count == 0)
            {
                <p class="text-sm text-neutral-400">No active branches.</p>
            }
            else
            {
                foreach (var s in stores)
                {
                    <label class="flex items-center gap-3 text-sm text-neutral-700">
                        <input type="checkbox" name="storeIds" value="@s.Id" checked="@assigned.Contains(s.Id)"
                               class="rounded border-neutral-300 text-brand-500 focus:ring-brand-400" />
                        @s.Name
                    </label>
                }
            }
            <div class="pt-4 flex items-center gap-3">
                <button type="submit" class="bg-brand-500 text-white text-xs tracking-[0.15em] uppercase px-6 py-2.5 rounded-sm hover:bg-brand-600 transition-colors">Save</button>
                <a asp-action="Index" class="text-xs text-neutral-500 hover:text-neutral-800 transition-colors">Cancel</a>
            </div>
        </form>
    </div>
</div>
