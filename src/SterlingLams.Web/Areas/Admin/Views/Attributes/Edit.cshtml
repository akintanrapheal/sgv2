@model SterlingLams.Web.Areas.Admin.ViewModels.AdminAttributeEditViewModel
@{
    var isNew = Model.Id == 0;
    ViewData["Title"] = isNew ? "New Attribute" : $"Edit — {Model.Name}";
}

<div class="flex items-center gap-3 mb-6">
    <a asp-area="Admin" asp-controller="Attributes" asp-action="Index"
       class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">← Attributes</a>
    <span class="text-neutral-200">/</span>
    <span class="text-xs text-neutral-600">@(isNew ? "New Attribute" : Model.Name)</span>
</div>

<div class="max-w-2xl space-y-6">

    <!-- ── Attribute details ──────────────────────────────────────────────── -->
    <div class="bg-white rounded-sm border border-neutral-100 p-6">
        <h2 class="text-xs tracking-[0.15em] uppercase text-neutral-400 mb-4">Attribute Details</h2>
        <form asp-area="Admin" asp-controller="Attributes" asp-action="Save" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Name" class="block text-xs text-neutral-500 mb-1">Name <span class="text-red-400">*</span></label>
                    <input asp-for="Name" placeholder="e.g. Colour"
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                    <span asp-validation-for="Name" class="text-xs text-red-500"></span>
                </div>
                <div>
                    <label asp-for="Slug" class="block text-xs text-neutral-500 mb-1">Slug <span class="text-neutral-300">(auto if blank)</span></label>
                    <input asp-for="Slug" placeholder="e.g. colour"
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm font-mono focus:outline-none focus:border-neutral-400" />
                </div>
            </div>

            <div class="flex gap-6">
                <label class="flex items-center gap-2 text-sm text-neutral-600 cursor-pointer">
                    <input asp-for="IsActive" type="checkbox" class="rounded" />
                    Active
                </label>
                <div class="flex items-center gap-2">
                    <label asp-for="SortOrder" class="text-xs text-neutral-500">Sort Order</label>
                    <input asp-for="SortOrder" type="number" min="0"
                           class="w-20 border border-neutral-200 rounded-sm px-3 py-1.5 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
            </div>

            <div class="flex gap-3">
                <button type="submit"
                        class="px-6 py-2.5 bg-neutral-900 text-white text-sm rounded-sm hover:bg-neutral-700 transition-colors">
                    @(isNew ? "Create Attribute" : "Save Changes")
                </button>
                <a asp-area="Admin" asp-controller="Attributes" asp-action="Index"
                   class="px-6 py-2.5 border border-neutral-200 text-neutral-600 text-sm rounded-sm hover:bg-neutral-50 transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>

    <!-- ── Values ─────────────────────────────────────────────────────────── -->
    @if (!isNew)
    {
        <div class="bg-white rounded-sm border border-neutral-100 p-6">
            <h2 class="text-xs tracking-[0.15em] uppercase text-neutral-400 mb-4">Values</h2>

            @if (Model.Values.Any())
            {
                <div class="mb-5 space-y-2">
                    @foreach (var val in Model.Values)
                    {
                        <div class="flex items-center justify-between py-2 border-b border-neutral-50">
                            <div class="flex items-center gap-3">
                                @if (!string.IsNullOrEmpty(val.ColorHex))
                                {
                                    <span class="w-5 h-5 rounded-full border border-neutral-200 flex-shrink-0"
                                          style="background-color: @val.ColorHex"></span>
                                }
                                <span class="text-sm text-neutral-800">@val.Value</span>
                                @if (!string.IsNullOrEmpty(val.ColorHex))
                                {
                                    <span class="text-xs font-mono text-neutral-400">@val.ColorHex</span>
                                }
                            </div>
                            <form asp-area="Admin" asp-controller="Attributes" asp-action="DeleteValue"
                                  method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="attributeId" value="@Model.Id" />
                                <input type="hidden" name="valueId" value="@val.Id" />
                                <button type="submit"
                                        class="text-xs text-rose-400 hover:text-rose-700 transition-colors"
                                        onclick="return confirm('Remove value @val.Value?')">Remove</button>
                            </form>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-xs text-neutral-400 mb-4">No values yet. Add your first value below.</p>
            }

            <!-- Add value form -->
            <form asp-area="Admin" asp-controller="Attributes" asp-action="AddValue"
                  asp-route-id="@Model.Id" method="post" class="flex gap-3 items-end">
                @Html.AntiForgeryToken()
                <div class="flex-1">
                    <label class="block text-xs text-neutral-500 mb-1">New Value <span class="text-red-400">*</span></label>
                    <input name="value" type="text" required placeholder="e.g. Gold"
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
                <div class="w-36">
                    <label class="block text-xs text-neutral-500 mb-1">Colour Hex <span class="text-neutral-300">(optional)</span></label>
                    <input name="colorHex" type="text" placeholder="#FFD700"
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm font-mono focus:outline-none focus:border-neutral-400" />
                </div>
                <button type="submit"
                        class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors flex-shrink-0">
                    Add Value
                </button>
            </form>
        </div>
    }
</div>
