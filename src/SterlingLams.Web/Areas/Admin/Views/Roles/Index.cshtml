@model SterlingLams.Web.Areas.Admin.ViewModels.AdminRoleListViewModel
@{
    ViewData["Title"] = "Roles & Permissions";
}

<div class="flex items-center justify-between mb-6">
    <p class="text-xs text-neutral-400 max-w-xl">
        Roles control which sections of the admin a staff member can access. Assign roles to users
        on the <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="underline hover:text-neutral-700">Users</a> page.
    </p>
    <a asp-area="Admin" asp-controller="Roles" asp-action="Create"
       class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors whitespace-nowrap">
        + New Role
    </a>
</div>

<div class="space-y-3">
    @foreach (var role in Model.Roles)
    {
        <div class="bg-white rounded-sm border border-neutral-100 p-5">
            <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-3">
                    <h2 class="text-sm font-medium text-neutral-800">@role.Name</h2>
                    @if (role.IsFullAccess)
                    {
                        <span class="text-[10px] bg-violet-50 text-violet-700 px-2 py-0.5 rounded-full">Full Access</span>
                    }
                    else if (role.IsSystem)
                    {
                        <span class="text-[10px] bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full">System</span>
                    }
                    <span class="text-[10px] text-neutral-400">@role.UserCount user@(role.UserCount == 1 ? "" : "s")</span>
                </div>
                @if (!role.IsSystem)
                {
                    <div class="flex items-center gap-3">
                        <a asp-area="Admin" asp-controller="Roles" asp-action="Edit" asp-route-id="@role.Name"
                           class="text-xs text-neutral-500 hover:text-neutral-900 transition-colors">Edit</a>
                        <form asp-area="Admin" asp-controller="Roles" asp-action="Delete" asp-route-id="@role.Name"
                              method="post" class="inline"
                              onsubmit="return confirm('Delete role @role.Name?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" data-no-loading="1"
                                    class="text-xs text-rose-400 hover:text-rose-700 transition-colors">Delete</button>
                        </form>
                    </div>
                }
            </div>

            @if (role.IsFullAccess)
            {
                <p class="text-xs text-neutral-400">Access to every section. Cannot be restricted.</p>
            }
            else if (role.Sections.Any())
            {
                <div class="flex flex-wrap gap-1.5">
                    @foreach (var s in role.Sections)
                    {
                        <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2.5 py-0.5 rounded-full">@s</span>
                    }
                </div>
            }
            else
            {
                <p class="text-xs text-amber-600">No sections granted — users with this role can't access anything.</p>
            }
        </div>
    }
</div>
