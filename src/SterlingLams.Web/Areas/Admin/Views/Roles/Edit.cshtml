@model SterlingLams.Web.Areas.Admin.ViewModels.AdminRoleEditViewModel
@{
    ViewData["Title"] = Model.IsNew ? "New Role" : "Edit Role";
}

<div class="flex items-center gap-3 mb-6">
    <a asp-area="Admin" asp-controller="Roles" asp-action="Index"
       class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">← Roles</a>
    <span class="text-neutral-200">/</span>
    <span class="text-xs text-neutral-600">@(Model.IsNew ? "New Role" : Model.Name)</span>
</div>

<div class="max-w-2xl">
    <form asp-area="Admin" asp-controller="Roles" asp-action="Save" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IsNew" />
        <input type="hidden" asp-for="OriginalName" />

        <!-- Role name -->
        <div class="bg-white rounded-sm border border-neutral-100 p-6">
            <label asp-for="Name" class="block text-xs text-neutral-500 mb-1">Role Name <span class="text-red-400">*</span></label>
            <input asp-for="Name" required placeholder="e.g. Operations"
                   class="w-full max-w-sm border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
        </div>

        <!-- Section permissions -->
        <div class="bg-white rounded-sm border border-neutral-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <h2 class="text-sm font-medium text-neutral-800">Section Access</h2>
                    <p class="text-xs text-neutral-400 mt-0.5">Tick the admin sections this role can access.</p>
                </div>
                <div class="flex gap-3">
                    <button type="button" onclick="toggleAllSections(true)"
                            class="text-[11px] text-neutral-500 hover:text-neutral-900 underline underline-offset-2">Select all</button>
                    <button type="button" onclick="toggleAllSections(false)"
                            class="text-[11px] text-neutral-500 hover:text-neutral-900 underline underline-offset-2">Clear</button>
                </div>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
                @foreach (var sec in SterlingLams.Web.Areas.Admin.AdminSections.All)
                {
                    var isChecked = Model.SelectedSections.Contains(sec.Key);
                    <label class="flex items-center gap-2.5 px-3 py-2.5 border border-neutral-200 rounded-sm hover:bg-neutral-50 cursor-pointer">
                        <input type="checkbox" name="sections" value="@sec.Key"
                               @(isChecked ? "checked" : "")
                               class="section-cb rounded border-neutral-300 accent-neutral-900 flex-shrink-0" />
                        <svg class="w-4 h-4 text-neutral-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="@sec.Icon"/>
                        </svg>
                        <span class="text-sm text-neutral-700">@sec.Label</span>
                    </label>
                }
            </div>

            <p class="text-[11px] text-neutral-400 mt-4">
                Note: <strong>Roles &amp; Permissions</strong> management is always restricted to full Administrators
                and cannot be granted to other roles.
            </p>
        </div>

        <div class="flex gap-3">
            <button type="submit"
                    class="px-6 py-2.5 bg-neutral-900 text-white text-sm rounded-sm hover:bg-neutral-700 transition-colors">
                @(Model.IsNew ? "Create Role" : "Save Changes")
            </button>
            <a asp-area="Admin" asp-controller="Roles" asp-action="Index"
               class="px-6 py-2.5 border border-neutral-200 text-neutral-600 text-sm rounded-sm hover:bg-neutral-50 transition-colors">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
<script>
function toggleAllSections(check) {
    document.querySelectorAll('.section-cb').forEach(cb => cb.checked = check);
}
</script>
}
