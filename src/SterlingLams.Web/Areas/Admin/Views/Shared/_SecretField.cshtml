@model (string Name, string Label, string Placeholder, bool IsSet)
@{
    var ph = Model.IsSet ? "•••••••••••• saved — leave blank to keep" : Model.Placeholder;
}
<div>
    <div class="flex items-center gap-2 mb-1">
        <label class="block text-xs font-medium text-neutral-700">@Model.Label</label>
        @if (Model.IsSet)
        {
            <span class="text-[10px] uppercase tracking-wide bg-emerald-50 text-emerald-600 px-1.5 py-0.5 rounded">Saved</span>
        }
        else
        {
            <span class="text-[10px] uppercase tracking-wide bg-neutral-100 text-neutral-400 px-1.5 py-0.5 rounded">Not set</span>
        }
    </div>
    <input type="password" name="@Model.Name" value="" placeholder="@ph" autocomplete="new-password"
           class="w-full border border-neutral-200 px-3 py-2 text-sm rounded-sm font-mono focus:outline-none focus:border-brand-500" />
</div>
