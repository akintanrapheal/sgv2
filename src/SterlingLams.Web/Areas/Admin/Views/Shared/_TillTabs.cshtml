@model string
@{
    // Active-tab key: "Sessions" | "Tills" | "DiscountReasons" | "Sales"
    string Cls(string tab) => tab == Model
        ? "border-neutral-900 text-neutral-900"
        : "border-transparent text-neutral-400 hover:text-neutral-700";
}
<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-lg font-medium text-neutral-800">Till</h1>
        <p class="text-xs text-neutral-400">Manage tills, sessions, discounts and POS sales. Cashiers ring up sales in the till app.</p>
    </div>
    <a href="/till" target="_blank" rel="noopener"
       class="px-4 py-2 bg-brand-500 text-white text-sm rounded-sm hover:bg-brand-600 transition-colors">
        Open Till App →
    </a>
</div>
<div class="flex gap-1 border-b border-neutral-200 mb-6">
    <a asp-area="Admin" asp-controller="Pos" asp-action="Sessions"        class="px-4 py-2.5 text-xs font-medium border-b-2 transition-colors @Cls("Sessions")">Sessions</a>
    <a asp-area="Admin" asp-controller="Registers" asp-action="Index"     class="px-4 py-2.5 text-xs font-medium border-b-2 transition-colors @Cls("Tills")">Tills</a>
    <a asp-area="Admin" asp-controller="Pos" asp-action="DiscountReasons" class="px-4 py-2.5 text-xs font-medium border-b-2 transition-colors @Cls("DiscountReasons")">Discount Reasons</a>
    <a asp-area="Admin" asp-controller="Pos" asp-action="Sales"           class="px-4 py-2.5 text-xs font-medium border-b-2 transition-colors @Cls("Sales")">Sales</a>
</div>
