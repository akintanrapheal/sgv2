<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin — @ViewData["Title"] — Sterlin Glams</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="~/favicon-16.png" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png" />
    <partial name="_AccentStyle" />
</head>
<body class="bg-neutral-50 text-neutral-900 font-inter antialiased">
    @* Secret-URL-aware base for this area so inline fetch()/link JS resolves to the configured prefix. *@
    <script>window.__adminBase = '/@SterlingLams.Web.Infrastructure.StaffPaths.Admin';</script>

<div class="flex h-screen overflow-hidden">

    <!-- Mobile drawer backdrop -->
    <div id="sb-backdrop" class="hidden fixed inset-0 bg-black/50 z-40 md:hidden"></div>

    <!-- ─── Sidebar (slide-in drawer on mobile) ──────────────────────────── -->
    <aside id="sb" class="w-64 bg-neutral-900 text-white flex flex-col flex-shrink-0 overflow-y-auto
                          fixed inset-y-0 left-0 z-50 -translate-x-full transition-transform duration-200
                          md:static md:translate-x-0">

        <!-- Logo -->
        <div class="px-6 py-6 border-b border-neutral-800">
            <span class="font-cormorant text-xl font-light tracking-[0.2em] uppercase">Sterlin Glams</span>
            <p class="text-[10px] text-neutral-500 tracking-widest uppercase mt-0.5">Admin Console</p>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-3 py-3 space-y-0.5 overflow-y-auto">
            @{
                var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                var allowedSections = ViewData["AllowedSections"] as HashSet<string> ?? new HashSet<string>();
                var isFullAdmin = ViewData["IsFullAdmin"] as bool? ?? false;

                // Owner-only entries (Roles, Integrations, SEO) show to full admins; everything else
                // shows if the role has been granted that section.
                bool Visible(SterlingLams.Web.Areas.Admin.AdminSection s)
                {
                    // Subscribe (billing) is Admin + Developer only — hidden from Owner.
                    if (s.Key == "Subscribe") return SterlingLams.Web.Areas.Admin.AdminSections.IsSystemManager(User);
                    return s.OwnerOnly ? isFullAdmin : allowedSections.Contains(s.Key);
                }
            }

            @foreach (var group in SterlingLams.Web.Areas.Admin.AdminSections.GroupOrder)
            {
                var items = SterlingLams.Web.Areas.Admin.AdminSections.Nav
                    .Where(s => s.Group == group && Visible(s)).ToList();
                if (items.Count == 0) { continue; }

                if (string.IsNullOrEmpty(group))
                {
                    @* Overview — top of the menu, no heading *@
                    foreach (var item in items)
                    {
                        var isActive = currentController == item.Controller;
                        <a asp-area="Admin" asp-controller="@item.Controller" asp-action="Index"
                           class="flex items-center gap-3 px-3 py-2.5 rounded-sm text-sm transition-colors @(isActive ? "bg-neutral-800 text-white" : "text-neutral-400 hover:text-white hover:bg-neutral-800")">
                            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="@item.Icon"/>
                            </svg>
                            @item.Label
                        </a>
                    }
                }
                else
                {
                    // Only expand the group that holds the current page — the rest stay collapsed.
                    var groupOpen = items.Any(i => currentController == i.Controller);
                    <details class="group/nav" open="@groupOpen">
                        <summary class="cursor-pointer list-none flex items-center justify-between px-3 pt-3 pb-1 text-[10px] tracking-widest uppercase text-neutral-500 hover:text-neutral-300">
                            <span>@group</span>
                            <svg class="w-3 h-3 transition-transform group-open/nav:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="space-y-0.5 mb-1">
                            @foreach (var item in items)
                            {
                                var isActive = currentController == item.Controller;
                                <a asp-area="Admin" asp-controller="@item.Controller" asp-action="Index"
                                   class="flex items-center gap-3 px-3 py-2 rounded-sm text-sm transition-colors @(isActive ? "bg-neutral-800 text-white" : "text-neutral-400 hover:text-white hover:bg-neutral-800")">
                                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="@item.Icon"/>
                                    </svg>
                                    <span class="flex-1">@item.Label</span>
                                </a>
                            }
                        </div>
                    </details>
                }
            }
        </nav>

        <!-- Bottom: storefront link + logout -->
        <div class="px-3 py-4 border-t border-neutral-800 space-y-1">
            <a asp-controller="Home" asp-action="Index" asp-area=""
               class="flex items-center gap-3 px-3 py-2.5 text-xs text-neutral-500 hover:text-white transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
                View Storefront
            </a>
            <form asp-controller="Account" asp-action="Logout" asp-area="" method="post">
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="flex items-center gap-3 px-3 py-2.5 w-full text-xs text-neutral-500 hover:text-white transition-colors text-left">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                    </svg>
                    Sign Out
                </button>
            </form>
        </div>
    </aside>

    <!-- ─── Main ─────────────────────────────────────────────────────────── -->
    <div class="flex-1 flex flex-col overflow-hidden">

        <!-- Top bar -->
        <header class="bg-white border-b border-neutral-100 px-4 md:px-8 py-4 flex items-center justify-between gap-4 flex-shrink-0">
            <div class="flex items-center gap-3 flex-shrink-0 min-w-0">
                <button id="sb-toggle" type="button" class="md:hidden text-neutral-700 hover:text-neutral-900 -ml-1" aria-label="Menu">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </button>
                <h1 class="text-sm font-medium text-neutral-800 truncate">@ViewData["Title"]</h1>
            </div>
            <form method="get" asp-area="Admin" asp-controller="Search" asp-action="Index" class="relative flex-1 max-w-md hidden sm:block">
                <svg class="w-4 h-4 text-neutral-400 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <input type="search" name="q" value="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Search" ? Context.Request.Query["q"].ToString() : "")"
                       placeholder="Search orders, customers, products…"
                       class="w-full pl-9 pr-3 py-2 text-sm bg-neutral-50 border border-neutral-200 rounded-sm focus:outline-none focus:border-neutral-400 focus:bg-white transition-colors" />
            </form>
            <div class="flex items-center gap-3 flex-shrink-0">
                @if (TempData["Success"] != null)
                {
                    <span class="text-xs text-emerald-700 bg-emerald-50 px-3 py-1.5 rounded-full">✓ @TempData["Success"]</span>
                }
                @if (TempData["Error"] != null)
                {
                    <span class="text-xs text-red-700 bg-red-50 px-3 py-1.5 rounded-full">@TempData["Error"]</span>
                }
                @* New-order sound toggle (per-device; remembered in this browser). *@
                <button id="order-alert-bell" type="button" title="New-order sound"
                        class="relative text-neutral-400 hover:text-neutral-700 transition-colors" aria-label="Toggle new-order sound">
                    <svg id="order-alert-icon-on" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                    <svg id="order-alert-icon-off" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.73 21a2 2 0 01-3.46 0M18.63 13A17.9 17.9 0 0118 8m-6-4a6 6 0 00-3.84 1.4M3 3l18 18"/></svg>
                    <span id="order-alert-badge" class="hidden absolute -top-1.5 -right-1.5 min-w-[16px] h-[16px] px-1 rounded-full bg-brand-500 text-white text-[10px] leading-4 text-center font-semibold"></span>
                </button>
                <partial name="_UserChip" />
            </div>
        </header>

        <!-- Page content -->
        <main class="flex-1 overflow-y-auto overflow-x-auto p-4 md:p-8">
            <partial name="_TrialNoticeBanner" />
            @RenderBody()
            <partial name="_DevCredit" />
        </main>
    </div>
</div>

<script src="~/js/app.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
<script>
// Mobile sidebar drawer. Toggle via inline transform styles (not a purgeable class).
(function () {
    var sb = document.getElementById('sb'), bd = document.getElementById('sb-backdrop'), t = document.getElementById('sb-toggle');
    if (!sb || !t) return;
    var open = false;
    function set(v) { open = v; sb.style.transform = v ? 'translateX(0)' : ''; bd.classList.toggle('hidden', !v); }
    t.addEventListener('click', function () { set(!open); });
    bd.addEventListener('click', function () { set(false); });
    sb.addEventListener('click', function (e) { if (e.target.closest('a')) set(false); });
    // Reset when crossing to desktop so the inline transform never lingers.
    window.matchMedia('(min-width: 768px)').addEventListener('change', function (e) { if (e.matches) set(false); });
})();

// Global: disable submit buttons on form submit to prevent double-submissions
document.addEventListener('submit', function (e) {
    const form = e.target;
    form.querySelectorAll('button[type="submit"]').forEach(btn => {
        if (btn.dataset.noLoading) return;
        const original = btn.textContent.trim();
        btn.disabled = true;
        btn.textContent = 'Saving…';
        // Re-enable after 8s as safety net
        setTimeout(() => { btn.disabled = false; btn.textContent = original; }, 8000);
    });
});

// ── New-order notification: sound + toast, polled every ~25s. Per-device toggle (localStorage). ──
(function () {
    var bell = document.getElementById('order-alert-bell');
    if (!bell) return;
    var iconOn = document.getElementById('order-alert-icon-on');
    var iconOff = document.getElementById('order-alert-icon-off');
    var badgeEl = document.getElementById('order-alert-badge');

    var NEW_URL = '@Url.Action("NewOrders", "Orders", new { area = "Admin" })';
    var DETAIL_TPL = '@Url.Action("Detail", "Orders", new { area = "Admin", id = "__ID__" })';
    var onOrdersList = @(((ViewContext.RouteData.Values["controller"]?.ToString() == "Orders") && (ViewContext.RouteData.Values["action"]?.ToString() == "Index")).ToString().ToLowerInvariant());
    var K_SOUND = 'sg_neworder_sound', K_CURSOR = 'sg_neworder_cursor', K_UNSEEN = 'sg_neworder_unseen';

    var audioCtx = null;
    function soundOn() { return localStorage.getItem(K_SOUND) !== 'off'; }
    function esc(s) { return String(s == null ? '' : s).replace(/[&<>"]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]; }); }

    function renderBell() {
        var on = soundOn();
        iconOn.classList.toggle('hidden', !on);
        iconOff.classList.toggle('hidden', on);
        bell.title = on ? 'New-order sound: ON (click to mute)' : 'New-order sound: OFF (click to enable)';
    }
    function renderBadge() {
        var n = parseInt(localStorage.getItem(K_UNSEEN) || '0', 10);
        if (n > 0) { badgeEl.textContent = n > 99 ? '99+' : n; badgeEl.classList.remove('hidden'); }
        else badgeEl.classList.add('hidden');
    }

    // Web Audio chime — no asset. Needs a prior user gesture (browser autoplay policy); we unlock below.
    function unlock() {
        try { var C = window.AudioContext || window.webkitAudioContext; if (C) { audioCtx = audioCtx || new C(); if (audioCtx.state === 'suspended') audioCtx.resume(); } } catch (e) {}
        document.removeEventListener('click', unlock); document.removeEventListener('keydown', unlock);
    }
    document.addEventListener('click', unlock); document.addEventListener('keydown', unlock);
    function chime() {
        try {
            var C = window.AudioContext || window.webkitAudioContext; if (!C) return;
            audioCtx = audioCtx || new C(); if (audioCtx.state === 'suspended') audioCtx.resume();
            var now = audioCtx.currentTime;
            [[880, 0], [1174.66, 0.12]].forEach(function (p) {
                var o = audioCtx.createOscillator(), g = audioCtx.createGain();
                o.type = 'sine'; o.frequency.value = p[0]; o.connect(g); g.connect(audioCtx.destination);
                var t = now + p[1];
                g.gain.setValueAtTime(0.0001, t);
                g.gain.exponentialRampToValueAtTime(0.25, t + 0.02);
                g.gain.exponentialRampToValueAtTime(0.0001, t + 0.38);
                o.start(t); o.stop(t + 0.4);
            });
        } catch (e) {}
    }

    var toastWrap;
    function toast(order) {
        if (!toastWrap) {
            toastWrap = document.createElement('div');
            toastWrap.style.cssText = 'position:fixed;top:16px;right:16px;z-index:9999;display:flex;flex-direction:column;gap:8px;max-width:340px;';
            document.body.appendChild(toastWrap);
        }
        var a = document.createElement('a');
        a.href = DETAIL_TPL.replace('__ID__', order.id);
        a.style.cssText = 'display:block;background:#111827;color:#fff;text-decoration:none;padding:12px 14px;border-radius:8px;box-shadow:0 6px 18px rgba(0,0,0,.28);font:500 13px/1.4 ui-sans-serif,system-ui,sans-serif;';
        a.innerHTML = '<div style="font-weight:600;margin-bottom:2px;">🛎️ New order ' + esc(order.number) + '</div>'
            + '<div style="color:#d1d5db;font-size:12px;">₦' + Number(order.total).toLocaleString() + (order.customer ? ' · ' + esc(order.customer) : '') + '</div>';
        toastWrap.appendChild(a);
        setTimeout(function () { a.style.transition = 'opacity .4s'; a.style.opacity = '0'; setTimeout(function () { a.remove(); }, 400); }, 9000);
    }

    // Seeing the Orders list clears the "new" badge.
    if (onOrdersList) { localStorage.setItem(K_UNSEEN, '0'); }
    renderBell(); renderBadge();

    bell.addEventListener('click', function () {
        localStorage.setItem(K_SOUND, soundOn() ? 'off' : 'on');
        renderBell();
        unlock();               // clicking the bell also satisfies the autoplay gesture
        if (soundOn()) chime();  // preview the sound when enabling
    });

    var stopped = false;
    function poll() {
        if (stopped) return;
        var cur = localStorage.getItem(K_CURSOR);
        var since = cur === null ? 0 : cur;
        fetch(NEW_URL + '?sinceTicks=' + encodeURIComponent(since), { headers: { 'X-Requested-With': 'fetch' } })
            .then(function (r) { if (r.status === 401 || r.status === 403) { stopped = true; return null; } return r.ok ? r.json() : null; })
            .then(function (d) {
                if (!d) return;
                // cur === null → first load in this browser: set the baseline, never ding for old orders.
                if (cur !== null && d.orders && d.orders.length) {
                    if (soundOn()) chime();
                    d.orders.slice().reverse().forEach(toast);
                    var n = parseInt(localStorage.getItem(K_UNSEEN) || '0', 10) + d.orders.length;
                    localStorage.setItem(K_UNSEEN, String(n));
                    renderBadge();
                }
                localStorage.setItem(K_CURSOR, String(d.latestTicks));
            })
            .catch(function () {});
    }
    setTimeout(poll, 4000);          // first check shortly after load
    setInterval(poll, 25000);        // then every 25s
})();
</script>
</body>
</html>
