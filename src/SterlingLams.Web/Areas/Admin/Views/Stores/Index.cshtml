@model IEnumerable<SterlingLams.Web.Models.Domain.Store>
@{
    ViewData["Title"] = "Stores";
}

<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    @foreach (var store in Model)
    {
        <div class="bg-white rounded-sm border border-neutral-100 p-6 space-y-3">
            <div class="flex items-start justify-between">
                <div>
                    <h2 class="text-sm font-medium">@store.Name</h2>
                    <p class="text-xs text-neutral-400">@store.City, @store.State</p>
                </div>
                @if (store.IsActive)
                {
                    <span class="text-[10px] bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Active</span>
                }
                else
                {
                    <span class="text-[10px] bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full">Inactive</span>
                }
            </div>

            <div class="text-xs text-neutral-500 space-y-1">
                <p>📍 @store.Address</p>
                @if (store.Phone != null)
                {
                    <p>📞 @store.Phone</p>
                }
                @if (store.OpeningHours != null)
                {
                    <p>🕐 @store.OpeningHours</p>
                }
                <p class="font-mono text-neutral-400">Warehouse: @store.ErpNextWarehouse</p>
            </div>

            <a asp-area="Admin" asp-controller="Stores" asp-action="Edit" asp-route-id="@store.Id"
               class="inline-block mt-2 px-4 py-1.5 border border-neutral-200 text-xs text-neutral-600 rounded-sm hover:bg-neutral-50 transition-colors">
                Edit Store
            </a>
        </div>
    }
</div>
