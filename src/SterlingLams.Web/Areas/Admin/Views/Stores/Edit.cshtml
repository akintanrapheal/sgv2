@model SterlingLams.Web.Areas.Admin.ViewModels.AdminStoreEditViewModel
@{
    ViewData["Title"] = "Edit Store";
}

<div class="flex items-center gap-3 mb-6">
    <a asp-area="Admin" asp-controller="Stores" asp-action="Index"
       class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">← Stores</a>
    <span class="text-neutral-200">/</span>
    <span class="text-xs text-neutral-600">@Model.Name</span>
</div>

<div class="max-w-lg">
    <form asp-area="Admin" asp-controller="Stores" asp-action="Edit" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="bg-white rounded-sm border border-neutral-100 p-6 space-y-4">

            <div>
                <label asp-for="Name" class="block text-xs text-neutral-500 mb-1">Store Name</label>
                <input asp-for="Name" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>

            <div>
                <label asp-for="Address" class="block text-xs text-neutral-500 mb-1">Street Address</label>
                <input asp-for="Address" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="City" class="block text-xs text-neutral-500 mb-1">City</label>
                    <input asp-for="City" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
                <div>
                    <label asp-for="State" class="block text-xs text-neutral-500 mb-1">State</label>
                    <input asp-for="State" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Phone" class="block text-xs text-neutral-500 mb-1">Phone</label>
                    <input asp-for="Phone" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
                <div>
                    <label asp-for="Email" class="block text-xs text-neutral-500 mb-1">Email</label>
                    <input asp-for="Email" type="email" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
            </div>

            <div>
                <label asp-for="OpeningHours" class="block text-xs text-neutral-500 mb-1">Opening Hours</label>
                <input asp-for="OpeningHours" placeholder="e.g. Mon–Sat 9am–7pm"
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>

            <div>
                <label asp-for="OdooWarehouseId" class="block text-xs text-neutral-500 mb-1">Odoo Warehouse ID</label>
                <input asp-for="OdooWarehouseId" type="number"
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm font-mono focus:outline-none focus:border-neutral-400" />
            </div>

            <label class="flex items-center gap-2 text-sm text-neutral-600 cursor-pointer">
                <input asp-for="IsActive" type="checkbox" class="rounded" />
                Store is active
            </label>
        </div>

        <div class="flex gap-3">
            <button type="submit"
                    class="px-6 py-2.5 bg-neutral-900 text-white text-sm rounded-sm hover:bg-neutral-700 transition-colors">
                Save Changes
            </button>
            <a asp-area="Admin" asp-controller="Stores" asp-action="Index"
               class="px-6 py-2.5 border border-neutral-200 text-neutral-600 text-sm rounded-sm hover:bg-neutral-50 transition-colors">
                Cancel
            </a>
        </div>
    </form>
</div>
