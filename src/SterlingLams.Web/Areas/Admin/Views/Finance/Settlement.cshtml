@model SterlingLams.Web.Areas.Admin.Controllers.FinanceController.SettlementVm
@{
    ViewData["Title"] = "Finance — Settlement";
    string Money(decimal v) => "₦" + v.ToString("N0");
}

<partial name="_FinanceTabs" model="@("Settlement")" />

<div class="flex items-center justify-between mb-5">
    <p class="text-xs text-neutral-400">Online (Paystack) takings vs estimated gateway fees, so you can reconcile what actually settles to the bank. Fees are estimated at Paystack's standard 1.5% + ₦100 (capped ₦2,000).</p>
</div>

<form method="get" class="flex flex-wrap items-end gap-3 mb-6">
    <div>
        <label class="block text-xs text-neutral-500 mb-1">From</label>
        <input type="date" name="from" value="@Model.From.ToString("yyyy-MM-dd")" class="border border-neutral-200 rounded-sm px-3 py-1.5 text-sm" />
    </div>
    <div>
        <label class="block text-xs text-neutral-500 mb-1">To</label>
        <input type="date" name="to" value="@Model.To.ToString("yyyy-MM-dd")" class="border border-neutral-200 rounded-sm px-3 py-1.5 text-sm" />
    </div>
    <button class="px-4 py-1.5 bg-neutral-900 text-white text-sm rounded-sm hover:bg-neutral-700 transition-colors">Apply</button>
</form>

<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white border border-neutral-100 rounded-sm p-4">
        <p class="text-xs text-neutral-400">Online takings</p><p class="text-xl font-light text-neutral-900 mt-1">@Money(Model.Gross)</p>
        <p class="mt-1 text-[11px] text-neutral-400">@Model.Count transaction(s)</p>
    </div>
    <div class="bg-white border border-neutral-100 rounded-sm p-4">
        <p class="text-xs text-neutral-400">Est. gateway fees</p><p class="text-xl font-light text-red-600 mt-1">@Money(Model.EstFees)</p>
    </div>
    <div class="bg-white border border-neutral-100 rounded-sm p-4">
        <p class="text-xs text-neutral-400">Est. net settled</p><p class="text-xl font-light text-neutral-900 mt-1">@Money(Model.NetSettled)</p>
    </div>
    <div class="bg-white border border-neutral-100 rounded-sm p-4">
        <p class="text-xs text-neutral-400">Effective fee rate</p><p class="text-xl font-light text-neutral-900 mt-1">@((Model.Gross > 0 ? Model.EstFees / Model.Gross : 0).ToString("P2"))</p>
    </div>
</div>

<div class="bg-white border border-neutral-100 rounded-sm overflow-hidden">
    <div class="px-4 py-2.5 bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">Daily settlement (estimated)</div>
    <table class="w-full text-sm">
        <thead><tr class="text-xs text-neutral-400">
            <th class="px-4 py-2 text-left font-medium">Date</th>
            <th class="px-4 py-2 text-right font-medium">Txns</th>
            <th class="px-4 py-2 text-right font-medium">Takings</th>
            <th class="px-4 py-2 text-right font-medium">Est. fee</th>
            <th class="px-4 py-2 text-right font-medium">Est. net</th>
        </tr></thead>
        <tbody class="divide-y divide-neutral-100">
            @if (!Model.ByDay.Any()) { <tr><td colspan="5" class="px-4 py-8 text-center text-neutral-400">No online payments in range.</td></tr> }
            @foreach (var d in Model.ByDay)
            {
                <tr class="hover:bg-neutral-50">
                    <td class="px-4 py-2.5 text-neutral-700">@d.Day.ToString("ddd, dd MMM yyyy")</td>
                    <td class="px-4 py-2.5 text-right text-neutral-500">@d.Count</td>
                    <td class="px-4 py-2.5 text-right text-neutral-800">@Money(d.Gross)</td>
                    <td class="px-4 py-2.5 text-right text-red-600">@Money(d.Fee)</td>
                    <td class="px-4 py-2.5 text-right text-neutral-800">@Money(d.Net)</td>
                </tr>
            }
        </tbody>
    </table>
</div>
