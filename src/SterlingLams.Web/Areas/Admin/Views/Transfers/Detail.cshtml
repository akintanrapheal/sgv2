@model SterlingLams.Web.Models.Domain.StockTransfer
@{ ViewData["Title"] = Model.TransferNumber; }

<div class="flex items-center gap-3 mb-6">
    <a asp-area="Admin" asp-controller="Transfers" asp-action="Index" class="text-xs text-neutral-400 hover:text-neutral-700">← Transfers</a>
    <span class="text-neutral-200">/</span>
    <h1 class="text-lg font-medium text-neutral-800 font-mono">@Model.TransferNumber</h1>
</div>

<div class="max-w-2xl">
    <div class="bg-white border border-neutral-100 rounded-sm p-5 mb-4">
        <div class="flex items-center justify-center gap-4 mb-2">
            <div class="text-center"><p class="text-xs text-neutral-400">From</p><p class="text-sm font-medium text-neutral-800">@Model.FromStore?.Name</p></div>
            <svg class="w-6 h-6 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            <div class="text-center"><p class="text-xs text-neutral-400">To</p><p class="text-sm font-medium text-neutral-800">@Model.ToStore?.Name</p></div>
        </div>
        <p class="text-center text-xs text-neutral-400">@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</p>
        @if (!string.IsNullOrEmpty(Model.Note)) { <p class="text-center text-sm text-neutral-500 mt-2">@Model.Note</p> }
    </div>

    <div class="bg-white border border-neutral-100 rounded-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-neutral-50 text-neutral-500 text-xs uppercase tracking-wide">
                <tr><th class="text-left font-medium px-4 py-3">Product</th><th class="text-right font-medium px-4 py-3">Quantity moved</th></tr>
            </thead>
            <tbody class="divide-y divide-neutral-100">
                @foreach (var i in Model.Items)
                {
                    <tr><td class="px-4 py-3 text-neutral-800">@i.ProductName</td><td class="px-4 py-3 text-right text-neutral-700">@i.Quantity</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
