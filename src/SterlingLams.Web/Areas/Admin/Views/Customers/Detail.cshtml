@model SterlingLams.Web.Areas.Admin.ViewModels.AdminCustomerDetailViewModel
@{
    ViewData["Title"] = "Customer — " + Model.FullName;
}

<div class="mb-6">
    <a asp-area="Admin" asp-controller="Customers" asp-action="Index"
       class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">← Back to Customers</a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Stats -->
    <div class="space-y-4">
        <div class="bg-white rounded-sm border border-neutral-100 px-6 py-5">
            <h2 class="text-sm font-medium mb-4">Customer Info</h2>
            <div class="space-y-2">
                <p class="text-xs font-medium text-neutral-800">@Model.FullName</p>
                <p class="text-xs text-neutral-500">@Model.Email</p>
                @if (!string.IsNullOrWhiteSpace(Model.Phone))
                {
                    <p class="text-xs text-neutral-500">@Model.Phone</p>
                }
                <p class="text-xs text-neutral-400 pt-2">Joined @Model.JoinedAt.ToString("dd MMMM yyyy")</p>
            </div>
        </div>

        <div class="bg-white rounded-sm border border-neutral-100 px-6 py-5">
            <h2 class="text-sm font-medium mb-4">Summary</h2>
            <div class="space-y-3">
                <div class="flex justify-between">
                    <span class="text-xs text-neutral-400">Total Orders</span>
                    <span class="text-xs font-medium">@Model.OrderCount</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-xs text-neutral-400">Total Spend (paid)</span>
                    <span class="text-xs font-medium text-emerald-700">₦@Model.TotalSpend.ToString("N0")</span>
                </div>
                @if (Model.OrderCount > 0)
                {
                    <div class="flex justify-between">
                        <span class="text-xs text-neutral-400">Avg. Order Value</span>
                        <span class="text-xs font-medium">₦@((Model.TotalSpend / Model.OrderCount).ToString("N0"))</span>
                    </div>
                }
            </div>
        </div>

        <!-- Tags -->
        <div class="bg-white rounded-sm border border-neutral-100 px-6 py-5">
            <h2 class="text-sm font-medium mb-3">Tags</h2>
            <form asp-area="Admin" asp-controller="Customers" asp-action="SaveTags" asp-route-id="@Model.Id" method="post" class="flex gap-2">
                <input type="text" name="tags" value="@Model.Tags" placeholder="e.g. vip, wholesale"
                       class="flex-1 border border-neutral-200 rounded-sm px-3 py-2 text-xs focus:outline-none focus:border-neutral-400" />
                <button type="submit" class="px-3 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">Save</button>
            </form>
            <p class="text-[10px] text-neutral-400 mt-2">Comma-separated. Used for filtering on the customer list.</p>
        </div>

        <!-- Loyalty -->
        <div class="bg-white rounded-sm border border-neutral-100 px-6 py-5">
            <div class="flex items-center justify-between mb-3">
                <h2 class="text-sm font-medium">Loyalty points</h2>
                <span class="text-lg font-light text-emerald-700">@Model.LoyaltyBalance</span>
            </div>
            <form asp-area="Admin" asp-controller="Customers" asp-action="AdjustLoyalty" asp-route-id="@Model.Id" method="post" class="space-y-2 mb-3">
                <div class="flex gap-2">
                    <input type="number" name="points" placeholder="± points" step="1"
                           class="w-24 border border-neutral-200 rounded-sm px-2 py-2 text-xs focus:outline-none focus:border-neutral-400" />
                    <input type="text" name="reason" placeholder="Reason (e.g. goodwill)"
                           class="flex-1 border border-neutral-200 rounded-sm px-2 py-2 text-xs focus:outline-none focus:border-neutral-400" />
                    <button type="submit" class="px-3 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">Apply</button>
                </div>
                <p class="text-[10px] text-neutral-400">Use a negative number to deduct. Balance never goes below zero.</p>
            </form>
            @if (Model.LoyaltyEntries.Any())
            {
                <div class="border-t border-neutral-100 pt-2 space-y-1.5 max-h-48 overflow-y-auto">
                    @foreach (var e in Model.LoyaltyEntries)
                    {
                        <div class="flex justify-between items-baseline text-[11px]">
                            <span class="text-neutral-500 truncate pr-2">@e.Reason<span class="text-neutral-300"> · @e.CreatedAt.ToLocalTime().ToString("dd MMM")</span></span>
                            <span class="font-medium @(e.Points >= 0 ? "text-emerald-600" : "text-red-500")">@(e.Points >= 0 ? "+" : "")@e.Points</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-[11px] text-neutral-400 border-t border-neutral-100 pt-2">No points activity yet.</p>
            }
        </div>
    </div>

    <!-- Orders -->
    <div class="lg:col-span-2">
        <div class="bg-white rounded-sm border border-neutral-100">
            <div class="px-6 py-4 border-b border-neutral-100">
                <h2 class="text-sm font-medium">Recent Orders</h2>
            </div>
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-neutral-50 border-b border-neutral-100">
                        <th class="text-left px-6 py-2 text-xs text-neutral-400 font-medium">Order #</th>
                        <th class="text-left px-6 py-2 text-xs text-neutral-400 font-medium">Status</th>
                        <th class="text-right px-6 py-2 text-xs text-neutral-400 font-medium">Total</th>
                        <th class="text-left px-6 py-2 text-xs text-neutral-400 font-medium">Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-neutral-50">
                    @if (!Model.RecentOrders.Any())
                    {
                        <tr><td colspan="4" class="px-6 py-8 text-center text-xs text-neutral-400">No orders yet</td></tr>
                    }
                    @foreach (var o in Model.RecentOrders)
                    {
                        <tr class="hover:bg-neutral-50">
                            <td class="px-6 py-3 text-xs font-mono text-neutral-700">@o.OrderNumber</td>
                            <td class="px-6 py-3">
                                @{
                                    var bc = o.Status switch
                                    {
                                        "Delivered" or "Collected" => "bg-emerald-50 text-emerald-700",
                                        "Cancelled" => "bg-red-50 text-red-700",
                                        "Processing" or "Confirmed" => "bg-blue-50 text-blue-700",
                                        _ => "bg-neutral-100 text-neutral-600"
                                    };
                                }
                                <span class="text-[10px] px-2 py-0.5 rounded-full @bc">@o.Status</span>
                            </td>
                            <td class="px-6 py-3 text-xs text-right font-medium">₦@o.Total.ToString("N0")</td>
                            <td class="px-6 py-3 text-xs text-neutral-400">@o.CreatedAt.ToString("dd MMM yy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
