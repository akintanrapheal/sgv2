@model List<SterlingLams.Web.Models.Domain.GiftCard>
@{
    ViewData["Title"] = "Gift Cards";
    Layout = "_AdminLayout";
    string status = ViewBag.Status ?? "all";
    string? q = ViewBag.Q;
    int page = ViewBag.Page ?? 1; int totalPages = ViewBag.TotalPages ?? 1; int total = ViewBag.Total ?? 0;
    decimal outstanding = ViewBag.OutstandingBalance ?? 0m;
    decimal issued = ViewBag.TotalIssued ?? 0m;
    int activeCount = ViewBag.ActiveCount ?? 0;
    string TabCls(string f) => f == status ? "border-neutral-900 text-neutral-900" : "border-transparent text-neutral-400 hover:text-neutral-700";
    var now = DateTime.UtcNow;
}
@Html.AntiForgeryToken()

<div class="mb-6 flex items-start justify-between gap-4 flex-wrap">
    <div>
        <h1 class="text-2xl font-light text-neutral-900">Gift Cards</h1>
        <p class="text-sm text-neutral-500 mt-1">Issue prepaid gift cards customers can redeem at checkout.</p>
    </div>
    <button type="button" onclick="document.getElementById('issue-panel').classList.toggle('hidden')"
            class="px-4 py-2 text-sm bg-neutral-900 text-white rounded-sm hover:bg-neutral-700">+ Issue gift card</button>
</div>

@if (TempData["Message"] != null)
{
    <div class="mb-4 bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm px-4 py-3 rounded-sm">@TempData["Message"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="mb-4 bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-sm">@TempData["Error"]</div>
}

<div id="issue-panel" class="hidden bg-white border border-neutral-200 rounded-sm p-5 mb-6">
    <form asp-area="Admin" asp-controller="GiftCards" asp-action="Issue" method="post" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        @Html.AntiForgeryToken()
        <div>
            <label class="block text-xs text-neutral-500 mb-1">Amount (₦) *</label>
            <input name="amount" type="number" step="0.01" min="1" required class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" placeholder="e.g. 10000" />
        </div>
        <div>
            <label class="block text-xs text-neutral-500 mb-1">Recipient name</label>
            <input name="recipientName" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" placeholder="Optional" />
        </div>
        <div>
            <label class="block text-xs text-neutral-500 mb-1">Recipient email</label>
            <input name="recipientEmail" type="email" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" placeholder="Optional" />
        </div>
        <div>
            <label class="block text-xs text-neutral-500 mb-1">Expires</label>
            <input name="expiresAt" type="date" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" />
            <p class="text-[11px] text-neutral-400 mt-1">Leave blank for no expiry.</p>
        </div>
        <div class="lg:col-span-2">
            <label class="block text-xs text-neutral-500 mb-1">Note</label>
            <input name="note" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" placeholder="Occasion, source, etc. (optional)" />
        </div>
        <div class="sm:col-span-2 lg:col-span-3">
            <button type="submit" class="px-5 py-2 text-sm bg-emerald-600 text-white rounded-sm hover:bg-emerald-700">Issue card</button>
        </div>
    </form>
</div>

<div class="grid grid-cols-3 gap-4 mb-6">
    <div class="bg-white border border-neutral-200 rounded-sm p-4">
        <div class="text-xs text-neutral-400">Outstanding balance</div>
        <div class="text-xl font-light text-neutral-900 mt-1">₦@outstanding.ToString("N0")</div>
    </div>
    <div class="bg-white border border-neutral-200 rounded-sm p-4">
        <div class="text-xs text-neutral-400">Active cards</div>
        <div class="text-xl font-light text-neutral-900 mt-1">@activeCount.ToString("N0")</div>
    </div>
    <div class="bg-white border border-neutral-200 rounded-sm p-4">
        <div class="text-xs text-neutral-400">Total ever issued</div>
        <div class="text-xl font-light text-neutral-900 mt-1">₦@issued.ToString("N0")</div>
    </div>
</div>

<div class="flex items-center justify-between gap-4 flex-wrap mb-4">
    <div class="flex gap-6 border-b border-neutral-200 text-sm">
        @foreach (var f in new[] { ("all", "All"), ("active", "Active"), ("spent", "Spent"), ("inactive", "Deactivated"), ("expired", "Expired") })
        {
            <a asp-area="Admin" asp-controller="GiftCards" asp-action="Index" asp-route-status="@f.Item1" asp-route-q="@q"
               class="pb-2.5 border-b-2 @TabCls(f.Item1)">@f.Item2</a>
        }
    </div>
    <form asp-area="Admin" asp-controller="GiftCards" asp-action="Index" method="get" class="flex gap-2">
        <input type="hidden" name="status" value="@status" />
        <input name="q" value="@q" placeholder="Search code / recipient…" class="border border-neutral-200 rounded-sm px-3 py-1.5 text-sm w-56" />
        <button type="submit" class="px-3 py-1.5 text-xs border border-neutral-200 rounded-sm text-neutral-600 hover:border-neutral-400">Search</button>
    </form>
</div>

@if (!Model.Any())
{
    <div class="bg-white border border-neutral-200 rounded-sm p-12 text-center text-sm text-neutral-400">No gift cards here.</div>
}
else
{
    <div class="bg-white border border-neutral-200 rounded-sm overflow-x-auto">
        <table class="w-full text-sm min-w-[720px]">
            <thead class="bg-neutral-50 text-neutral-500 text-xs">
                <tr>
                    <th class="text-left font-semibold px-4 py-3">Code</th>
                    <th class="text-left font-semibold px-4 py-3">Recipient</th>
                    <th class="text-right font-semibold px-4 py-3">Issued</th>
                    <th class="text-right font-semibold px-4 py-3">Balance</th>
                    <th class="text-left font-semibold px-4 py-3">Status</th>
                    <th class="text-left font-semibold px-4 py-3">Created</th>
                    <th class="px-4 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-neutral-100">
                @foreach (var g in Model)
                {
                    var expired = g.ExpiresAt != null && g.ExpiresAt <= now;
                    <tr class="hover:bg-neutral-50">
                        <td class="px-4 py-2.5 font-mono text-neutral-800">@g.Code</td>
                        <td class="px-4 py-2.5 text-neutral-600">@(g.RecipientName ?? g.RecipientEmail ?? "—")</td>
                        <td class="px-4 py-2.5 text-right text-neutral-500">₦@g.InitialAmount.ToString("N0")</td>
                        <td class="px-4 py-2.5 text-right font-medium @(g.Balance > 0 ? "text-neutral-900" : "text-neutral-400")">₦@g.Balance.ToString("N0")</td>
                        <td class="px-4 py-2.5">
                            @if (!g.IsActive) { <span class="text-[10px] bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full">Deactivated</span> }
                            else if (expired) { <span class="text-[10px] bg-red-50 text-red-600 px-2 py-0.5 rounded-full">Expired</span> }
                            else if (g.Balance <= 0) { <span class="text-[10px] bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full">Spent</span> }
                            else { <span class="text-[10px] bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Active</span> }
                        </td>
                        <td class="px-4 py-2.5 text-neutral-400 text-xs">@g.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td class="px-4 py-2.5 text-right">
                            <a asp-area="Admin" asp-controller="GiftCards" asp-action="Details" asp-route-id="@g.Id" class="text-xs text-neutral-500 hover:text-neutral-900">Manage →</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="flex items-center justify-center gap-1.5 mt-6 text-xs">
            @for (int p = 1; p <= totalPages; p++)
            {
                <a asp-area="Admin" asp-controller="GiftCards" asp-action="Index" asp-route-status="@status" asp-route-q="@q" asp-route-page="@p"
                   class="px-3 py-1.5 rounded-sm border @(p == page ? "bg-neutral-900 text-white border-neutral-900" : "border-neutral-200 text-neutral-600 hover:border-neutral-400")">@p</a>
            }
        </div>
    }
}
