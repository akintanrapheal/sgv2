@model SterlingLams.Web.Areas.Admin.Controllers.IntegrationsViewModel
@{
    ViewData["Title"] = "Integrations";
}

<div class="max-w-3xl">
    <div class="mb-6">
        <h1 class="text-lg font-medium text-neutral-900">Integrations</h1>
        <p class="text-sm text-neutral-500 mt-1">
            Payment gateway keys, webhooks and email (SMTP). Enter your keys and save — changes take
            effect immediately, no redeploy. Secret keys are <span class="font-medium">encrypted at rest</span>
            and never shown again once saved. This page is visible to full administrators only.
        </p>
    </div>

    <form asp-area="Admin" asp-controller="Integrations" asp-action="Save" method="post" class="space-y-8">
        @Html.AntiForgeryToken()

        @* ─── Payments ─────────────────────────────────────────────────────── *@
        <section class="bg-white rounded-sm border border-neutral-100 p-6 space-y-5">
            <div>
                <h2 class="text-sm font-semibold text-neutral-800">Payment Gateway</h2>
                <p class="text-xs text-neutral-400 mt-0.5">Choose which provider processes checkout, then enter its keys.</p>
            </div>

            <div>
                <label class="block text-xs font-medium text-neutral-700 mb-1">Active Provider</label>
                <select name="payment.provider" class="w-full border border-neutral-200 px-3 py-2 text-sm rounded-sm focus:outline-none focus:border-brand-500">
                    <option value="paystack"    selected="@(Model.Provider == "paystack")">Paystack</option>
                    <option value="stripe"      selected="@(Model.Provider == "stripe")">Stripe</option>
                    <option value="flutterwave" selected="@(Model.Provider == "flutterwave")">Flutterwave</option>
                </select>
                <p class="text-xs text-neutral-400 mt-1">Only the selected provider's keys are used at checkout.</p>
            </div>

            @* Paystack *@
            <div class="border-t border-neutral-100 pt-4 space-y-3">
                <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Paystack</p>
                <div>
                    <label class="block text-xs font-medium text-neutral-700 mb-1">Public Key</label>
                    <input type="text" name="payment.paystack.public_key" value="@Model.PaystackPublicKey"
                           placeholder="pk_live_…" autocomplete="off"
                           class="w-full border border-neutral-200 px-3 py-2 text-sm rounded-sm font-mono focus:outline-none focus:border-brand-500" />
                </div>
                <partial name="_SecretField" model="@(("payment.paystack.secret_key", "Secret Key", "sk_live_…", Model.PaystackSecretSet))" />
            </div>

            @* Stripe *@
            <div class="border-t border-neutral-100 pt-4 space-y-3">
                <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Stripe</p>
                <div>
                    <label class="block text-xs font-medium text-neutral-700 mb-1">Publishable Key</label>
                    <input type="text" name="payment.stripe.publishable_key" value="@Model.StripePublishableKey"
                           placeholder="pk_live_…" autocomplete="off"
                           class="w-full border border-neutral-200 px-3 py-2 text-sm rounded-sm font-mono focus:outline-none focus:border-brand-500" />
                </div>
                <partial name="_SecretField" model="@(("payment.stripe.secret_key", "Secret Key", "sk_live_…", Model.StripeSecretSet))" />
                <partial name="_SecretField" model="@(("payment.stripe.webhook_secret", "Webhook Signing Secret", "whsec_…", Model.StripeWebhookSet))" />
            </div>

            @* Flutterwave *@
            <div class="border-t border-neutral-100 pt-4 space-y-3">
                <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Flutterwave</p>
                <div>
                    <label class="block text-xs font-medium text-neutral-700 mb-1">Public Key</label>
                    <input type="text" name="payment.flutterwave.public_key" value="@Model.FlutterwavePublicKey"
                           placeholder="FLWPUBK-…" autocomplete="off"
                           class="w-full border border-neutral-200 px-3 py-2 text-sm rounded-sm font-mono focus:outline-none focus:border-brand-500" />
                </div>
                <partial name="_SecretField" model="@(("payment.flutterwave.secret_key", "Secret Key", "FLWSECK-…", Model.FlutterwaveSecretSet))" />
                <partial name="_SecretField" model="@(("payment.flutterwave.encryption_key", "Encryption Key", "FLWSECK_…", Model.FlutterwaveEncSet))" />
            </div>
        </section>

        @* ─── Webhook ──────────────────────────────────────────────────────── *@
        <section class="bg-white rounded-sm border border-neutral-100 p-6 space-y-3">
            <div>
                <h2 class="text-sm font-semibold text-neutral-800">Webhook URL</h2>
                <p class="text-xs text-neutral-400 mt-0.5">
                    Paste this into your <span class="font-medium capitalize">@Model.Provider</span> dashboard so
                    paid orders confirm automatically even if the customer closes the tab. The signature is verified
                    with the Secret Key above (Stripe uses the Webhook Signing Secret).
                </p>
            </div>
            @{
                // Only Paystack has a wired handler today; show the endpoint for the active provider.
                var hookUrl = Model.BaseUrl + "/webhooks/" + Model.Provider;
            }
            <div>
                <div class="flex gap-2">
                    <input type="text" readonly value="@hookUrl"
                           class="flex-1 border border-neutral-200 bg-neutral-50 px-3 py-2 text-sm rounded-sm font-mono text-neutral-600" />
                    <button type="button" onclick="navigator.clipboard.writeText('@hookUrl'); this.textContent='Copied'; setTimeout(()=>this.textContent='Copy',1200);"
                            class="px-3 py-2 text-xs border border-neutral-200 rounded-sm text-neutral-600 hover:bg-neutral-50 whitespace-nowrap">Copy</button>
                </div>
                @if (Model.Provider != "paystack")
                {
                    <p class="text-xs text-amber-600 mt-2">
                        Note: automatic webhook confirmation is currently wired for Paystack. Stripe/Flutterwave
                        payments still verify on the browser return; ask to enable their webhook handler if you switch.
                    </p>
                }
            </div>
        </section>

        @* ─── Email / SMTP ─────────────────────────────────────────────────── *@
        <section class="bg-white rounded-sm border border-neutral-100 p-6 space-y-4">
            <div>
                <h2 class="text-sm font-semibold text-neutral-800">Email (SMTP)</h2>
                <p class="text-xs text-neutral-400 mt-0.5">Outgoing mail for order confirmations, receipts and marketing.</p>
            </div>

            <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" name="email.smtp.enabled" value="true" @(Model.SmtpEnabled ? "checked" : "")
                       class="mt-0.5 rounded border-neutral-300 accent-neutral-900 w-4 h-4" />
                <div>
                    <p class="text-sm font-medium text-neutral-800">Send email via SMTP</p>
                    <p class="text-xs text-neutral-400 mt-0.5">When off, emails are previewed/logged but not sent.</p>
                </div>
            </label>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div class="sm:col-span-2">
                    <label class="block text-xs font-medium text-neutral-700 mb-1">SMTP Host</label>
                    <input type="text" name="email.smtp.host" value="@Model.SmtpHost" placeholder="smtp.zoho.com" autocomplete="off"
                           class="w-full border border-neutral-200 px-3 py-2 text-sm rounded-sm focus:outline-none focus:border-brand-500" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-neutral-700 mb-1">Port</label>
                    <input type="number" name="email.smtp.port" value="@Model.SmtpPort" placeholder="587"
                           class="w-full border border-neutral-200 px-3 py-2 text-sm rounded-sm focus:outline-none focus:border-brand-500" />
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-medium text-neutral-700 mb-1">Username</label>
                    <input type="text" name="email.smtp.username" value="@Model.SmtpUsername" placeholder="hello@sterlinglams.com" autocomplete="off"
                           class="w-full border border-neutral-200 px-3 py-2 text-sm rounded-sm focus:outline-none focus:border-brand-500" />
                </div>
                <div>
                    <partial name="_SecretField" model="@(("email.smtp.password", "Password", "mailbox / app password", Model.SmtpPasswordSet))" />
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-medium text-neutral-700 mb-1">From Address</label>
                    <input type="email" name="email.smtp.from_address" value="@Model.SmtpFromAddress" placeholder="hello@sterlinglams.com" autocomplete="off"
                           class="w-full border border-neutral-200 px-3 py-2 text-sm rounded-sm focus:outline-none focus:border-brand-500" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-neutral-700 mb-1">From Name</label>
                    <input type="text" name="email.smtp.from_name" value="@Model.SmtpFromName" placeholder="Sterlin Glams"
                           class="w-full border border-neutral-200 px-3 py-2 text-sm rounded-sm focus:outline-none focus:border-brand-500" />
                </div>
            </div>

            <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" name="email.smtp.ssl" value="true" @(Model.SmtpSsl ? "checked" : "")
                       class="mt-0.5 rounded border-neutral-300 accent-neutral-900 w-4 h-4" />
                <div>
                    <p class="text-sm font-medium text-neutral-800">Use SSL/TLS</p>
                    <p class="text-xs text-neutral-400 mt-0.5">Keep on for ports 587 and 465.</p>
                </div>
            </label>
        </section>

        <div class="flex items-center gap-3">
            <button type="submit" class="bg-neutral-900 text-white text-sm px-6 py-2.5 rounded-sm hover:bg-neutral-700 transition-colors">
                Save changes
            </button>
            <span class="text-xs text-neutral-400">Secret fields left blank keep their current value.</span>
        </div>
    </form>
</div>
