@model SterlingLams.Web.Areas.Admin.ViewModels.AdminDiscountListViewModel
@using SterlingLams.Web.Models.Domain
@{
    ViewData["Title"] = "Discount Codes";
}

<div class="flex items-center justify-between mb-6">
    <p class="text-xs text-neutral-400">@Model.DiscountCodes.Count discount@(Model.DiscountCodes.Count == 1 ? "" : "s")</p>
    <a asp-area="Admin" asp-controller="Discounts" asp-action="Create"
       class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
        + New Discount
    </a>
</div>

<div class="bg-white rounded-sm border border-neutral-100 overflow-x-auto">
    <table class="w-full text-sm min-w-[860px]">
        <thead>
            <tr class="border-b border-neutral-100 bg-neutral-50">
                <th class="text-left px-5 py-3 text-xs text-neutral-400 font-medium">Code</th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Type</th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Applies To</th>
                <th class="text-right px-4 py-3 text-xs text-neutral-400 font-medium">Value</th>
                <th class="text-right px-4 py-3 text-xs text-neutral-400 font-medium">Uses</th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Status</th>
                <th class="px-5 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-50">
            @if (!Model.DiscountCodes.Any())
            {
                <tr><td colspan="7" class="px-6 py-12 text-center text-xs text-neutral-400">No discounts yet. Create your first one.</td></tr>
            }
            @foreach (var d in Model.DiscountCodes)
            {
                <tr class="hover:bg-neutral-50 transition-colors">
                    <td class="px-5 py-3">
                        @if (d.IsAutomatic)
                        {
                            <span class="text-[10px] bg-violet-50 text-violet-700 px-2 py-0.5 rounded-full">Auto</span>
                            <p class="text-xs text-neutral-700 mt-1">@(d.Description ?? "Automatic promotion")</p>
                        }
                        else
                        {
                            <span class="font-mono text-xs text-neutral-800 bg-neutral-50 border border-neutral-200 px-2 py-0.5 rounded">@d.Code</span>
                            @if (!string.IsNullOrEmpty(d.Description))
                            {
                                <p class="text-[10px] text-neutral-400 mt-1">@d.Description</p>
                            }
                        }
                    </td>
                    <td class="px-4 py-3 text-xs text-neutral-600">
                        @(d.Type switch {
                            DiscountType.Percentage => "Percentage",
                            DiscountType.FixedAmount => "Fixed ₦",
                            DiscountType.FreeShipping => "Free Shipping",
                            _ => d.Type.ToString()
                        })
                    </td>
                    <td class="px-4 py-3 text-xs text-neutral-500">
                        @(d.Scope switch {
                            DiscountScope.EntireOrder => "Entire order",
                            DiscountScope.Categories => "Categories",
                            DiscountScope.Products => "Products",
                            _ => d.Scope.ToString()
                        })
                    </td>
                    <td class="px-4 py-3 text-xs text-right font-medium">
                        @(d.Type switch {
                            DiscountType.Percentage => d.Value.ToString("N0") + "%",
                            DiscountType.FixedAmount => "₦" + d.Value.ToString("N0"),
                            _ => "—"
                        })
                    </td>
                    <td class="px-4 py-3 text-xs text-right text-neutral-500">
                        @d.UsedCount@(d.MaxUses.HasValue ? " / " + d.MaxUses : "")
                    </td>
                    <td class="px-4 py-3">
                        @if (!d.IsActive)
                        {
                            <span class="text-[10px] bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full">Inactive</span>
                        }
                        else if (d.IsExpired)
                        {
                            <span class="text-[10px] bg-red-50 text-red-700 px-2 py-0.5 rounded-full">Expired</span>
                        }
                        else if (d.IsScheduled)
                        {
                            <span class="text-[10px] bg-amber-50 text-amber-700 px-2 py-0.5 rounded-full">Scheduled</span>
                        }
                        else if (d.IsUsedUp)
                        {
                            <span class="text-[10px] bg-orange-50 text-orange-700 px-2 py-0.5 rounded-full">Used up</span>
                        }
                        else
                        {
                            <span class="text-[10px] bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Live</span>
                        }
                    </td>
                    <td class="px-5 py-3 text-right">
                        <div class="flex items-center justify-end gap-3 whitespace-nowrap">
                            <a asp-area="Admin" asp-controller="Discounts" asp-action="Usage" asp-route-id="@d.Id"
                               class="text-xs text-neutral-400 hover:text-neutral-900 transition-colors">Usage</a>
                            <a asp-area="Admin" asp-controller="Discounts" asp-action="Edit" asp-route-id="@d.Id"
                               class="text-xs text-neutral-500 hover:text-neutral-900 transition-colors">Edit</a>
                            <form asp-area="Admin" asp-controller="Discounts" asp-action="Toggle" asp-route-id="@d.Id" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <button data-no-loading="1" class="text-xs text-blue-500 hover:text-blue-700 transition-colors">@(d.IsActive ? "Disable" : "Enable")</button>
                            </form>
                            <form asp-area="Admin" asp-controller="Discounts" asp-action="Delete" asp-route-id="@d.Id"
                                  method="post" class="inline" onsubmit="return confirm('Delete @d.Code?')">
                                @Html.AntiForgeryToken()
                                <button data-no-loading="1" class="text-xs text-rose-400 hover:text-rose-700 transition-colors">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
