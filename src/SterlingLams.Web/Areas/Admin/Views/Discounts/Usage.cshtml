@model SterlingLams.Web.Areas.Admin.ViewModels.AdminDiscountUsageViewModel
@{
    ViewData["Title"] = "Discount Usage";
}

<div class="flex items-center gap-3 mb-6">
    <a asp-area="Admin" asp-controller="Discounts" asp-action="Index"
       class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">← Discounts</a>
    <span class="text-neutral-200">/</span>
    <span class="text-xs text-neutral-600">Usage: @Model.Discount.Code</span>
</div>

<!-- Summary cards -->
<div class="grid grid-cols-2 lg:grid-cols-3 gap-3 mb-6">
    <div class="bg-white rounded-sm border border-neutral-100 p-4">
        <p class="text-[10px] text-neutral-400 uppercase tracking-widest mb-1">Times Used</p>
        <p class="text-2xl font-light text-neutral-800">@Model.Usages.Count</p>
    </div>
    <div class="bg-white rounded-sm border border-neutral-100 p-4">
        <p class="text-[10px] text-neutral-400 uppercase tracking-widest mb-1">Total Discounted</p>
        <p class="text-2xl font-light text-emerald-600">₦@Model.TotalDiscounted.ToString("N0")</p>
    </div>
    <div class="bg-white rounded-sm border border-neutral-100 p-4">
        <p class="text-[10px] text-neutral-400 uppercase tracking-widest mb-1">Limit</p>
        <p class="text-2xl font-light text-neutral-800">@(Model.Discount.MaxUses?.ToString() ?? "∞")</p>
    </div>
</div>

<div class="bg-white rounded-sm border border-neutral-100 overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-neutral-100 bg-neutral-50">
                <th class="text-left px-6 py-3 text-xs text-neutral-400 font-medium">Order</th>
                <th class="text-left px-6 py-3 text-xs text-neutral-400 font-medium">Customer</th>
                <th class="text-right px-6 py-3 text-xs text-neutral-400 font-medium">Discount</th>
                <th class="text-right px-6 py-3 text-xs text-neutral-400 font-medium">Order Total</th>
                <th class="text-left px-6 py-3 text-xs text-neutral-400 font-medium">Date</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-50">
            @if (!Model.Usages.Any())
            {
                <tr><td colspan="5" class="px-6 py-12 text-center text-xs text-neutral-400">This discount hasn't been used in any paid order yet.</td></tr>
            }
            @foreach (var u in Model.Usages)
            {
                <tr class="hover:bg-neutral-50 transition-colors">
                    <td class="px-6 py-3">
                        <a asp-area="Admin" asp-controller="Orders" asp-action="Detail" asp-route-id="@u.OrderId"
                           class="font-mono text-xs text-neutral-700 hover:text-neutral-900 hover:underline">@u.OrderNumber</a>
                    </td>
                    <td class="px-6 py-3 text-xs text-neutral-600">@u.CustomerName</td>
                    <td class="px-6 py-3 text-xs text-right text-emerald-600 font-medium">-₦@u.DiscountAmount.ToString("N0")</td>
                    <td class="px-6 py-3 text-xs text-right">₦@u.OrderTotal.ToString("N0")</td>
                    <td class="px-6 py-3 text-xs text-neutral-400">@u.CreatedAt.ToLocalTime().ToString("dd MMM yy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
