@model SterlingLams.Web.Areas.Admin.ViewModels.AdminDiscountEditViewModel
@{
    var isNew = Model.Id == 0;
}

<div class="mb-6">
    <a asp-area="Admin" asp-controller="Discounts" asp-action="Index"
       class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">← Back to Discount Codes</a>
</div>

<div class="max-w-lg">
    <form asp-area="Admin" asp-controller="Discounts" asp-action="Save" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div>
            <label class="block text-xs text-neutral-500 mb-1">Code *</label>
            <input asp-for="Code" required placeholder="e.g. SUMMER20"
                   class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400 font-mono uppercase" />
            <p class="text-[10px] text-neutral-400 mt-1">Code will be auto-uppercased. Must be unique.</p>
        </div>

        <div>
            <label class="block text-xs text-neutral-500 mb-1">Description</label>
            <input asp-for="Description"
                   class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-xs text-neutral-500 mb-1">Type *</label>
                <select asp-for="Type"
                        class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400">
                    <option value="Percentage">Percentage (%)</option>
                    <option value="FixedAmount">Fixed Amount (₦)</option>
                </select>
            </div>
            <div>
                <label class="block text-xs text-neutral-500 mb-1">Value *</label>
                <input asp-for="Value" type="number" step="0.01" min="0" required
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-xs text-neutral-500 mb-1">Minimum Order Amount (₦)</label>
                <input asp-for="MinimumOrderAmount" type="number" step="100" min="0"
                       placeholder="Leave blank for no minimum"
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>
            <div>
                <label class="block text-xs text-neutral-500 mb-1">Max Uses</label>
                <input asp-for="MaxUses" type="number" min="1"
                       placeholder="Leave blank for unlimited"
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-xs text-neutral-500 mb-1">Starts At</label>
                <input asp-for="StartsAt" type="date"
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>
            <div>
                <label class="block text-xs text-neutral-500 mb-1">Expires At</label>
                <input asp-for="ExpiresAt" type="date"
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>
        </div>

        <div class="flex items-center gap-2">
            <input asp-for="IsActive" type="checkbox" class="accent-neutral-900" />
            <label class="text-xs text-neutral-600">Active</label>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit"
                    class="px-6 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
                @(isNew ? "Create Code" : "Save Changes")
            </button>
            <a asp-area="Admin" asp-controller="Discounts" asp-action="Index"
               class="px-6 py-2 border border-neutral-200 text-neutral-600 text-xs rounded-sm hover:border-neutral-400 transition-colors">
                Cancel
            </a>
        </div>
    </form>
</div>
