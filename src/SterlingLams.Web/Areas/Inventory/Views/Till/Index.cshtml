@model SterlingLams.Web.Areas.Inventory.Controllers.TillOversightViewModel
@{
    ViewData["Title"] = "POS";
    var stores = ViewBag.Stores as List<SterlingLams.Web.Models.Domain.Store> ?? new();
    int? storeId = ViewBag.StoreId;
    string status = ViewBag.Status ?? "all";
    var selectCls = "border border-neutral-200 rounded-sm px-3 py-2 text-sm bg-white focus:outline-none focus:border-emerald-400";
}

<div class="flex items-center justify-between mb-6">
    <div class="flex gap-8">
        <div><p class="text-xs text-neutral-400 uppercase tracking-wide">Sales today</p><p class="text-xl font-semibold text-neutral-900">₦@Model.SalesToday.ToString("N0")</p></div>
        <div><p class="text-xs text-neutral-400 uppercase tracking-wide">Transactions</p><p class="text-xl font-semibold text-neutral-900">@Model.TxToday</p></div>
        <div><p class="text-xs text-neutral-400 uppercase tracking-wide">Open sessions</p><p class="text-xl font-semibold @(Model.OpenSessions > 0 ? "text-emerald-600" : "text-neutral-900")">@Model.OpenSessions</p></div>
    </div>
    <a href="/till" target="_blank" rel="noopener"
       class="px-4 py-2 bg-emerald-600 text-white text-sm rounded-sm hover:bg-emerald-700 transition-colors">Open POS App →</a>
</div>

<form asp-area="Inventory" asp-controller="Till" asp-action="Index" method="get" class="flex gap-2 flex-wrap mb-3">
    <select name="storeId" onchange="this.form.submit()" class="@selectCls">
        <option value="">All branches</option>
        @foreach (var s in stores)
        {
            <option value="@s.Id" selected="@(storeId == s.Id)">@s.Name</option>
        }
    </select>
    <select name="status" onchange="this.form.submit()" class="@selectCls">
        <option value="all" selected="@(status == "all")">All statuses</option>
        <option value="open" selected="@(status == "open")">Open</option>
        <option value="closed" selected="@(status == "closed")">Closed</option>
    </select>
</form>

<p class="text-xs text-neutral-400 mb-3">Cash-ups across all tills.</p>
<div class="bg-white border border-neutral-100 rounded-sm overflow-x-auto">
    <table class="w-full text-sm min-w-[800px]">
        <thead class="bg-neutral-50 text-neutral-500 text-xs uppercase tracking-wide">
            <tr>
                <th class="text-left font-medium px-4 py-3">Till</th>
                <th class="text-left font-medium px-4 py-3">Opened</th>
                <th class="text-left font-medium px-4 py-3">Status</th>
                <th class="text-right font-medium px-4 py-3">Sales</th>
                <th class="text-right font-medium px-4 py-3">Expected cash</th>
                <th class="text-right font-medium px-4 py-3">Counted</th>
                <th class="text-right font-medium px-4 py-3">Variance</th>
                <th class="px-4 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-100">
            @if (!Model.Rows.Any())
            {
                <tr><td colspan="8" class="px-4 py-10 text-center text-neutral-400">No till sessions yet.</td></tr>
            }
            @foreach (var r in Model.Rows)
            {
                <tr class="hover:bg-neutral-50">
                    <td class="px-4 py-3">
                        <p class="text-neutral-800">@r.Session.Register?.Name</p>
                        <p class="text-[10px] text-neutral-400">@r.Session.Register?.Store?.Name · @r.SaleCount sale(s)</p>
                    </td>
                    <td class="px-4 py-3 text-neutral-600 whitespace-nowrap">@r.Session.OpenedAt.ToLocalTime().ToString("dd MMM, HH:mm")</td>
                    <td class="px-4 py-3">
                        @if (r.Session.ClosedAt == null)
                        {
                            <span class="text-[10px] px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-700">Open</span>
                        }
                        else
                        {
                            <span class="text-[10px] px-2 py-0.5 rounded-full bg-neutral-100 text-neutral-500">Closed</span>
                        }
                    </td>
                    <td class="px-4 py-3 text-right text-neutral-800">₦@r.Sales.ToString("N0")</td>
                    <td class="px-4 py-3 text-right text-neutral-600">₦@r.ExpectedCash.ToString("N0")</td>
                    <td class="px-4 py-3 text-right text-neutral-600">@(r.Session.CountedCash.HasValue ? "₦" + r.Session.CountedCash.Value.ToString("N0") : "—")</td>
                    <td class="px-4 py-3 text-right">
                        @if (r.Variance.HasValue)
                        {
                            <span class="@(r.Variance == 0 ? "text-emerald-600" : "text-red-600")">@(r.Variance >= 0 ? "+" : "")₦@r.Variance.Value.ToString("N0")</span>
                        }
                        else { <span class="text-neutral-300">—</span> }
                    </td>
                    <td class="px-4 py-3 text-right">
                        <a href="/Till/Zreport/@r.Session.Id" target="_blank" class="text-xs text-neutral-500 hover:text-emerald-600">Z-report</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
