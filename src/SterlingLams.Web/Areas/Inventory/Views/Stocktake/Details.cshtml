@model SterlingLams.Web.Models.Domain.StockTake
@{
    ViewData["Title"] = $"Stock Take {Model.Reference}";
}

<div class="flex items-center gap-3 mb-5">
    <a asp-area="Inventory" asp-controller="Stocktake" asp-action="History" class="text-xs text-neutral-400 hover:text-neutral-700">← Stock Takes</a>
    <span class="text-neutral-200">/</span>
    <h1 class="text-xl font-semibold text-neutral-900">Stock Take Details</h1>
    <button type="button" onclick="window.print()" class="ml-auto px-4 py-2 border border-neutral-200 text-neutral-700 text-xs rounded-md hover:border-neutral-400">Print</button>
</div>

<!-- Header info -->
<div class="bg-white border border-neutral-200 rounded-md p-6 mb-4">
    <h2 class="text-sm font-semibold text-neutral-700 mb-4">Stock Take Info</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-2 gap-x-8 text-sm max-w-2xl">
        <div class="flex justify-between border-b border-neutral-50 py-1.5"><span class="text-neutral-400">Location</span><span class="text-neutral-800">@Model.Store.Name</span></div>
        <div class="flex justify-between border-b border-neutral-50 py-1.5"><span class="text-neutral-400">Reference</span><span class="text-neutral-800 font-medium">@Model.Reference</span></div>
        <div class="flex justify-between border-b border-neutral-50 py-1.5"><span class="text-neutral-400">Status</span><span class="text-emerald-600">@Model.Status</span></div>
        <div class="flex justify-between border-b border-neutral-50 py-1.5"><span class="text-neutral-400">Staff</span><span class="text-neutral-800">@Model.StaffName</span></div>
        <div class="flex justify-between border-b border-neutral-50 py-1.5"><span class="text-neutral-400">Date</span><span class="text-neutral-800">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span></div>
        <div class="flex justify-between border-b border-neutral-50 py-1.5"><span class="text-neutral-400">Items</span><span class="text-neutral-800">@Model.ItemCount (@Model.Discrepancies discrepancies)</span></div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.Note))
    {
        <div class="mt-4"><div class="text-[11px] text-neutral-400 mb-1">Note</div><div class="text-sm text-neutral-700 bg-neutral-50 rounded-md p-3">@Model.Note</div></div>
    }
</div>

<!-- Lines -->
<div class="bg-white border border-neutral-200 rounded-md overflow-x-auto">
    <table class="w-full text-sm min-w-[720px]">
        <thead class="bg-neutral-50 text-neutral-500 text-xs">
            <tr>
                <th class="text-left font-semibold px-4 py-3">Product</th>
                <th class="text-left font-semibold px-4 py-3">Barcode</th>
                <th class="text-left font-semibold px-4 py-3">Category</th>
                <th class="text-center font-semibold px-4 py-3">Expected</th>
                <th class="text-center font-semibold px-4 py-3">Actual</th>
                <th class="text-center font-semibold px-4 py-3">Variance</th>
                <th class="text-left font-semibold px-4 py-3">Item Reason</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-100">
            @foreach (var l in Model.Lines.OrderBy(x => x.ProductName))
            {
                <tr class="hover:bg-neutral-50">
                    <td class="px-4 py-2.5 text-neutral-800">@l.ProductName</td>
                    <td class="px-4 py-2.5 text-neutral-500 font-mono text-xs">@(l.Barcode ?? "—")</td>
                    <td class="px-4 py-2.5 text-neutral-500 text-xs">@(string.IsNullOrEmpty(l.CategoryName) ? "—" : l.CategoryName)</td>
                    <td class="px-4 py-2.5 text-center text-neutral-600">@l.ExpectedQty</td>
                    <td class="px-4 py-2.5 text-center text-neutral-800">@l.CountedQty</td>
                    <td class="px-4 py-2.5 text-center @(l.Variance == 0 ? "text-neutral-400" : l.Variance > 0 ? "text-emerald-600" : "text-red-600")">@(l.Variance > 0 ? "+" : "")@l.Variance</td>
                    <td class="px-4 py-2.5 text-neutral-600 text-xs">@(string.IsNullOrEmpty(l.Reason) ? "n/a" : l.Reason)</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="bg-blue-500 text-white font-medium">
                <td class="px-4 py-2.5" colspan="3">Total</td>
                <td class="px-4 py-2.5 text-center">@Model.Lines.Sum(l => l.ExpectedQty)</td>
                <td class="px-4 py-2.5 text-center">@Model.Lines.Sum(l => l.CountedQty)</td>
                <td class="px-4 py-2.5 text-center">@Model.Lines.Sum(l => l.Variance)</td>
                <td class="px-4 py-2.5"></td>
            </tr>
        </tfoot>
    </table>
</div>
