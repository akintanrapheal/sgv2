@model List<SterlingLams.Web.Models.Domain.StockTake>
@{
    ViewData["Title"] = "Stock Takes";
    var stores = ViewBag.Stores as List<SterlingLams.Web.Models.Domain.Store> ?? new();
    DateTime from = ViewBag.From; DateTime to = ViewBag.To;
    int? storeId = ViewBag.StoreId; string q = ViewBag.Q ?? "";
    int page = ViewBag.Page ?? 1; int totalPages = ViewBag.TotalPages ?? 1; int total = ViewBag.Total ?? 0;
    Dictionary<string, string> rd(int pg) => new() {
        ["from"] = from.ToString("yyyy-MM-dd"), ["to"] = to.ToString("yyyy-MM-dd"),
        ["storeId"] = storeId?.ToString() ?? "", ["q"] = q, ["page"] = pg.ToString()
    };
}

<div class="flex items-start justify-between gap-3 mb-5 flex-wrap">
    <h1 class="text-2xl font-semibold text-neutral-900">Stock Takes</h1>
    <div class="flex items-center gap-2">
        <a asp-area="Inventory" asp-controller="Stocktake" asp-action="History" asp-all-route-data="@(new Dictionary<string,string>(rd(1)){ ["format"]="csv" })"
           class="px-4 py-2 border border-neutral-200 text-neutral-700 text-xs rounded-md hover:border-neutral-400">Export CSV</a>
        <button type="button" onclick="window.print()" class="px-4 py-2 border border-neutral-200 text-neutral-700 text-xs rounded-md hover:border-neutral-400">Print</button>
        <a asp-area="Inventory" asp-controller="Stocktake" asp-action="Index" class="px-4 py-2 bg-blue-600 text-white text-xs font-medium rounded-md hover:bg-blue-700">+ New Stock Take</a>
    </div>
</div>

<form asp-area="Inventory" asp-controller="Stocktake" asp-action="History" method="get" class="bg-white border border-neutral-200 rounded-md p-4 mb-4 flex flex-wrap items-end gap-4">
    <div>
        <label class="block text-[11px] text-neutral-400 mb-1">From date</label>
        <input type="date" name="from" value="@from.ToString("yyyy-MM-dd")" class="border border-neutral-200 rounded-md px-3 py-2 text-sm" />
    </div>
    <div>
        <label class="block text-[11px] text-neutral-400 mb-1">To date</label>
        <input type="date" name="to" value="@to.ToString("yyyy-MM-dd")" class="border border-neutral-200 rounded-md px-3 py-2 text-sm" />
    </div>
    <div>
        <label class="block text-[11px] text-neutral-400 mb-1">Filter by location</label>
        <select name="storeId" class="border border-neutral-200 rounded-md px-3 py-2 text-sm bg-white">
            <option value="">All locations</option>
            @foreach (var s in stores) { <option value="@s.Id" selected="@(storeId == s.Id)">@s.Name</option> }
        </select>
    </div>
    <div class="flex-1 min-w-[180px]">
        <label class="block text-[11px] text-neutral-400 mb-1">Search reference</label>
        <input type="text" name="q" value="@q" placeholder="ST00042…" class="w-full border border-neutral-200 rounded-md px-3 py-2 text-sm" />
    </div>
    <button type="submit" class="px-5 py-2 bg-blue-600 text-white text-sm rounded-md hover:bg-blue-700">Search</button>
</form>

<div class="bg-white border border-neutral-200 rounded-md overflow-x-auto">
    <table class="w-full text-sm min-w-[680px]">
        <thead class="bg-neutral-50 text-neutral-500 text-xs">
            <tr>
                <th class="text-left font-semibold px-4 py-3">Stock Ref.</th>
                <th class="text-left font-semibold px-4 py-3">Location</th>
                <th class="text-left font-semibold px-4 py-3">Staff</th>
                <th class="text-center font-semibold px-4 py-3">Items</th>
                <th class="text-center font-semibold px-4 py-3">Discrepancies</th>
                <th class="text-left font-semibold px-4 py-3">Date</th>
                <th class="px-4 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-100">
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="px-4 py-16 text-center text-neutral-400">No stock takes in this range.</td></tr>
            }
            @foreach (var t in Model)
            {
                <tr class="hover:bg-neutral-50">
                    <td class="px-4 py-3 font-medium text-neutral-800">@t.Reference</td>
                    <td class="px-4 py-3 text-neutral-600">@t.Store.Name</td>
                    <td class="px-4 py-3 text-neutral-600">@t.StaffName</td>
                    <td class="px-4 py-3 text-center text-neutral-600">@t.ItemCount</td>
                    <td class="px-4 py-3 text-center @(t.Discrepancies > 0 ? "text-red-600 font-medium" : "text-neutral-400")">@t.Discrepancies</td>
                    <td class="px-4 py-3 text-neutral-500">@t.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="px-4 py-3 text-right">
                        <a asp-area="Inventory" asp-controller="Stocktake" asp-action="Details" asp-route-id="@t.Id"
                           class="px-3 py-1.5 border border-blue-300 text-blue-700 text-xs rounded-md hover:bg-blue-50">View Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (totalPages > 1)
    {
        <div class="flex items-center justify-end gap-4 px-4 py-3 border-t border-neutral-100 text-sm text-neutral-500">
            <span>Page @(page) of @totalPages (@total.ToString("N0"))</span>
            <div class="flex items-center gap-1">
                <a asp-area="Inventory" asp-controller="Stocktake" asp-action="History" asp-all-route-data="rd(1)" class="px-2 py-1 rounded @(page<=1 ? "text-neutral-300 pointer-events-none" : "hover:bg-neutral-100")">«</a>
                <a asp-area="Inventory" asp-controller="Stocktake" asp-action="History" asp-all-route-data="rd(page-1)" class="px-2 py-1 rounded @(page<=1 ? "text-neutral-300 pointer-events-none" : "hover:bg-neutral-100")">‹</a>
                <a asp-area="Inventory" asp-controller="Stocktake" asp-action="History" asp-all-route-data="rd(page+1)" class="px-2 py-1 rounded @(page>=totalPages ? "text-neutral-300 pointer-events-none" : "hover:bg-neutral-100")">›</a>
                <a asp-area="Inventory" asp-controller="Stocktake" asp-action="History" asp-all-route-data="rd(totalPages)" class="px-2 py-1 rounded @(page>=totalPages ? "text-neutral-300 pointer-events-none" : "hover:bg-neutral-100")">»</a>
            </div>
        </div>
    }
</div>
