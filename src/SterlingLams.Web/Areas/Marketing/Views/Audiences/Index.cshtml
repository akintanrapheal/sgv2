@model List<(SterlingLams.Web.Models.Domain.Segment Seg, int Count)>
@using SterlingLams.Web.Models.Domain
@{
    ViewData["Title"] = "Audiences";
    var builtins = ViewBag.Builtins as List<(string Name, string Desc, int Count)> ?? new();
    string AudLabel(CampaignAudience a) => a switch
    {
        CampaignAudience.AllCustomers => "All customers",
        CampaignAudience.NewsletterSubscribers => "Newsletter subscribers",
        CampaignAudience.RecentBuyers => "Recent buyers",
        CampaignAudience.LapsedCustomers => "Lapsed customers",
        CampaignAudience.NeverOrdered => "Never ordered",
        CampaignAudience.HighValue => "High value",
        CampaignAudience.ByState => "By state",
        _ => a.ToString()
    };
}
@Html.AntiForgeryToken()

<div class="mb-6 flex items-start justify-between gap-4 flex-wrap">
    <div>
        <h1 class="text-2xl font-light text-neutral-900">Audiences</h1>
        <p class="text-sm text-neutral-500 mt-1">Segments you can target with a campaign. Sizes are live and exclude unsubscribed contacts.</p>
    </div>
    <button type="button" onclick="document.getElementById('seg-form').classList.toggle('hidden')" class="px-4 py-2 text-sm bg-neutral-900 text-white rounded-sm hover:bg-neutral-700">+ Save a segment</button>
</div>

@if (TempData["Success"] != null) { <div class="mb-4 bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm px-4 py-3 rounded-sm">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="mb-4 bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-sm">@TempData["Error"]</div> }

<div id="seg-form" class="hidden bg-white border border-neutral-200 rounded-sm p-5 mb-6">
    <form asp-area="Marketing" asp-controller="Audiences" asp-action="Create" method="post" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        @Html.AntiForgeryToken()
        <div><label class="block text-xs text-neutral-500 mb-1">Name *</label><input name="name" required class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" /></div>
        <div>
            <label class="block text-xs text-neutral-500 mb-1">Rule</label>
            <select name="audience" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm bg-white">
                @foreach (var a in Enum.GetValues<CampaignAudience>()) { <option value="@a">@AudLabel(a)</option> }
            </select>
        </div>
        <div><label class="block text-xs text-neutral-500 mb-1">Days (recent/lapsed)</label><input name="days" type="number" min="1" placeholder="e.g. 90" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" /></div>
        <div><label class="block text-xs text-neutral-500 mb-1">Min spend ₦ (high value)</label><input name="minSpend" type="number" step="0.01" min="0" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" /></div>
        <div><label class="block text-xs text-neutral-500 mb-1">State (by state)</label><input name="state" placeholder="e.g. Lagos" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" /></div>
        <div><label class="block text-xs text-neutral-500 mb-1">Description</label><input name="description" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" /></div>
        <div class="sm:col-span-2 lg:col-span-3"><button type="submit" class="px-5 py-2 text-sm bg-emerald-600 text-white rounded-sm hover:bg-emerald-700">Save segment</button></div>
    </form>
</div>

@if (Model.Any())
{
    <p class="text-xs tracking-[0.15em] uppercase text-neutral-400 mb-3">Saved segments</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        @foreach (var (seg, count) in Model)
        {
            <div class="bg-white border border-neutral-200 rounded-sm p-5">
                <div class="flex items-start justify-between gap-2">
                    <div class="text-3xl font-light text-neutral-900">@count.ToString("N0")</div>
                    <form asp-area="Marketing" asp-controller="Audiences" asp-action="Delete" method="post" onsubmit="return confirm('Delete this segment?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@seg.Id" />
                        <button type="submit" class="text-xs text-red-500 hover:text-red-700">Delete</button>
                    </form>
                </div>
                <div class="text-sm font-medium text-neutral-700 mt-1">@seg.Name</div>
                <div class="text-xs text-neutral-400 mt-1">@(seg.Description ?? AudLabel(seg.Audience))</div>
            </div>
        }
    </div>
}

<p class="text-xs tracking-[0.15em] uppercase text-neutral-400 mb-3">Built-in segments</p>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    @foreach (var s in builtins)
    {
        <div class="bg-white border border-neutral-200 rounded-sm p-5">
            <div class="text-3xl font-light text-neutral-900">@s.Count.ToString("N0")</div>
            <div class="text-sm font-medium text-neutral-700 mt-1">@s.Name</div>
            <div class="text-xs text-neutral-400 mt-1">@s.Desc</div>
        </div>
    }
</div>

<div class="mt-6">
    <a asp-area="Marketing" asp-controller="Campaigns" asp-action="Create" class="px-4 py-2 text-sm bg-neutral-900 text-white rounded-sm hover:bg-neutral-700">Create a campaign</a>
</div>
