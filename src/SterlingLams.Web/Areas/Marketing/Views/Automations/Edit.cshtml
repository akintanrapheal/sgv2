@model SterlingLams.Web.Models.Domain.Automation
@using SterlingLams.Web.Models.Domain
@{
    ViewData["Title"] = Model.Id == 0 ? "New Automation" : "Edit Automation";
}

<div class="mb-6">
    <a asp-area="Marketing" asp-controller="Automations" asp-action="Index" class="text-xs text-neutral-400 hover:text-neutral-700">← All automations</a>
    <h1 class="text-2xl font-light text-neutral-900 mt-2">@ViewData["Title"]</h1>
</div>

<form asp-area="Marketing" asp-controller="Automations" asp-action="Save" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-4">
            <div class="bg-white border border-neutral-200 rounded-sm p-5 space-y-4">
                <div>
                    <label asp-for="Name" class="block text-xs text-neutral-500 mb-1">Name (internal) *</label>
                    <input asp-for="Name" required class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
                <div>
                    <label asp-for="Subject" class="block text-xs text-neutral-500 mb-1">Email subject *</label>
                    <input asp-for="Subject" required class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
                <div>
                    <label class="block text-xs text-neutral-500 mb-1">Email body</label>
                    <partial name="_RichTextEditor" model='new SterlingLams.Web.Models.ViewModels.RichTextEditorVm(nameof(Model.BodyHtml), "automation-body", Model.BodyHtml, "min-h-[16rem]")' />
                    <p class="text-[10px] text-neutral-400 mt-1">An unsubscribe footer is added automatically.</p>
                </div>
            </div>
            <partial name="_CouponFields" model='new SterlingLams.Web.Models.ViewModels.CouponFieldsVm(Model.CouponEnabled, Model.CouponType, Model.CouponValue, Model.CouponExpiryDays, Model.CouponMinOrder)' />
        </div>
        <div class="lg:col-span-1 space-y-4">
            <div class="bg-white border border-neutral-200 rounded-sm p-5 space-y-4">
                <div class="text-sm font-medium text-neutral-700">Trigger</div>
                <div>
                    <label asp-for="Trigger" class="block text-xs text-neutral-500 mb-1">When this happens</label>
                    <select asp-for="Trigger" id="trig" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm bg-white">
                        <option value="WelcomeNewCustomer">A new customer registers</option>
                        <option value="PostPurchase">A customer's order is paid</option>
                        <option value="WinBackLapsed">A customer hasn't ordered in a while</option>
                    </select>
                </div>
                <div data-trig="WinBackLapsed">
                    <label asp-for="WinBackDays" class="block text-xs text-neutral-500 mb-1">Days since last order</label>
                    <input asp-for="WinBackDays" type="number" min="1" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" />
                </div>
                <div>
                    <label asp-for="DelayHours" class="block text-xs text-neutral-500 mb-1">Wait before sending (hours)</label>
                    <input asp-for="DelayHours" type="number" min="0" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" />
                    <p class="text-[10px] text-neutral-400 mt-1">0 = send as soon as the sweep runs.</p>
                </div>
            </div>
            <div class="bg-white border border-neutral-200 rounded-sm p-5">
                <button type="submit" class="w-full px-4 py-2 text-sm bg-neutral-900 text-white rounded-sm hover:bg-neutral-700">Save</button>
                <p class="text-[11px] text-neutral-400 mt-2">Saved paused. Activate it from the next screen.</p>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
(function () {
    const sel = document.getElementById('trig');
    function sync() {
        const v = sel.value;
        document.querySelectorAll('[data-trig]').forEach(el => {
            el.style.display = el.getAttribute('data-trig') === v ? '' : 'none';
        });
    }
    sel.addEventListener('change', sync); sync();
})();
</script>
}
