@model List<SterlingLams.Web.Models.Domain.Automation>
@using SterlingLams.Web.Models.Domain
@{
    ViewData["Title"] = "Automations";
    string TriggerLabel(AutomationTrigger t) => t switch
    {
        AutomationTrigger.WelcomeNewCustomer => "Welcome new customer",
        AutomationTrigger.PostPurchase => "After purchase",
        AutomationTrigger.WinBackLapsed => "Win back lapsed",
        _ => t.ToString()
    };
}

<div class="mb-6 flex items-start justify-between gap-4 flex-wrap">
    <div>
        <h1 class="text-2xl font-light text-neutral-900">Automations</h1>
        <p class="text-sm text-neutral-500 mt-1">Automatic emails triggered by what customers do.</p>
    </div>
    <a asp-area="Marketing" asp-controller="Automations" asp-action="Create" class="px-4 py-2 text-sm bg-neutral-900 text-white rounded-sm hover:bg-neutral-700">+ New automation</a>
</div>

@if (!Model.Any())
{
    <div class="bg-white border border-neutral-200 rounded-sm p-12 text-center text-sm text-neutral-400">No automations yet. Create one to start sending welcome, post-purchase or win-back emails automatically.</div>
}
else
{
    <div class="bg-white border border-neutral-200 rounded-sm overflow-x-auto">
        <table class="w-full text-sm min-w-[680px]">
            <thead class="bg-neutral-50 text-neutral-500 text-xs">
                <tr><th class="text-left font-semibold px-4 py-3">Automation</th><th class="text-left font-semibold px-4 py-3">Trigger</th><th class="text-left font-semibold px-4 py-3">Status</th><th class="text-center font-semibold px-4 py-3">Sent</th><th class="px-4 py-3"></th></tr>
            </thead>
            <tbody class="divide-y divide-neutral-100">
                @foreach (var a in Model)
                {
                    <tr class="hover:bg-neutral-50">
                        <td class="px-4 py-2.5"><div class="text-neutral-800 font-medium">@a.Name</div><div class="text-xs text-neutral-400">@a.Subject</div></td>
                        <td class="px-4 py-2.5 text-neutral-600">@TriggerLabel(a.Trigger)@(a.DelayHours > 0 ? $" (+{a.DelayHours}h)" : "")</td>
                        <td class="px-4 py-2.5">@(a.IsActive ? Html.Raw("<span class=\"text-[10px] bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full\">Active</span>") : Html.Raw("<span class=\"text-[10px] bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full\">Paused</span>"))</td>
                        <td class="px-4 py-2.5 text-center text-neutral-600">@a.SentCount.ToString("N0")</td>
                        <td class="px-4 py-2.5 text-right"><a asp-area="Marketing" asp-controller="Automations" asp-action="Detail" asp-route-id="@a.Id" class="text-xs text-neutral-500 hover:text-neutral-900">Open →</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
