@model SterlingLams.Web.Models.Domain.Campaign
@using SterlingLams.Web.Models.Domain
@{
    ViewData["Title"] = Model.Id == 0 ? "New Campaign" : "Edit Campaign";
}

<div class="mb-6">
    <a asp-area="Marketing" asp-controller="Campaigns" asp-action="Index" class="text-xs text-neutral-400 hover:text-neutral-700">← All campaigns</a>
    <h1 class="text-2xl font-light text-neutral-900 mt-2">@ViewData["Title"]</h1>
</div>

<form asp-area="Marketing" asp-controller="Campaigns" asp-action="Save" method="post" id="campaign-form">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-4">
            <div class="bg-white border border-neutral-200 rounded-sm p-5 space-y-4">
                <div>
                    <label asp-for="Name" class="block text-xs text-neutral-500 mb-1">Campaign name (internal) *</label>
                    <input asp-for="Name" required class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
                <div>
                    <label asp-for="Subject" class="block text-xs text-neutral-500 mb-1">Email subject *</label>
                    <input asp-for="Subject" required class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
                <div>
                    <label class="block text-xs text-neutral-500 mb-1">Email body</label>
                    <partial name="_RichTextEditor" model='new SterlingLams.Web.Models.ViewModels.RichTextEditorVm(nameof(Model.BodyHtml), "campaign-body", Model.BodyHtml, "min-h-[18rem]")' />
                    <p class="text-[10px] text-neutral-400 mt-1">An unsubscribe footer is added automatically.</p>
                </div>
            </div>
        </div>

        <div class="lg:col-span-1 space-y-4">
            <div class="bg-white border border-neutral-200 rounded-sm p-5 space-y-4">
                <div class="text-sm font-medium text-neutral-700">Audience</div>
                <div>
                    <label asp-for="Audience" class="block text-xs text-neutral-500 mb-1">Segment</label>
                    <select asp-for="Audience" id="aud-select" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm bg-white">
                        @foreach (var a in Enum.GetValues<CampaignAudience>())
                        {
                            <option value="@a">@System.Text.RegularExpressions.Regex.Replace(a.ToString(), "([a-z])([A-Z])", "$1 $2")</option>
                        }
                    </select>
                </div>
                <div data-aud="RecentBuyers,LapsedCustomers">
                    <label asp-for="AudienceDays" class="block text-xs text-neutral-500 mb-1">Within / since (days)</label>
                    <input asp-for="AudienceDays" type="number" min="1" placeholder="e.g. 90" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" />
                </div>
                <div data-aud="HighValue">
                    <label asp-for="AudienceMinSpend" class="block text-xs text-neutral-500 mb-1">Min lifetime spend (₦)</label>
                    <input asp-for="AudienceMinSpend" type="number" step="0.01" min="0" placeholder="e.g. 50000" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" />
                </div>
                <div data-aud="ByState">
                    <label asp-for="AudienceState" class="block text-xs text-neutral-500 mb-1">State</label>
                    <input asp-for="AudienceState" placeholder="e.g. Lagos" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm" />
                </div>
                <button type="button" id="count-btn" class="w-full px-3 py-2 text-xs border border-neutral-300 rounded-sm hover:bg-neutral-50">Preview audience size</button>
                <p id="count-out" class="text-sm text-center text-neutral-600 hidden"></p>
            </div>
            <div class="bg-white border border-neutral-200 rounded-sm p-5">
                <button type="submit" class="w-full px-4 py-2 text-sm bg-neutral-900 text-white rounded-sm hover:bg-neutral-700">Save draft</button>
                <p class="text-[11px] text-neutral-400 mt-2">Saving keeps it a draft. Send it from the next screen.</p>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
(function () {
    const sel = document.getElementById('aud-select');
    function sync() {
        const v = sel.value;
        document.querySelectorAll('[data-aud]').forEach(el => {
            el.style.display = el.getAttribute('data-aud').split(',').includes(v) ? '' : 'none';
        });
    }
    sel.addEventListener('change', () => { sync(); document.getElementById('count-out').classList.add('hidden'); });
    sync();

    document.getElementById('count-btn').addEventListener('click', async () => {
        const form = document.getElementById('campaign-form');
        const fd = new FormData(form);
        const out = document.getElementById('count-out');
        out.classList.remove('hidden'); out.textContent = 'Counting…';
        try {
            const res = await fetch('/Marketing/Campaigns/Count', { method: 'POST', body: fd });
            const data = await res.json();
            out.textContent = (data.count ?? 0).toLocaleString() + ' recipient(s)';
        } catch { out.textContent = 'Could not estimate.'; }
    });
})();
</script>
}
