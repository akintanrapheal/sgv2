# ──────────────────────────────────────────────────────────────────────────────
# SterlingLams.com — Environment Variables
# Copy this to .env and fill in real values. Never commit .env to source control.
# In production, set these as system/process environment variables or use
# Azure Key Vault / AWS Secrets Manager / Docker secrets instead.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Database ──────────────────────────────────────────────────────────────────
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=sterlinglams;Username=postgres;Password=CHANGE_ME
ConnectionStrings__Redis=

# ─── Odoo ERP ──────────────────────────────────────────────────────────────────
Odoo__BaseUrl=https://your-odoo.example.com
Odoo__Database=your_odoo_db
Odoo__Username=api@sterlinglams.com
Odoo__ApiKey=YOUR_ODOO_API_KEY
Odoo__Stores__VictoriaIsland=1
Odoo__Stores__Ikeja=2
Odoo__Stores__Lekki=3
Odoo__InventoryCacheTtlSeconds=300

# ─── Payment Provider (Paystack | Stripe | Flutterwave) ───────────────────────
Payment__Provider=Paystack

# Paystack
Payment__Paystack__SecretKey=sk_live_YOUR_PAYSTACK_SECRET
Payment__Paystack__PublicKey=pk_live_YOUR_PAYSTACK_PUBLIC
Payment__Paystack__WebhookSecret=YOUR_PAYSTACK_WEBHOOK_HMAC
Payment__Paystack__BaseUrl=https://api.paystack.co

# Stripe (if using Stripe)
Payment__Stripe__SecretKey=sk_live_YOUR_STRIPE_SECRET
Payment__Stripe__PublishableKey=pk_live_YOUR_STRIPE_PUBLISHABLE
Payment__Stripe__WebhookSecret=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# Flutterwave (if using Flutterwave)
Payment__Flutterwave__SecretKey=FLWSECK-YOUR_SECRET
Payment__Flutterwave__PublicKey=FLWPUBK-YOUR_PUBLIC
Payment__Flutterwave__EncryptionKey=YOUR_ENCRYPTION_KEY
Payment__Flutterwave__BaseUrl=https://api.flutterwave.com/v3

# ─── Authentication ────────────────────────────────────────────────────────────
Authentication__Google__ClientId=YOUR_GOOGLE_CLIENT_ID
Authentication__Google__ClientSecret=YOUR_GOOGLE_CLIENT_SECRET

# ─── ASPNETCORE ────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
